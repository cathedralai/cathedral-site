---
/**
 * Centered agent profile modal. Empty on render; populated on open by
 * seeding from the clicked tile's data-* attributes first, then
 * enriching with a /v1/agents/{id} fetch. One modal per page; the
 * same dialog recycles across all wall + procession clicks so we
 * don't ship N copies of identical markup.
 *
 * Triggered by:
 *   - any element with `data-agent-modal-open="<agent_id>"` (wall
 *     stones, procession rows, vitals "you" links, etc.). The dialog's
 *     delegated click listener reads the rest of the seed (display
 *     name, score, rank, ran-at) straight off the clicked element so
 *     the modal renders the mason's real handle the instant it opens.
 *   - a `cd:agent-modal-open` CustomEvent with
 *     `detail: { agentId, seed? }` (kept as a public API for callers
 *     that want to open the modal without an originating click).
 *
 * The publisher API base is injected as a data attribute at build
 * time so the inline script knows where to fetch profiles. Two
 * defensive layers cover the historical "Unknown mason" failure
 * modes:
 *   1) The static cathedral.computer deploy has no /api/cathedral
 *      proxy, so the URL must be absolute (PR #123 fix).
 *   2) The publisher does not send CORS headers from
 *      cathedral.computer, so the in-browser fetch can fail.
 *      Seeding the modal from the tile's data-* attributes means
 *      every scored stone shows its mason's real display_name even
 *      if the fetch never lands.
 */
const apiBase =
  (import.meta.env.PUBLIC_CATHEDRAL_API_URL as string | undefined) ||
  'https://cathedral-publisher-production.up.railway.app'
---

<dialog class="agent-dialog" data-agent-dialog data-api-base={apiBase}>
  <form method="dialog" class="agent-shell">
    <header class="agent-head">
      <span class="agent-k" data-agent-rank>·</span>
      <h2 class="agent-title" data-agent-name>—</h2>
      <button type="submit" class="agent-x" value="close" aria-label="Close">&times;</button>
    </header>

    <div class="agent-meta">
      <span class="meta-pair">
        <span class="ml">hotkey</span>
        <code data-agent-hotkey>—</code>
      </span>
      <span class="meta-pair">
        <span class="ml">score</span>
        <strong data-agent-score>—</strong>
      </span>
      <span class="meta-pair">
        <span class="ml">vigil</span>
        <span data-agent-vigil>—</span>
      </span>
      <span class="meta-pair">
        <span class="ml">last stone</span>
        <span data-agent-last>—</span>
      </span>
    </div>

    <p class="agent-bio" data-agent-bio hidden></p>

    <section class="agent-section card-section" data-agent-card hidden>
      <h3 class="section-k" data-agent-card-eyebrow>Submitted card · pending</h3>
      <h4 class="card-title" data-agent-card-title>—</h4>
      <p class="card-summary" data-agent-card-summary></p>
      <dl class="card-fields" data-agent-card-fields></dl>
      <ul class="card-cites" data-agent-card-cites hidden></ul>
      <p class="card-foot" data-agent-card-foot></p>
    </section>

    <section class="agent-section" data-agent-history hidden>
      <h3 class="section-k">Score history · 30d</h3>
      <div class="sparkline" data-agent-spark></div>
    </section>

    <section class="agent-section" data-agent-recent hidden>
      <h3 class="section-k">Recent stones</h3>
      <ol class="agent-recent-list" data-agent-recent-list></ol>
    </section>

    <p class="agent-empty" data-agent-empty hidden>
      No profile yet. Mason hasn't shipped a scored stone.
    </p>

    <p class="agent-loading" data-agent-loading>Loading…</p>
  </form>
</dialog>

<script is:inline>
  (function () {
    var dialog = document.querySelector('[data-agent-dialog]')
    if (!dialog || typeof dialog.showModal !== 'function') return
    // Build-time-injected publisher base. The static deploy has no
    // /api/cathedral proxy, so we have to fetch the publisher directly.
    var API_BASE = dialog.getAttribute('data-api-base') || ''

    var byKey = {
      name: dialog.querySelector('[data-agent-name]'),
      rank: dialog.querySelector('[data-agent-rank]'),
      hotkey: dialog.querySelector('[data-agent-hotkey]'),
      score: dialog.querySelector('[data-agent-score]'),
      vigil: dialog.querySelector('[data-agent-vigil]'),
      last: dialog.querySelector('[data-agent-last]'),
      bio: dialog.querySelector('[data-agent-bio]'),
      cardSec: dialog.querySelector('[data-agent-card]'),
      cardEyebrow: dialog.querySelector('[data-agent-card-eyebrow]'),
      cardTitle: dialog.querySelector('[data-agent-card-title]'),
      cardSummary: dialog.querySelector('[data-agent-card-summary]'),
      cardFields: dialog.querySelector('[data-agent-card-fields]'),
      cardCites: dialog.querySelector('[data-agent-card-cites]'),
      cardFoot: dialog.querySelector('[data-agent-card-foot]'),
      historySec: dialog.querySelector('[data-agent-history]'),
      spark: dialog.querySelector('[data-agent-spark]'),
      recentSec: dialog.querySelector('[data-agent-recent]'),
      recentList: dialog.querySelector('[data-agent-recent-list]'),
      empty: dialog.querySelector('[data-agent-empty]'),
      loading: dialog.querySelector('[data-agent-loading]'),
    }

    var cache = {}
    var currentToken = 0

    function fmtScore(n) {
      if (n === null || n === undefined) return '—'
      return Number(n).toFixed(2)
    }
    function relTime(iso) {
      if (!iso) return '—'
      var ms = Date.now() - new Date(iso).getTime()
      if (ms < 60000) return Math.max(0, Math.floor(ms / 1000)) + 's ago'
      if (ms < 3600000) return Math.floor(ms / 60000) + 'm ago'
      if (ms < 86400000) return Math.floor(ms / 3600000) + 'h ago'
      return Math.floor(ms / 86400000) + 'd ago'
    }
    function truncHotkey(s) {
      if (!s) return '—'
      if (s.length <= 14) return s
      return s.slice(0, 6) + '…' + s.slice(-4)
    }
    function vigilDays(items) {
      if (!items || !items.length) return 0
      var cutoff = Date.now() - 30 * 86400000
      var days = {}
      for (var i = 0; i < items.length; i++) {
        var t = new Date(items[i].ran_at).getTime()
        if (t < cutoff) continue
        days[new Date(items[i].ran_at).toISOString().slice(0, 10)] = true
      }
      return Object.keys(days).length
    }
    function sparkPath(history) {
      if (!history || history.length < 2) return ''
      var W = 200, H = 36
      var min = Infinity, max = -Infinity
      for (var i = 0; i < history.length; i++) {
        var v = history[i].score
        if (v < min) min = v
        if (v > max) max = v
      }
      var range = (max - min) || 1
      var pts = history.map(function (h, i) {
        var x = (i / (history.length - 1)) * W
        var y = H - ((h.score - min) / range) * H
        return x.toFixed(1) + ',' + y.toFixed(1)
      }).join(' ')
      return '<svg viewBox="0 0 ' + W + ' ' + H + '" aria-hidden="true" width="100%" height="36">' +
        '<polyline fill="none" stroke="currentColor" stroke-width="1.2" points="' + pts + '"/>' +
        '</svg>'
    }

    // Render the actual card the mason submitted — title, summary,
    // narrative fields, citations. This is the load-bearing payload
    // visitors come to inspect; "score 0.94" is meaningless without
    // showing them what the mason actually wrote that earned that score.
    function renderCard(card, score, ranAt) {
      if (!card || typeof card !== 'object') {
        byKey.cardSec.hidden = true
        return
      }
      byKey.cardSec.hidden = false
      var eyebrow = 'Submitted card'
      if (score !== null && score !== undefined && !isNaN(parseFloat(score))) {
        eyebrow += ' · scored ' + fmtScore(parseFloat(score))
      }
      if (ranAt) eyebrow += ' · ' + relTime(ranAt)
      byKey.cardEyebrow.textContent = eyebrow
      byKey.cardTitle.textContent = card.title || '(untitled)'
      byKey.cardSummary.textContent = card.summary || ''
      byKey.cardSummary.hidden = !card.summary

      // Narrative fields rendered as a definition list. Skip empties so
      // the modal isn't padded with placeholder dashes — masons who
      // shipped a thin card show as a thin card.
      var fields = [
        ['What changed', card.what_changed],
        ['Why it matters', card.why_it_matters],
        ['Action notes', card.action_notes],
        ['Risks', card.risks],
      ]
      var dl = ''
      for (var i = 0; i < fields.length; i++) {
        var label = fields[i][0]
        var val = fields[i][1]
        if (!val) continue
        dl += '<dt>' + escapeHtml(label) + '</dt>' +
              '<dd>' + escapeHtml(String(val)) + '</dd>'
      }
      byKey.cardFields.innerHTML = dl
      byKey.cardFields.hidden = !dl

      var cites = (card.citations || []).filter(function (c) { return c && c.url })
      if (cites.length) {
        var cul = ''
        for (var j = 0; j < cites.length; j++) {
          var c = cites[j]
          var href = c.url
          var label = c.class ? '[' + c.class + '] ' : ''
          cul += '<li><a href="' + escapeHtml(href) + '" target="_blank" rel="noopener noreferrer">' +
                 escapeHtml(label + href) + '</a></li>'
        }
        byKey.cardCites.innerHTML = cul
        byKey.cardCites.hidden = false
      } else {
        byKey.cardCites.hidden = true
      }

      var foot = []
      if (card.jurisdiction) foot.push(String(card.jurisdiction).toUpperCase())
      if (card.topic) foot.push(card.topic)
      if (card.confidence !== undefined && card.confidence !== null) {
        foot.push('confidence ' + fmtScore(card.confidence))
      }
      if (card.no_legal_advice) foot.push('not legal advice')
      byKey.cardFoot.textContent = foot.join(' · ')
      byKey.cardFoot.hidden = !foot.length
    }

    function render(profile) {
      byKey.loading.hidden = true
      byKey.empty.hidden = !profile || !profile.id
      if (!profile || !profile.id) {
        byKey.name.textContent = 'Unknown mason'
        byKey.rank.textContent = '·'
        byKey.hotkey.textContent = '—'
        byKey.score.textContent = '—'
        byKey.vigil.textContent = '—'
        byKey.last.textContent = '—'
        byKey.bio.hidden = true
        byKey.cardSec.hidden = true
        byKey.historySec.hidden = true
        byKey.recentSec.hidden = true
        return
      }
      // Name fallback chain: display_name → truncated hotkey →
      // truncated agent id. A short hotkey is more useful than 'Unknown
      // mason' because the visitor can still verify the mason on chain.
      var nm = profile.display_name
        || (profile.miner_hotkey ? truncHotkey(profile.miner_hotkey) : '')
        || profile.id.slice(0, 8)
      byKey.name.textContent = '@' + nm
      byKey.rank.textContent = profile.current_rank
        ? 'rank ' + String(profile.current_rank).padStart(2, '0')
        : 'unranked'
      byKey.hotkey.textContent = truncHotkey(profile.miner_hotkey)
      byKey.score.textContent = fmtScore(profile.current_score)
      byKey.vigil.textContent = vigilDays(profile.recent_evals) + 'd'
      var lastIso = profile.recent_evals && profile.recent_evals[0]
        ? profile.recent_evals[0].ran_at
        : profile.submitted_at
      byKey.last.textContent = relTime(lastIso)
      if (profile.bio) {
        byKey.bio.textContent = profile.bio
        byKey.bio.hidden = false
      } else {
        byKey.bio.hidden = true
      }
      // Surface the most recent submitted card. This is the actual
      // content the mason produced and Cathedral scored — the reason
      // visitors clicked into the modal in the first place.
      var latest = profile.recent_evals && profile.recent_evals[0]
      if (latest && latest.output_card) {
        renderCard(latest.output_card, latest.weighted_score, latest.ran_at)
      } else {
        byKey.cardSec.hidden = true
      }
      if (profile.score_history && profile.score_history.length >= 2) {
        byKey.spark.innerHTML = sparkPath(profile.score_history)
        byKey.historySec.hidden = false
      } else {
        byKey.historySec.hidden = true
      }
      var recent = (profile.recent_evals || []).slice(0, 5)
      if (recent.length) {
        var html = ''
        for (var i = 0; i < recent.length; i++) {
          var e = recent[i]
          var title = (e.output_card && e.output_card.title) || ('Card ' + (e.id || '').slice(0, 6))
          html += '<li>' +
            '<span class="rs-sc">' + fmtScore(e.weighted_score) + '</span>' +
            '<span class="rs-tt">' + escapeHtml(title) + '</span>' +
            '<span class="rs-when">' + relTime(e.ran_at) + '</span>' +
            '</li>'
        }
        byKey.recentList.innerHTML = html
        byKey.recentSec.hidden = false
      } else {
        byKey.recentSec.hidden = true
      }
    }

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
    }

    function showLoading() {
      byKey.loading.hidden = false
      byKey.empty.hidden = true
      byKey.bio.hidden = true
      byKey.cardSec.hidden = true
      byKey.historySec.hidden = true
      byKey.recentSec.hidden = true
      byKey.name.textContent = 'Loading…'
      byKey.rank.textContent = '·'
      byKey.hotkey.textContent = '—'
      byKey.score.textContent = '—'
      byKey.vigil.textContent = '—'
      byKey.last.textContent = '—'
    }

    // Seed render — paint everything the caller already knows from the
    // clicked tile (name, score, rank, last-eval). The publisher fetch
    // adds vigil, sparkline, and recent stones on top, but the modal
    // never shows "Loading…" or "Unknown mason" for a tile that already
    // carries a usable name. This is the load-bearing guarantee:
    // scored stones display their mason's handle the instant the modal
    // opens, regardless of network state (the publisher does not send
    // CORS headers from cathedral.computer, so the in-browser fetch can
    // fail; without the seed every click would fall through to the
    // "Unknown mason" empty-state branch).
    function seedRender(seed) {
      if (!seed) return
      byKey.loading.hidden = true
      byKey.empty.hidden = true
      byKey.cardSec.hidden = true
      byKey.historySec.hidden = true
      byKey.recentSec.hidden = true
      var nm = (seed.displayName || '').trim()
      byKey.name.textContent = nm ? '@' + nm : '—'
      if (seed.rank) {
        byKey.rank.textContent = 'rank ' + String(seed.rank).padStart(2, '0')
      } else if (seed.state === 'evaluating') {
        byKey.rank.textContent = 'evaluating'
      } else {
        byKey.rank.textContent = '·'
      }
      byKey.hotkey.textContent = '—'
      if (seed.state === 'evaluating') {
        byKey.score.textContent = '·'
      } else if (seed.score) {
        byKey.score.textContent = fmtScore(parseFloat(seed.score))
      } else {
        byKey.score.textContent = '—'
      }
      byKey.vigil.textContent = '—'
      byKey.last.textContent = seed.ranAt ? relTime(seed.ranAt) : '—'
      if (seed.bio) {
        byKey.bio.textContent = seed.bio
        byKey.bio.hidden = false
      } else {
        byKey.bio.hidden = true
      }
    }

    function open(agentId, seed) {
      if (!agentId) return
      dialog.showModal()
      if (cache[agentId]) {
        render(cache[agentId])
        return
      }
      var hasSeed = !!(seed && (seed.displayName || seed.score || seed.rank))
      if (hasSeed) {
        seedRender(seed)
      } else {
        showLoading()
      }
      var token = ++currentToken
      var url = API_BASE + '/v1/agents/' + encodeURIComponent(agentId)
      fetch(url, {
        headers: { accept: 'application/json' },
      })
        .then(function (r) { return r.ok ? r.json() : null })
        .catch(function () { return null })
        .then(function (data) {
          if (token !== currentToken) return
          cache[agentId] = data
          // If the fetch returned a real profile, render the rich
          // version. If it failed (CORS, network, 404) and we already
          // painted a usable seed, leave the seed on screen — falling
          // through to render(null) would replace the real handle with
          // "Unknown mason", which is exactly the bug this fix exists
          // to prevent.
          if (data && data.id) {
            render(data)
          } else if (!hasSeed) {
            render(data)
          }
        })
    }

    function seedFromEl(el) {
      if (!el) return null
      return {
        displayName: el.getAttribute('data-agent-name') || '',
        bio: el.getAttribute('data-agent-bio') || '',
        score: el.getAttribute('data-score') || '',
        rank: el.getAttribute('data-rank') || '',
        ranAt: el.getAttribute('data-ran-at') || el.getAttribute('data-submitted-at') || '',
        state: el.getAttribute('data-state') || '',
      }
    }

    // Custom-event entry point (used by Wall.astro's click handler,
    // which passes the tile's seed values in event.detail.seed so
    // scored stones paint their name without waiting for the fetch).
    document.addEventListener('cd:agent-modal-open', function (e) {
      var d = (e && e.detail) || {}
      open(d.agentId, d.seed)
    })

    // Click-attribute entry point (procession rows, you-block). Read
    // the seed straight off the clicked element so procession clicks
    // also get instant-paint without needing a CustomEvent dispatcher.
    document.addEventListener('click', function (e) {
      var el = e.target.closest('[data-agent-modal-open]')
      if (!el) return
      var id = el.getAttribute('data-agent-modal-open')
      if (!id) return
      e.preventDefault()
      open(id, seedFromEl(el))
    })
  })()
</script>

<style>
  .agent-dialog {
    border: 1px solid var(--border-soft);
    background: var(--bg);
    color: var(--fg);
    padding: 0;
    max-width: min(640px, calc(100vw - 32px));
    width: 100%;
    margin: auto;
  }
  .agent-dialog::backdrop {
    background: rgba(0, 0, 0, 0.62);
  }
  .agent-shell {
    margin: 0;
    padding: 22px 24px 24px;
    display: grid;
    gap: 16px;
  }
  .agent-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    position: relative;
  }
  .agent-k {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .agent-title {
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: 24px;
    margin: 0;
    color: var(--fg);
    flex: 1;
    min-width: 0;
  }
  .agent-x {
    background: none;
    border: 0;
    color: var(--dim);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    padding: 0 4px;
    font-family: inherit;
    transition: color 140ms;
  }
  .agent-x:hover, .agent-x:focus-visible {
    color: var(--accent);
    outline: 2px solid transparent;
  }
  .agent-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding: 12px 14px;
    border: 1px solid var(--border-soft);
    background: var(--surface);
  }
  .meta-pair {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .meta-pair .ml {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .meta-pair code,
  .meta-pair strong,
  .meta-pair span:last-child {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .meta-pair strong { font-weight: 500; }
  .agent-bio {
    margin: 0;
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg);
    max-width: 60ch;
  }
  .agent-section {
    display: grid;
    gap: 8px;
  }
  .section-k {
    margin: 0;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 400;
  }
  .sparkline {
    color: var(--accent);
    border: 1px solid var(--border-soft);
    background: var(--surface);
    padding: 8px 10px;
  }
  .agent-recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 4px;
  }
  .agent-recent-list :global(li) {
    display: grid;
    grid-template-columns: 56px 1fr 72px;
    gap: 10px;
    align-items: baseline;
    padding: 7px 10px;
    border: 1px solid var(--border-soft);
    background: var(--surface);
  }
  .agent-recent-list :global(.rs-sc) {
    font-family: var(--serif);
    font-size: 16px;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .agent-recent-list :global(.rs-tt) {
    font-size: 12.5px;
    color: var(--fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .agent-recent-list :global(.rs-when) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--dim);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .card-section {
    border: 1px solid var(--border-soft);
    background: var(--surface);
    padding: 14px 16px 16px;
    gap: 10px;
  }
  .card-title {
    margin: 0;
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: 18px;
    line-height: 1.3;
    color: var(--fg);
  }
  .card-summary {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg);
    max-width: 64ch;
  }
  .card-fields {
    margin: 4px 0 0;
    display: grid;
    grid-template-columns: 132px 1fr;
    gap: 6px 14px;
    font-size: 13px;
    line-height: 1.5;
  }
  .card-fields :global(dt) {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    padding-top: 3px;
  }
  .card-fields :global(dd) {
    margin: 0;
    color: var(--fg);
  }
  .card-cites {
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 4px;
    font-family: var(--mono);
    font-size: 11px;
  }
  .card-cites :global(li) {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card-cites :global(a) {
    color: var(--accent);
    text-decoration: none;
  }
  .card-cites :global(a:hover),
  .card-cites :global(a:focus-visible) {
    text-decoration: underline;
  }
  .card-foot {
    margin: 6px 0 0;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .agent-empty,
  .agent-loading {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
  }
  @media (max-width: 540px) {
    .card-fields { grid-template-columns: 1fr; gap: 2px 0; }
