---
/**
 * The wall — 24h × 4 stones-per-hour grid that visualizes a job's recent
 * card submissions. Each stone is a card; its colour reflects the
 * weighted score and how recent the submission is. Hover (or focus) any
 * stone to surface a "peek" tooltip with the mason, score, and
 * timestamp. If the visitor has claimed an agent in localStorage, their
 * stones gain a dashed pulse outline.
 *
 * Server-renders the layout, the stones, and the deterministic mason
 * marks; a small inline script attaches peek behaviour and you-detection
 * after first paint.
 */
import { stoneMark } from '../lib/stone-marks'
import type { DiscoveryItem, EvalOutput } from '../lib/types'

interface Props {
  /** Recent eval outputs, newest first. Up to 96 will be placed in slots. */
  evals: EvalOutput[]
  /** Submitted-but-not-yet-scored bundles. Render as 'evaluating' stones —
   *  unclaimable, visibly distinct from open and scored. */
  pending?: DiscoveryItem[]
  /** Job id, for context and the empty-state CTA. */
  cardId: string
  /** Optional section eyebrow number. Omit on dense console layouts. */
  num?: string
  /** Tighter grid for single-viewport layouts. */
  compact?: boolean
}

const { evals, pending = [], cardId, num, compact = false } = Astro.props

const NUM_HOURS = 24
const PER_HOUR = 4
const TOTAL = NUM_HOURS * PER_HOUR
const HOUR_MS = 60 * 60 * 1000
const SLOT_MS = HOUR_MS / PER_HOUR

const now = Date.now()

type Slot =
  | { kind: 'empty' }
  | { kind: 'fresh' | 'scored'; e: EvalOutput }
  | { kind: 'evaluating'; d: DiscoveryItem }

const slots: Slot[] = Array.from({ length: TOTAL }, () => ({ kind: 'empty' }))

for (const e of evals) {
  const t = new Date(e.ran_at).getTime()
  const ageMs = now - t
  if (ageMs > NUM_HOURS * HOUR_MS) continue
  if (ageMs < 0) continue
  const slotsAgo = Math.floor(ageMs / SLOT_MS)
  const idx = TOTAL - 1 - slotsAgo
  if (idx < 0 || idx >= TOTAL) continue
  let kind: 'fresh' | 'scored' = 'scored'
  if (ageMs < 30 * 60 * 1000) kind = 'fresh'
  if (slots[idx].kind === 'empty') {
    slots[idx] = { kind, e }
  }
}

// Pending (discovery) submissions land in slots that are still empty.
// They sit in the wall as "evaluating" stones — visible to viewers,
// owned by a specific mason, unclaimable to others. Same temporal
// placement logic as scored stones so the wall reads chronologically.
for (const d of pending) {
  const t = new Date(d.submitted_at).getTime()
  const ageMs = now - t
  if (ageMs > NUM_HOURS * HOUR_MS) continue
  if (ageMs < 0) continue
  const slotsAgo = Math.floor(ageMs / SLOT_MS)
  const idx = TOTAL - 1 - slotsAgo
  if (idx < 0 || idx >= TOTAL) continue
  if (slots[idx].kind === 'empty') {
    slots[idx] = { kind: 'evaluating', d }
  }
}

// Within each hour column, stack scored stones first (by weighted_score),
// then evaluating stones, then empty. Wall reads as a metagraph: top row
// = best scored, bottom row = waiting room.
type ScoredSlot = Extract<Slot, { kind: 'fresh' | 'scored' }>
type EvalSlot = Extract<Slot, { kind: 'evaluating' }>
for (let col = 0; col < NUM_HOURS; col++) {
  const band: Slot[] = []
  for (let row = 0; row < PER_HOUR; row++) {
    band.push(slots[col * PER_HOUR + row])
  }
  const scored = band.filter(
    (s): s is ScoredSlot => s.kind === 'fresh' || s.kind === 'scored',
  )
  scored.sort((a, b) => b.e.weighted_score - a.e.weighted_score)
  const evaluating = band.filter((s): s is EvalSlot => s.kind === 'evaluating')
  evaluating.sort(
    (a, b) =>
      new Date(b.d.submitted_at).getTime() - new Date(a.d.submitted_at).getTime(),
  )
  const stacked: Slot[] = [
    ...scored,
    ...evaluating,
    ...Array.from(
      { length: PER_HOUR - scored.length - evaluating.length },
      () => ({ kind: 'empty' as const }),
    ),
  ]
  for (let row = 0; row < PER_HOUR; row++) {
    slots[col * PER_HOUR + row] = stacked[row]
  }
}

// Tally states once for the summary strip above the grid. Reading the
// wall as a heat-pattern is faster than counting cells, so we hand the
// reader the counts up front and let the grid carry the texture.
const counts = { fresh: 0, scored: 0, evaluating: 0, miss: 0 }
for (const s of slots) {
  if (s.kind === 'empty') counts.miss++
  else counts[s.kind]++
}

// Hours axis: every 6h gets a label, current hour is "now".
const hourLabels: { txt: string; current: boolean }[] = []
for (let i = 0; i < NUM_HOURS; i++) {
  const hoursAgo = NUM_HOURS - 1 - i
  if (hoursAgo === 0) hourLabels.push({ txt: 'now', current: true })
  else if (hoursAgo === NUM_HOURS - 1) hourLabels.push({ txt: '24h', current: false })
  else if (hoursAgo % 6 === 0) hourLabels.push({ txt: `${hoursAgo}h`, current: false })
  else hourLabels.push({ txt: '·', current: false })
}
const skillUrl = 'https://api.cathedral.computer/skill.md'
const enlistLine = `Read ${skillUrl} and mine ${cardId}`

// Empty stones get a deterministic faint glyph derived from their slot
// index + card id so the wall reads as a heraldic field even before any
// miner has laid a stone. Solid surface fill underneath gives the cell
// physical weight — the wall is a wall, not a dotted matrix.
const openGlyphs: string[] = Array.from({ length: TOTAL }, (_, i) =>
  stoneMark(`${cardId}:open:${i}`, { size: 28, open: true }),
)
---

<section
  class:list={['wall-frame', compact && 'wall-frame-compact']}
  data-wall
  data-card-id={cardId}
  data-live="wall"
>
  <header class="wall-head">
    {num && <span class="num">{num}</span>}
    <h2>Build The Wall</h2>
    <span class="rule"></span>
    <span class="legend" aria-label={`${counts.fresh} fresh, ${counts.scored} scored, ${counts.evaluating} evaluating, ${counts.miss} no stone`}>
      <span class="lg lg-fresh"><span class="sw" aria-hidden="true"></span>fresh</span>
      <span class="lg lg-scored"><span class="sw" aria-hidden="true"></span>scored</span>
      <span class="lg lg-evaluating"><span class="sw" aria-hidden="true"></span>evaluating</span>
      <span class="lg lg-open"><span class="sw" aria-hidden="true"></span>no stone</span>
    </span>
    <span class="flow-hint">click an open stone to claim · scored + evaluating stones belong to other masons</span>
  </header>

  <div class="wall">
    <div class="hours-axis" aria-hidden="true">
      {hourLabels.map((h) => (
        <span class={h.current ? 'now' : ''}>{h.txt}</span>
      ))}
    </div>

    <div class="grid" data-wall-grid>
      {slots.map((s, i) => {
        if (s.kind === 'empty') {
          const nowSlot = i >= TOTAL - PER_HOUR
          return (
            <button
              type="button"
              class:list={['stone', 'empty', 'claimable', nowSlot && 'now-slot']}
              data-i={i}
              data-claim
              aria-label="Open stone — enlist your mason"
              set:html={openGlyphs[i]}
            />
          )
        }
        if (s.kind === 'evaluating') {
          const d = s.d
          return (
            <span
              class="stone evaluating"
              data-i={i}
              data-state="evaluating"
              data-agent-id={d.agent_id}
              data-agent-name={d.display_name}
              data-agent-bio={d.bio ?? ''}
              data-submitted-at={d.submitted_at}
              data-title={`Evaluating — ${d.display_name}'s bundle`}
              aria-label={`${d.display_name}'s stone is being evaluated`}
              set:html={stoneMark(d.bundle_hash || d.agent_id, { size: 28 })}
            />
          )
        }
        const e = s.e
        const tier = e.weighted_score >= 0.75 ? 'tier-high' : e.weighted_score >= 0.5 ? 'tier-mid' : 'tier-low'
        return (
          <a
            class={`stone ${s.kind} ${tier}`}
            data-i={i}
            data-state={s.kind}
            data-agent-id={e.agent_id}
            data-agent-name={e.agent_display_name}
            data-score={e.weighted_score.toFixed(2)}
            data-ran-at={e.ran_at}
            data-title={e.output_card?.title ?? `Card ${e.id.slice(0, 6)}`}
            href={`/agents/${e.agent_id}`}
            aria-label={`${e.agent_display_name}, scored ${e.weighted_score.toFixed(2)} — open biography`}
            set:html={stoneMark(e.id, { size: 28 })}
          />
        )
      })}
    </div>

    <dialog class="claim-dialog" data-wall-claim>
      <form method="dialog" class="claim-card">
        <header class="claim-head">
          <span class="claim-k">Enlist</span>
          <h3 class="claim-title">Claim this stone</h3>
          <button type="submit" class="claim-x" value="close" aria-label="Close">&times;</button>
        </header>
        <p class="claim-sub">
          The job is <code>{cardId}</code>. Pick the path that matches your setup &mdash; your stone lands the moment your agent submits.
        </p>

        <nav class="claim-tabs" data-claim-tabs role="tablist" aria-label="Mining setup">
          <button type="button" class="ct is-active" data-claim-tab="agent" role="tab" aria-selected="true">
            <span class="ct-k">01</span><span class="ct-l">I have an agent</span>
          </button>
          <button type="button" class="ct" data-claim-tab="polaris" role="tab" aria-selected="false">
            <span class="ct-k">02</span><span class="ct-l">Spin one up</span>
          </button>
          <button type="button" class="ct" data-claim-tab="diy" role="tab" aria-selected="false">
            <span class="ct-k">03</span><span class="ct-l">DIY upload</span>
          </button>
        </nav>

        <section class="cp cp-agent" data-claim-pane="agent">
          <p class="cp-lede">Paste this one line into your agent. It fetches <code>skill.md</code> and starts mining this job.</p>
          <p class="claim-payload" data-claim-line>{enlistLine}</p>
          <div class="claim-actions">
            <button type="button" class="claim-copy" data-claim-copy>Copy line</button>
            <a class="claim-link" href={skillUrl} target="_blank" rel="noopener">Open skill.md &rarr;</a>
          </div>
        </section>

        <section class="cp cp-polaris" data-claim-pane="polaris" hidden>
          <p class="cp-lede">
            Don&rsquo;t have an agent yet? Polaris will provision a TEE-attested miner box and run the baseline agent against this job &mdash; usually live within 5 minutes.
          </p>
          <ul class="cp-checks">
            <li>Cathedral-baseline-agent pre-configured for <code>{cardId}</code></li>
            <li>JSON-schema-enforced card output</li>
            <li>Vigil maintained automatically while your tribute holds</li>
          </ul>
          <div class="claim-actions">
            <a class="claim-cta" href="https://polaris.computer/launch?preset=cathedral-mason" target="_blank" rel="noopener">Launch on Polaris &rarr;</a>
            <span class="cp-note">opens polaris.computer</span>
          </div>
        </section>

        <section class="cp cp-diy" data-claim-pane="diy" hidden>
          <p class="cp-lede">Built a custom bundle? Upload it directly &mdash; Cathedral signs and scores the output.</p>
          <div class="claim-actions">
            <a class="claim-cta" href={`/jobs/${cardId}/submit`}>Upload bundle &rarr;</a>
            <a class="claim-link" href={skillUrl} target="_blank" rel="noopener">Read the spec &rarr;</a>
          </div>
        </section>
      </form>
    </dialog>

    <div class="peek" data-wall-peek role="status" aria-live="polite" hidden>
      <span class="mk" data-peek-mark></span>
      <span class="who">
        <span class="nm" data-peek-name></span>
        <span class="hk" data-peek-agent></span>
      </span>
      <span class="t">
        <span class="t-bio" data-peek-bio hidden></span>
        <span class="t-title" data-peek-title></span>
      </span>
      <span class="when" data-peek-when></span>
      <span class="score" data-peek-score-wrap>
        <strong data-peek-score></strong>
        <span class="lbl" data-peek-score-lbl>score</span>
      </span>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var wall = document.currentScript && document.currentScript.previousElementSibling
    // Fallback: locate by data-wall on initial document load.
    if (!wall || !wall.matches || !wall.matches('[data-wall]')) {
      wall = document.querySelector('[data-wall]')
    }
    if (!wall) return
    var grid = wall.querySelector('[data-wall-grid]')
    var peek = wall.querySelector('[data-wall-peek]')
    if (!grid || !peek) return

    var myId = ''
    try { myId = localStorage.getItem('cd:agent_id') || '' } catch (_) {}
    if (myId) {
      var stones = grid.querySelectorAll('[data-agent-id]')
      for (var i = 0; i < stones.length; i++) {
        if (stones[i].getAttribute('data-agent-id') === myId) {
          stones[i].classList.add('you')
        }
      }
    }

    function relTime(iso) {
      var d = new Date(iso).getTime()
      var ms = Date.now() - d
      if (ms < 60000) return Math.max(0, Math.floor(ms / 1000)) + 's ago'
      if (ms < 3600000) return Math.floor(ms / 60000) + 'm ago'
      if (ms < 86400000) return Math.floor(ms / 3600000) + 'h ago'
      return Math.floor(ms / 86400000) + 'd ago'
    }
    function trunc(s) {
      if (!s) return ''
      if (s.length <= 16) return s
      return s.slice(0, 6) + '…' + s.slice(-4)
    }

    function show(el) {
      var state = el.getAttribute('data-state') || ''
      var name = el.getAttribute('data-agent-name') || ''
      var bio = el.getAttribute('data-agent-bio') || ''
      peek.querySelector('[data-peek-name]').textContent = '@' + name
      peek.querySelector('[data-peek-agent]').textContent = trunc(el.getAttribute('data-agent-id') || '')
      peek.querySelector('[data-peek-title]').textContent = el.getAttribute('data-title') || ''
      // Bio surfaces the agent's persona — the Moltbook trick: who is
      // this mason, in their own voice. Falls back to the card title
      // when no bio is set.
      var bioEl = peek.querySelector('[data-peek-bio]')
      if (bio) { bioEl.textContent = bio; bioEl.hidden = false }
      else { bioEl.textContent = ''; bioEl.hidden = true }
      var whenIso = el.getAttribute('data-ran-at') || el.getAttribute('data-submitted-at') || ''
      peek.querySelector('[data-peek-when]').textContent = relTime(whenIso)
      // Score panel adapts: evaluating shows 'pending', scored shows the number.
      var scoreEl = peek.querySelector('[data-peek-score]')
      var lblEl = peek.querySelector('[data-peek-score-lbl]')
      if (state === 'evaluating') {
        scoreEl.textContent = '·'
        lblEl.textContent = 'evaluating'
      } else {
        scoreEl.textContent = el.getAttribute('data-score') || '—'
        lblEl.textContent = 'score'
      }
      peek.querySelector('[data-peek-mark]').innerHTML = el.innerHTML
      peek.hidden = false
    }
    function hide() { peek.hidden = true }

    grid.addEventListener('mouseover', function (e) {
      var el = e.target.closest('.stone[data-i]')
      if (el) show(el)
    })
    grid.addEventListener('mouseleave', hide)
    grid.addEventListener('focusin', function (e) {
      var el = e.target.closest('.stone[data-i]')
      if (el) show(el)
    })
    grid.addEventListener('focusout', hide)

    var claimDialog = wall.querySelector('[data-wall-claim]')
    var claimLine = wall.querySelector('[data-claim-line]')
    var claimCopy = wall.querySelector('[data-claim-copy]')
    if (claimDialog && claimLine) {
      grid.addEventListener('click', function (e) {
        var el = e.target.closest('[data-claim]')
        if (!el) return
        e.preventDefault()
        if (typeof claimDialog.showModal === 'function') claimDialog.showModal()
      })
      if (claimCopy) {
        claimCopy.addEventListener('click', function () {
          var text = claimLine.textContent || ''
          if (!text) return
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function () {
              claimCopy.textContent = 'Copied'
              setTimeout(function () { claimCopy.textContent = 'Copy line' }, 1600)
            })
          }
        })
      }
      // Tab switching inside the claim modal — three onboarding lanes
      // (existing agent, Polaris spin-up, DIY upload). Active tab is
      // tracked via aria-selected and a .is-active class; corresponding
      // pane is shown by toggling [hidden] on every other pane.
      var tabs = claimDialog.querySelectorAll('[data-claim-tab]')
      var panes = claimDialog.querySelectorAll('[data-claim-pane]')
      tabs.forEach(function (t) {
        t.addEventListener('click', function () {
          var key = t.getAttribute('data-claim-tab')
          tabs.forEach(function (other) {
            var active = other === t
            other.classList.toggle('is-active', active)
            other.setAttribute('aria-selected', active ? 'true' : 'false')
          })
          panes.forEach(function (p) {
            p.hidden = p.getAttribute('data-claim-pane') !== key
          })
        })
      })
    }

    // Scored stones are real <a> tags — the browser handles navigation,
    // cmd/middle-click, and right-click natively. No JS click handler.
  })()
</script>

<style>
  .wall-frame {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 12px;
    margin: 0 0 28px;
  }
  .wall-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    flex-wrap: wrap;
  }
  .wall-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
  .wall-head h2 {
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: 22px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--fg);
    margin: 0;
  }
  .wall-head .rule {
    flex: 1; height: 1px; min-width: 24px;
    background: var(--border-soft); margin: 0 4px;
  }
  /* Legend strip on the right of the wall header — four swatches with
     terse labels. Replaces the old summary-counts strip (counts read
     as noise next to the heraldic grid). */
  .wall-head .legend {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 14px;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    color: var(--dim);
    text-transform: uppercase;
  }
  .wall-head .legend .lg {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .wall-head .legend .sw {
    width: 8px;
    height: 8px;
    display: inline-block;
    border: 1px solid currentColor;
  }
  .wall-head .legend .lg-fresh .sw {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 6px rgba(126, 168, 208, 0.5);
  }
  .wall-head .legend .lg-scored .sw {
    background: var(--accent-dim);
    border-color: var(--accent);
  }
  .wall-head .legend .lg-evaluating .sw {
    background: var(--warn-dim, rgba(216, 167, 101, 0.16));
    border-color: var(--warn, #d8a765);
    border-style: dotted;
  }
  .wall-head .legend .lg-open .sw {
    background: rgba(126, 168, 208, 0.08);
    border-color: rgba(126, 168, 208, 0.45);
    border-style: dashed;
  }
  .wall-head .flow-hint {
    flex-basis: 100%;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2px;
  }

  .wall-frame-compact {
    margin: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
    flex: 0 1 auto;
    gap: 10px;
  }
  .wall-frame-compact .wall-head {
    gap: 10px;
    flex: 0 0 auto;
  }
  .wall-frame-compact .wall-head h2 {
    font-size: 19px;
  }
  .wall-frame-compact .wall-head .flow-hint {
    display: none;
  }
  .wall-frame-compact .wall {
    padding: 12px 14px;
    gap: 10px;
    flex: 0 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .wall-frame-compact .grid {
    flex: 0 1 auto;
    min-height: clamp(150px, 26vh, 280px);
    max-height: min(28vh, 300px);
    height: auto;
    aspect-ratio: unset;
    gap: clamp(5px, 0.65vmin, 9px);
    grid-template-rows: repeat(4, minmax(0, 1fr));
  }
  .wall-frame-compact .stone {
    min-height: 0;
    width: 100%;
    height: 100%;
  }
  .wall-frame-compact .stone :global(svg) {
    width: 78%;
    height: 78%;
    max-width: 52px;
    max-height: 52px;
  }

  .wall {
    position: relative;
    /* Geological strata: older stones (left, 24h ago) sit in slightly
       darker ground; fresher stones (right, now) sit in slightly lighter
       ground. The wall reads as time-of-day depth, not a flat surface. */
    background:
      linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.18) 0%,
        rgba(0, 0, 0, 0.06) 50%,
        rgba(126, 168, 208, 0.03) 100%
      ),
      var(--surface);
    border: 1px solid var(--border-soft);
    padding: 18px 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: hidden;
  }
  /* 6h boundary markers — three vertical rules at 25/50/75% so the wall
     reads as four six-hour bands, the unit the bell tower also counts in
     (roughly two liturgical blocks per band). Pure decoration; doesn't
     interfere with stone hit targets. */
  .wall::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(90deg, transparent calc(25% - 0.5px), var(--border-soft) calc(25% - 0.5px), var(--border-soft) calc(25% + 0.5px), transparent calc(25% + 0.5px)),
      linear-gradient(90deg, transparent calc(50% - 0.5px), var(--border-soft) calc(50% - 0.5px), var(--border-soft) calc(50% + 0.5px), transparent calc(50% + 0.5px)),
      linear-gradient(90deg, transparent calc(75% - 0.5px), var(--border-soft) calc(75% - 0.5px), var(--border-soft) calc(75% + 0.5px), transparent calc(75% + 0.5px));
    opacity: 0.5;
    z-index: 0;
  }
  /* Now-column glow — soft accent column on the right edge so the eye
     reads 'this is the live edge of the wall'. */
  .wall::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 4.166%; /* one column = 100/24 */
    pointer-events: none;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(126, 168, 208, 0.06) 70%,
      rgba(126, 168, 208, 0.10) 100%
    );
    z-index: 0;
  }
  .wall > * { position: relative; z-index: 1; }
  .hours-axis {
    display: grid;
    grid-template-columns: repeat(24, 1fr);
    gap: 4px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.04em;
    color: var(--dim);
  }
  .hours-axis span { text-align: center; font-variant-numeric: tabular-nums; }
  .hours-axis span.now { color: var(--accent); }

  .grid {
    display: grid;
    grid-template-columns: repeat(24, 1fr);
    grid-template-rows: repeat(4, 1fr);
    grid-auto-flow: column;
    gap: 4px;
