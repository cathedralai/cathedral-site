---
/**
 * The wall — 24h × 4 stones-per-hour grid that visualizes a job's recent
 * card submissions. Each stone is a card; its colour reflects the
 * weighted score and how recent the submission is. Hover (or focus) any
 * stone to surface a "peek" tooltip with the mason, score, and
 * timestamp. If the visitor has claimed an agent in localStorage, their
 * stones gain a dashed pulse outline.
 *
 * Server-renders the layout, the stones, and the deterministic mason
 * marks; a small inline script attaches peek behaviour and you-detection
 * after first paint.
 */
import { masonMark } from '../lib/mason-marks'
import type { EvalOutput } from '../lib/types'

interface Props {
  /** Recent eval outputs, newest first. Up to 96 will be placed in slots. */
  evals: EvalOutput[]
  /** Job id, for context and the empty-state CTA. */
  cardId: string
  /** Optional section number (default '01'). */
  num?: string
}

const { evals, cardId, num = '01' } = Astro.props

const NUM_HOURS = 24
const PER_HOUR = 4
const TOTAL = NUM_HOURS * PER_HOUR
const HOUR_MS = 60 * 60 * 1000
const SLOT_MS = HOUR_MS / PER_HOUR

const now = Date.now()

type Slot =
  | { kind: 'empty' }
  | {
      kind: 'fresh' | 'scored' | 'low'
      e: EvalOutput
    }

const slots: Slot[] = Array.from({ length: TOTAL }, () => ({ kind: 'empty' }))

for (const e of evals) {
  const t = new Date(e.ran_at).getTime()
  const ageMs = now - t
  if (ageMs > NUM_HOURS * HOUR_MS) continue
  if (ageMs < 0) continue
  const slotsAgo = Math.floor(ageMs / SLOT_MS)
  const idx = TOTAL - 1 - slotsAgo
  if (idx < 0 || idx >= TOTAL) continue
  let kind: 'fresh' | 'scored' | 'low' = 'scored'
  if (ageMs < 30 * 60 * 1000) kind = 'fresh'
  else if (e.weighted_score < 0.4) kind = 'low'
  if (slots[idx].kind === 'empty') {
    slots[idx] = { kind, e }
  }
}

const stoneCount = slots.filter((s) => s.kind !== 'empty').length

// Hours axis: every 6h gets a label, current hour is "now".
const hourLabels: { txt: string; current: boolean }[] = []
for (let i = 0; i < NUM_HOURS; i++) {
  const hoursAgo = NUM_HOURS - 1 - i
  if (hoursAgo === 0) hourLabels.push({ txt: 'now', current: true })
  else if (hoursAgo === NUM_HOURS - 1) hourLabels.push({ txt: '24h', current: false })
  else if (hoursAgo % 6 === 0) hourLabels.push({ txt: `${hoursAgo}h`, current: false })
  else hourLabels.push({ txt: '·', current: false })
}
---

<section class="wall-frame" data-wall data-card-id={cardId}>
  <header class="wall-head">
    <span class="num">{num}</span>
    <h2>The wall &mdash; last 24 hours</h2>
    <span class="rule"></span>
    <span class="legend" aria-hidden="true">
      <span class="l fresh">fresh</span>
      <span class="l scored">scored</span>
      <span class="l low">below break-even</span>
      <span class="l miss">no stone</span>
    </span>
  </header>

  <div class="wall">
    <div class="hours-axis" aria-hidden="true">
      {hourLabels.map((h) => (
        <span class={h.current ? 'now' : ''}>{h.txt}</span>
      ))}
    </div>

    <div class="grid" data-wall-grid>
      {slots.map((s, i) => {
        if (s.kind === 'empty') {
          return <div class="stone empty" aria-hidden="true"></div>
        }
        const e = s.e
        return (
          <div
            class={`stone ${s.kind}`}
            data-i={i}
            data-agent-id={e.agent_id}
            data-agent-name={e.agent_display_name}
            data-score={e.weighted_score.toFixed(2)}
            data-ran-at={e.ran_at}
            data-title={e.output_card?.title ?? `Card ${e.id.slice(0, 6)}`}
            tabindex="0"
            role="link"
            aria-label={`${e.agent_display_name}, scored ${e.weighted_score.toFixed(2)}`}
            set:html={masonMark(e.agent_id, { size: 22 })}
          />
        )
      })}
    </div>

    {stoneCount === 0 && (
      <p class="wall-empty">
        No stone yet on this wall in the last 24h.
        <a href={`/jobs/${cardId}/submit`}>Lay the first &rarr;</a>
      </p>
    )}

    <div class="peek" data-wall-peek role="status" aria-live="polite" hidden>
      <span class="mk" data-peek-mark></span>
      <span class="who">
        <span class="nm" data-peek-name></span>
        <span class="hk" data-peek-agent></span>
      </span>
      <span class="t" data-peek-title></span>
      <span class="when" data-peek-when></span>
      <span class="score">
        <strong data-peek-score></strong>
        <span class="lbl">score</span>
      </span>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var wall = document.currentScript && document.currentScript.previousElementSibling
    // Fallback: locate by data-wall on initial document load.
    if (!wall || !wall.matches || !wall.matches('[data-wall]')) {
      wall = document.querySelector('[data-wall]')
    }
    if (!wall) return
    var grid = wall.querySelector('[data-wall-grid]')
    var peek = wall.querySelector('[data-wall-peek]')
    if (!grid || !peek) return

    var myId = ''
    try { myId = localStorage.getItem('cd:agent_id') || '' } catch (_) {}
    if (myId) {
      var stones = grid.querySelectorAll('[data-agent-id]')
      for (var i = 0; i < stones.length; i++) {
        if (stones[i].getAttribute('data-agent-id') === myId) {
          stones[i].classList.add('you')
        }
      }
    }

    function relTime(iso) {
      var d = new Date(iso).getTime()
      var ms = Date.now() - d
      if (ms < 60000) return Math.max(0, Math.floor(ms / 1000)) + 's ago'
      if (ms < 3600000) return Math.floor(ms / 60000) + 'm ago'
      if (ms < 86400000) return Math.floor(ms / 3600000) + 'h ago'
      return Math.floor(ms / 86400000) + 'd ago'
    }
    function trunc(s) {
      if (!s) return ''
      if (s.length <= 16) return s
      return s.slice(0, 6) + '…' + s.slice(-4)
    }

    function show(el) {
      peek.querySelector('[data-peek-name]').textContent = '@' + (el.getAttribute('data-agent-name') || '')
      peek.querySelector('[data-peek-agent]').textContent = trunc(el.getAttribute('data-agent-id') || '')
      peek.querySelector('[data-peek-title]').textContent = el.getAttribute('data-title') || ''
      peek.querySelector('[data-peek-score]').textContent = el.getAttribute('data-score') || '—'
      peek.querySelector('[data-peek-when]').textContent = relTime(el.getAttribute('data-ran-at') || '')
      peek.querySelector('[data-peek-mark]').innerHTML = el.innerHTML
      peek.hidden = false
    }
    function hide() { peek.hidden = true }

    grid.addEventListener('mouseover', function (e) {
      var el = e.target.closest('.stone[data-i]')
      if (el) show(el)
    })
    grid.addEventListener('mouseleave', hide)
    grid.addEventListener('focusin', function (e) {
      var el = e.target.closest('.stone[data-i]')
      if (el) show(el)
    })
    grid.addEventListener('focusout', hide)

    // Click a stone to navigate to its agent.
    grid.addEventListener('click', function (e) {
      var el = e.target.closest('.stone[data-i]')
      if (el) {
        var id = el.getAttribute('data-agent-id')
        if (id) window.location.href = '/agents/' + encodeURIComponent(id)
      }
    })
  })()
</script>

<style>
  .wall-frame {
    display: grid;
    grid-template-rows: auto auto;
    gap: 14px;
    margin: 0 0 28px;
  }
  .wall-head {
    display: flex;
    align-items: baseline;
    gap: 18px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    flex-wrap: wrap;
  }
  .wall-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
  .wall-head h2 {
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: 19px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--fg);
    margin: 0;
  }
  .wall-head .rule {
    flex: 1; height: 1px; min-width: 24px;
    background: var(--border-soft); margin: 0 4px;
  }
  .wall-head .legend { display: inline-flex; gap: 12px; flex-wrap: wrap; }
  .wall-head .legend .l {
    display: inline-flex; gap: 5px; align-items: center;
    font-size: 9px; letter-spacing: 0.16em; color: var(--dim);
  }
  .wall-head .legend .l::before {
    content: ''; width: 8px; height: 8px; display: inline-block;
    border: 1px solid currentColor;
  }
  .wall-head .legend .l.fresh::before {
    background: var(--accent); border-color: var(--accent);
    box-shadow: 0 0 6px rgba(126, 168, 208, 0.5);
  }
  .wall-head .legend .l.scored::before {
    background: var(--accent-dim); border-color: var(--accent);
  }
  .wall-head .legend .l.low::before {
    background: transparent; border-color: var(--warn);
  }
  .wall-head .legend .l.miss::before {
    background: transparent; border-color: var(--faint);
  }

  .wall {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    padding: 18px 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .hours-axis {
    display: grid;
    grid-template-columns: repeat(24, 1fr);
    gap: 4px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.04em;
    color: var(--dim);
  }
  .hours-axis span { text-align: center; font-variant-numeric: tabular-nums; }
  .hours-axis span.now { color: var(--accent); }

  .grid {
    display: grid;
    grid-template-columns: repeat(24, 1fr);
    grid-template-rows: repeat(4, 1fr);
    grid-auto-flow: column;
    gap: 4px;
    aspect-ratio: 6 / 1;
    min-height: 140px;
  }
  .stone {
    position: relative;
    border: 1px solid var(--border-soft);
    background: var(--bg);
    cursor: pointer;
    transition: transform 160ms, border-color 160ms, background 160ms;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .stone :global(svg) { width: 60%; height: 60%; opacity: 0.6; }
  .stone:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    z-index: 2;
  }
  .stone.scored {
    background: var(--accent-dim);
    border-color: rgba(126, 168, 208, 0.55);
  }
  .stone.scored :global(svg) { opacity: 0.85; }
  .stone.fresh {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 12px rgba(126, 168, 208, 0.45);
  }
  .stone.fresh :global(svg) { opacity: 1; color: var(--bg); }
  .stone.fresh :global(svg *) { stroke: var(--bg) !important; }
  .stone.low {
    background: transparent;
    border-color: var(--warn);
  }
  .stone.low :global(svg) { opacity: 0.55; }
  .stone.low :global(svg *) { stroke: var(--warn) !important; }
  .stone.empty {
    background: transparent;
    border-style: dashed;
    border-color: var(--faint);
    cursor: default;
    opacity: 0.4;
  }
  .stone.empty :global(svg) { display: none; }
  .stone.you {
    outline: 1px solid var(--accent);
    outline-offset: 2px;
  }
  .stone.you::after {
    content: '';
    position: absolute;
    inset: -3px;
    border: 1px dashed var(--accent);
    pointer-events: none;
    animation: cd-pulse 2s ease-in-out infinite;
  }

  .wall-empty {
    margin: 4px 0 0;
    padding: 6px 4px 0;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 13.5px;
    color: var(--muted);
  }
  .wall-empty a {
    color: var(--accent);
    margin-left: 6px;
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 3px;
  }
  .wall-empty a:hover { text-decoration-color: var(--accent); }

  .peek {
    position: absolute;
    bottom: 16px; left: 18px; right: 18px;
    background: var(--bg);
    border: 1px solid var(--accent);
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 14px;
    z-index: 4;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.5);
    pointer-events: none;
  }
  .peek[hidden] { display: none; }
  .peek .mk { display: inline-flex; }
  .peek .mk :global(svg) { width: 28px; height: 28px; }
  .peek .who { display: flex; flex-direction: column; gap: 1px; min-width: 130px; }
  .peek .who .nm { color: var(--fg); font-size: 12.5px; }
  .peek .who .hk {
    color: var(--dim); font-size: 10px; letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }
  .peek .t {
    flex: 1;
    font-family: var(--serif);
    font-size: 13px;
    line-height: 1.4;
    color: var(--fg);
    font-weight: 300;
    font-style: italic;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .peek .when {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--dim);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
    min-width: 56px; text-align: right;
  }
  .peek .score { text-align: right; }
  .peek .score strong {
    font-family: var(--serif); font-weight: 300;
    font-size: 22px; color: var(--fg);
    font-variant-numeric: tabular-nums;
    display: block; line-height: 1;
  }
  .peek .score .lbl {
    font-size: 9px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--dim);
  }

  @media (max-width: 720px) {
    .grid { gap: 2px; min-height: 100px; }
    .hours-axis { font-size: 8px; }
    .wall-head .legend { display: none; }
    .peek { left: 8px; right: 8px; padding: 10px 12px; gap: 10px; }
    .peek .t { display: none; }
    .peek .who { min-width: 100px; }
  }
</style>
