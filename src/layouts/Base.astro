---
import RoseWindow from '../components/RoseWindow.astro'
import AuthBootstrap from '../components/AuthBootstrap.astro'

interface Props {
  title?: string
  /** When true, the page fills the viewport exactly — use for the log dashboard. */
  fullHeight?: boolean
}

const { title = 'cathedral', fullHeight = false } = Astro.props

const shellClass = fullHeight
  ? 'mx-auto max-w-[1180px] h-screen flex flex-col px-4 py-4 sm:px-5'
  : 'mx-auto max-w-[1180px] min-h-screen flex flex-col px-4 py-4 sm:px-5 sm:py-5'
/* Top nav keeps the full shell width (breathing, airy). The body of the
   page (everything under the nav) sits in a narrower column — roughly
   Word "Normal" margins (≈1in each side) — so content doesn't feel like
   it's running off the page. */
const mainClass = fullHeight
  ? 'flex-1 min-h-0 flex flex-col w-full max-w-[960px] mx-auto'
  : 'flex-1 flex flex-col w-full max-w-[960px] mx-auto'
const footerClass = fullHeight
  ? 'mt-3 pt-2 text-[10px] text-dim flex flex-wrap items-center gap-x-3 gap-y-2 shrink-0 w-full max-w-[960px] mx-auto'
  : 'mt-6 pt-3 text-[10px] text-dim flex flex-wrap items-center gap-x-3 gap-y-2 sm:mt-8 w-full max-w-[960px] mx-auto'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400&display=swap" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme')
          var theme = saved || 'dark'
          document.documentElement.setAttribute('data-theme', theme)
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'dark')
        }
      })()
    </script>
    <AuthBootstrap />
  </head>
  <body class={`bg-bg text-fg font-mono text-[13px] leading-[1.6] selection:bg-accent/30 antialiased ${fullHeight ? 'overflow-hidden' : ''}`}>
    <div class={shellClass}>
      <header class="relative z-20 flex flex-wrap items-center gap-x-3 gap-y-2 bg-bg text-[10px] text-muted mb-3 shrink-0 sm:mb-4 sm:gap-x-6 sm:text-[11px]">
        <a href="/" class="flex items-center gap-2 text-fg hover:text-accent transition-colors tracking-[0.1em] uppercase">
          <RoseWindow size={14} class="text-accent opacity-80" />
          <span>cathedral</span>
        </a>
        <span class="text-dim">·</span>
        <a href="/workforce" class="hover:text-fg transition-colors">workforce</a>
        <a href="/research" class="hover:text-fg transition-colors">research</a>
        <a href="/how-it-works" class="hover:text-fg transition-colors">how it works</a>
        <a href="/dashboard" class="hover:text-fg transition-colors">dashboard</a>
        <a href="/afrotensor" class="hover:text-fg transition-colors">afrotensor</a>
        <a href="/roadmap" class="hover:text-fg transition-colors">roadmap</a>
        <a href="/changelog" class="hover:text-fg transition-colors">changelog</a>
        <a href="https://github.com/bigailabs/cathedral" class="hover:text-fg transition-colors">github</a>
        <span class="hidden min-[560px]:block flex-1" aria-hidden="true"></span>
        <button
          type="button"
          data-theme-toggle
          class="text-dim hover:text-fg transition-colors tracking-[0.05em] uppercase text-[10px]"
          aria-label="Toggle theme"
        >
          <span data-theme-icon-dark>◐ dark</span>
          <span data-theme-icon-light class="hidden">◑ light</span>
        </button>
        <span class="text-dim">sn39 · finney</span>
      </header>
      <main class={mainClass}>
        <slot />
      </main>
      <footer class={footerClass}>
        <span>cathedral.computer</span>
        <span class="text-border">·</span>
        <a href="https://github.com/bigailabs/cathedral" class="hover:text-muted transition-colors">source</a>
        <a href="/origins" class="hover:text-muted transition-colors">origins</a>
        <a href="https://github.com/bigailabs/cathedral/blob/main/docs/policy.md" class="hover:text-muted transition-colors">policy</a>
        <a href="https://polaris.computer" class="hover:text-muted transition-colors">rent compute ↗</a>
        <span class="hidden min-[560px]:block flex-1" aria-hidden="true"></span>
        <span class="w-full min-[560px]:w-auto">operated by <a href="https://polaris.computer" class="hover:text-muted transition-colors underline decoration-dim underline-offset-2 decoration-[0.5px]">polaris</a></span>
      </footer>
    </div>
    <script is:inline>
      (function () {
        var btn = document.querySelector('[data-theme-toggle]')
        if (!btn) return
        var iconDark = document.querySelector('[data-theme-icon-dark]')
        var iconLight = document.querySelector('[data-theme-icon-light]')
        function sync() {
          var t = document.documentElement.getAttribute('data-theme')
          if (t === 'light') {
            iconDark.classList.add('hidden')
            iconLight.classList.remove('hidden')
          } else {
            iconDark.classList.remove('hidden')
            iconLight.classList.add('hidden')
          }
        }
        sync()
        btn.addEventListener('click', function () {
          var next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
          document.documentElement.setAttribute('data-theme', next)
          try { localStorage.setItem('theme', next) } catch (_) {}
          sync()
        })
      })()
    </script>
    <style is:global>
      /* Slate palette, inspired by the Cathedral Subnet design drop.
         oklch-first, with hex fallbacks handled by CSS variables being read
         directly into hex-compatible Tailwind tokens. */
      html[data-theme='dark'] {
        color-scheme: dark;
        --bg: #0e0f12;
        --surface: #16181c;
        --surface-2: #1b1e23;
        --border: #23262d;
        --border-soft: #1c1f25;
        --fg: #e6e9ef;
        --muted: #9ba2ae;
        --dim: #6a7380;
        --accent: #7ea8d0;          /* slate-blue — quiet, confident */
        --accent-dim: rgba(126, 168, 208, 0.14);
        --warn: #d8a765;
        --warn-dim: rgba(216, 167, 101, 0.12);
        --err: #d97a6c;
        --err-dim: rgba(217, 122, 108, 0.12);
        --ok: #89b890;                /* muted sage — verified, good, quiet */
        --ok-dim: rgba(137, 184, 144, 0.14);
        --scrollbar-thumb: #2a2e36;
        --scrollbar-thumb-hover: #3a3f48;
      }
      html[data-theme='light'] {
        color-scheme: light;
        --bg: #f3f1eb;
        --surface: #ecebe3;
        --surface-2: #e5e4db;
        --border: #d8d5c9;
        --border-soft: #e3e1d6;
        --fg: #1c1d1f;
        --muted: #5a6069;
        --dim: #85899a;
        --accent: #3a5d82;
        --accent-dim: rgba(58, 93, 130, 0.12);
        --warn: #8c5a1e;
        --warn-dim: rgba(140, 90, 30, 0.10);
        --err: #8a342a;
        --err-dim: rgba(138, 52, 42, 0.10);
        --ok: #4a7a54;                /* darker sage for light theme */
        --ok-dim: rgba(74, 122, 84, 0.10);
        --scrollbar-thumb: #cdc9bb;
        --scrollbar-thumb-hover: #b6b2a2;
      }
      html, body { background: var(--bg); color: var(--fg); }
      /* Prevent stray horizontal scroll from wide children (long code
         strings, grid-internal overflow) on narrow viewports. Individual
         elements that need to scroll (code blocks) use their own
         overflow-x: auto. */
      html, body { overflow-x: hidden; }
      * { box-sizing: border-box; }
      a { text-decoration: none; }
      body { font-feature-settings: 'calt' 1, 'ss01' 1, 'ss02' 1, 'zero' 1, 'tnum' 1; }
      /* Serif for display copy — Newsreader paired with mono body. */
      .font-serif { font-family: 'Newsreader', ui-serif, Georgia, serif; }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }
    </style>
  </body>
</html>
