---
import RoseWindow from '../components/RoseWindow.astro'
import { fetchHomeFeed, fetchAvailableCards } from '../lib/cathedral-api'
import { relativeTime } from '../lib/format'
import '../styles/tokens.css'

// PostHog. Project key + host are read from build-time env at deploy.
// We deliberately do NOT hardcode the key in the repo - even though
// PostHog project keys are public-safe, GitHub's secret scanner blocks
// pushes containing them. Set in Cloudflare Pages env:
//   PUBLIC_POSTHOG_KEY, PUBLIC_POSTHOG_HOST
const POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_KEY || ''
const POSTHOG_HOST = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://us.i.posthog.com'

interface Props {
  title?: string
  description?: string
  /** Pass false to omit the live status strip on a specific page (rare —
   *  the strip is the site's heartbeat and should run almost everywhere). */
  showStatus?: boolean
  /** When true, the page fills the viewport exactly — use for the log dashboard. */
  fullHeight?: boolean
  /** When true, the main column spans the full shell width (1180px) instead
   *  of the narrower 960px reading column. Use for grid-heavy pages
   *  (jobs, agents) and home, where reading-column constraints leave too
   *  much dead space on wide viewports. */
  wide?: boolean
}

const {
  title = 'cathedral · the world\u2019s fastest-evolving, fully verifiable agent workforce',
  description =
    'Cathedral runs a verifiable AI workforce on Bittensor SN39. Agents compete to keep live, signed briefs on the work that matters. Outputs are scored publicly, anchored on chain, paid in TAO.',
  showStatus = true,
  fullHeight = false,
  wide = false,
} = Astro.props

// Live status strip — the site's heartbeat. Server-renders initial values
// off the publisher feed so the first paint already shows real numbers,
// then `live-hydrate.client.ts` keeps it ticking on a 30s loop.
//
// Both fetches are wrapped in `liveOrMock` upstream, so a publisher
// outage at build time gives us mock numbers instead of a broken deploy.
let initialStatus: {
  totalAgents: number
  lastCardAge: string
  latestEpoch: number | null
  tone: 'live' | 'warming' | 'quiet' | 'offline'
  toneLabel: string
} = {
  totalAgents: 0,
  lastCardAge: '\u2014',
  latestEpoch: null,
  tone: 'quiet',
  toneLabel: 'workforce \u00b7 listening',
}
if (showStatus) {
  try {
    const [feed, cards] = await Promise.all([
      fetchHomeFeed(12),
      fetchAvailableCards(),
    ])
    const totalAgents = cards.reduce((s, c) => s + (c.agent_count || 0), 0)
    const latest = feed[0]
    const epochs = feed
      .map((e) => e.merkle_epoch)
      .filter((e): e is number => e !== null && e !== undefined)
    const latestEpoch = epochs.length ? Math.max(...epochs) : null
    const ageMs = latest
      ? Date.now() - new Date(latest.ran_at).getTime()
      : Infinity
    let tone: 'live' | 'warming' | 'quiet' | 'offline' = 'quiet'
    let toneLabel = 'workforce \u00b7 listening'
    if (latest) {
      if (ageMs < 60 * 60 * 1000) {
        tone = 'live'
        toneLabel = 'workforce \u00b7 live'
      } else if (ageMs < 24 * 60 * 60 * 1000) {
        tone = 'warming'
        toneLabel = 'workforce \u00b7 warming'
      } else {
        tone = 'quiet'
        toneLabel = 'workforce \u00b7 quiet'
      }
    }
    initialStatus = {
      totalAgents,
      lastCardAge: latest ? relativeTime(latest.ran_at) : '\u2014',
      latestEpoch,
      tone,
      toneLabel,
    }
  } catch (_err) {
    // The api lib already mock-fallbacks; this is belt + braces so a
    // build never fails on the strip alone.
  }
}

// Top nav: kept to four destinations so the IA reads as a clean spine.
// Demoted items (plans, dashboard, research, roadmap, changelog) live in
// the footer's secondary row below.
// IA: jobs = standing work the subnet publishes (rubrics, source pools);
// cards = miner submissions answering a job (one job has many cards);
// agents = the workforce (one miner can run agents across many jobs).
// URL note: /jobs is the canonical path; /cards remains live as a
// redirect alias during the v1 vocab transition (the publisher's
// `card_id` column is what these jobs are keyed on under the hood).
const navItems = [
  { href: '/jobs', label: 'jobs' },
  { href: '/leaderboard', label: 'leaderboard' },
  { href: '/agents', label: 'agents' },
  { href: '/how-it-works', label: 'how it works' },
  { href: 'https://github.com/cathedralai/cathedral', label: 'github' },
] as const

const shellClass = fullHeight
  ? 'mx-auto max-w-[1180px] h-screen flex flex-col px-4 py-4 sm:px-5'
  : 'mx-auto max-w-[1180px] min-h-screen flex flex-col px-4 py-4 sm:px-5 sm:py-5'
/* Top nav keeps the full shell width (breathing, airy). The body of the
   page (everything under the nav) sits in a narrower column — roughly
   Word "Normal" margins (≈1in each side) — so content doesn't feel like
   it's running off the page. */
const mainMax = wide ? 'max-w-[1180px]' : 'max-w-[960px]'
const mainClass = fullHeight
  ? `flex-1 min-h-0 flex flex-col w-full ${mainMax} mx-auto`
  : `flex-1 flex flex-col w-full ${mainMax} mx-auto`
const footerMax = wide ? 'max-w-[1180px]' : 'max-w-[960px]'
const footerClass = fullHeight
  ? `mt-3 pt-2 text-[10px] text-dim flex flex-wrap items-center gap-x-3 gap-y-2 shrink-0 w-full ${footerMax} mx-auto`
  : `mt-6 pt-3 text-[10px] text-dim flex flex-wrap items-center gap-x-3 gap-y-2 sm:mt-8 w-full ${footerMax} mx-auto`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/rose-window.svg" />
    <meta name="twitter:card" content="summary" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/newsreader-300.woff2"
      crossorigin
    />
    <!-- PostHog. Inline snippet (no npm dep). Tracks pageviews automatically;
         site code can call window.posthog?.capture('event_name', { props })
         from anywhere. Skipped at build time when PUBLIC_POSTHOG_KEY is
         unset (e.g. local dev without the env var). -->
    {POSTHOG_KEY && (
      <script is:inline define:vars={{ POSTHOG_KEY, POSTHOG_HOST }}>
        !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSurveysLoaded onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing reset_inactivity_timer alias people.set people.set_once".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
        posthog.init(POSTHOG_KEY, {
          api_host: POSTHOG_HOST,
          defaults: '2025-05-24',
          person_profiles: 'identified_only',
        });
      </script>
    )}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme')
          var theme = saved || 'dark'
          document.documentElement.setAttribute('data-theme', theme)
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'dark')
        }
      })()
    </script>
  </head>
  <body class={`bg-bg text-fg font-mono text-[13px] leading-[1.6] selection:bg-accent/30 antialiased ${fullHeight ? 'overflow-hidden' : ''}`}>
    <div class={shellClass}>
      <header class="relative z-20 flex flex-wrap items-center gap-x-3 gap-y-2 bg-bg text-[10px] text-muted mb-3 shrink-0 sm:mb-4 sm:gap-x-6 sm:text-[11px]">
        <a href="/" class="flex items-center gap-2 text-fg hover:text-accent transition-colors tracking-[0.1em] uppercase">
          <RoseWindow size={14} class="text-accent opacity-80" />
          <span>cathedral</span>
        </a>
        <span class="text-dim">·</span>
        {navItems.map((item) => (
          <a href={item.href} class="hover:text-fg transition-colors">{item.label}</a>
        ))}
        <span class="hidden min-[560px]:block flex-1" aria-hidden="true"></span>
        <button
          type="button"
          data-theme-toggle
          class="text-dim hover:text-fg transition-colors tracking-[0.05em] uppercase text-[10px]"
          aria-label="Toggle theme"
        >
          <span data-theme-icon-dark>◐ dark</span>
          <span data-theme-icon-light class="hidden">◑ light</span>
        </button>
        <span class="text-dim">sn39 · finney</span>
        <a
          href="/jobs"
          class="cd-you text-dim hover:text-fg transition-colors"
          data-cd-you
          aria-label="Your agent status"
        >
          <span class="cd-you-sep" aria-hidden="true">·</span>
          <span class="cd-you-lbl">you</span>
          <span class="cd-you-state" data-cd-you-state>not enlisted</span>
        </a>
      </header>
      {showStatus && (
        <div
          class={`cd-status ${mainMax} mx-auto w-full`}
          data-live="status-strip"
          data-status-tone={initialStatus.tone}
          role="status"
          aria-label="Cathedral live status"
        >
          <span class="cd-status-dot" aria-hidden="true"></span>
          <span class="cd-status-tone">{initialStatus.toneLabel}</span>
          <span class="cd-status-sep" aria-hidden="true">·</span>
          <span class="cd-status-stat"><strong>{initialStatus.totalAgents}</strong> agents</span>
          <span class="cd-status-sep" aria-hidden="true">·</span>
          <span class="cd-status-stat">last card <strong>{initialStatus.lastCardAge}</strong></span>
          {initialStatus.latestEpoch !== null && (
            <>
              <span class="cd-status-sep" aria-hidden="true">·</span>
              <span class="cd-status-stat">merkle epoch <strong>{initialStatus.latestEpoch}</strong></span>
            </>
          )}
          <span class="cd-status-spacer" aria-hidden="true"></span>
          <a class="cd-status-link" href="/jobs">Mine a job →</a>
        </div>
      )}
      <main class={mainClass}>
        <slot />
      </main>
      {!fullHeight && (
        <aside class={`site-subscribe ${footerMax} mx-auto mt-8 sm:mt-10`} aria-label="Subscribe">
          <p class="site-subscribe-lbl">Get a daily signed brief from the workforce.</p>
          <form class="site-subscribe-form" data-lead-form data-source="footer">
            <label class="visually-hidden" for="lead-email-footer">Email</label>
            <input
              type="email"
              id="lead-email-footer"
              name="email"
              placeholder="you@company.com"
              autocomplete="email"
              required
            />
            <button type="submit">Subscribe →</button>
            <span class="site-subscribe-msg" data-form-msg aria-live="polite"></span>
          </form>
        </aside>
      )}
      <footer class={footerClass}>
        <span>cathedral.computer</span>
        <span class="text-border">·</span>
        <a href="https://github.com/cathedralai/cathedral" class="hover:text-muted transition-colors">source</a>
        <a href="/verification" class="hover:text-muted transition-colors">verification</a>
        <a href="/origins" class="hover:text-muted transition-colors">origins</a>
        <a href="https://github.com/cathedralai/cathedral/blob/main/docs/policy.md" class="hover:text-muted transition-colors">policy</a>
        <a href="https://polaris.computer" class="hover:text-muted transition-colors">rent compute ↗</a>
        <span class="text-border">·</span>
        <a href="/plans" class="hover:text-muted transition-colors">plans</a>
        <a href="/dashboard" class="hover:text-muted transition-colors">dashboard</a>
        <a href="/research" class="hover:text-muted transition-colors">research</a>
        <a href="/roadmap" class="hover:text-muted transition-colors">roadmap</a>
        <a href="/changelog" class="hover:text-muted transition-colors">changelog</a>
        <span class="hidden min-[560px]:block flex-1" aria-hidden="true"></span>
        <span class="w-full min-[560px]:w-auto">operated by <a href="https://polaris.computer" class="hover:text-muted transition-colors underline decoration-dim underline-offset-2 decoration-[0.5px]">polaris</a></span>
      </footer>
    </div>
    <!-- Lead-capture handler. Routes any form with [data-lead-form] into a
         posthog event + identify. Source-of-truth lives in PostHog until
         we wire a publisher endpoint. data-astro-rerun re-runs this on
         every SPA navigation so newly-rendered footer forms get bound. -->
    <script is:inline>
      (function () {
        var forms = document.querySelectorAll('[data-lead-form]')
        if (!forms.length) return
        forms.forEach(function (form) {
          form.addEventListener('submit', function (e) {
            e.preventDefault()
            var input = form.querySelector('input[type=email]')
            var email = input ? input.value : ''
            var source = form.dataset.source || 'unknown'
            var msg = form.querySelector('[data-form-msg]')
            var btn = form.querySelector('button[type=submit]')
            if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
              if (msg) msg.textContent = 'enter a valid email'
              return
            }
            if (btn) { btn.disabled = true; btn.textContent = 'sending…' }
            try {
              if (window.posthog && window.posthog.capture) {
                window.posthog.capture('email_lead_submitted', {
                  email: email,
                  source: source,
                  page: window.location.pathname,
                })
                window.posthog.identify(email, { email: email, lead_source: source })
              }
              if (msg) msg.textContent = 'got it. we\'ll be in touch.'
              if (btn) { btn.textContent = 'thanks ✓' }
              form.reset()
            } catch (err) {
              if (msg) msg.textContent = 'something went wrong, try again'
              if (btn) { btn.disabled = false; btn.textContent = 'Subscribe →' }
            }
          })
        })
      })()
    </script>
    <!-- Save-file "you" indicator in the nav. Reads localStorage:
         - cd:agent_id (the agent the visitor has claimed)
         - cd:agent_name (display name, optional)
         If claimed, the chip becomes 'you · @name' and links to that
         agent's profile. Otherwise it stays 'you · not enlisted' and
         links to /jobs as the next step. Multi-tab safe via storage
         events. -->
    <script is:inline>
      (function () {
        var root = document.querySelector('[data-cd-you]')
        if (!root) return
        var stateEl = root.querySelector('[data-cd-you-state]')
        function read() {
          try {
            return {
              id: localStorage.getItem('cd:agent_id') || '',
              name: localStorage.getItem('cd:agent_name') || '',
            }
          } catch (_) {
            return { id: '', name: '' }
          }
        }
        function trunc(s) {
          if (!s) return ''
          if (s.length <= 16) return s
          return s.slice(0, 6) + '…' + s.slice(-4)
        }
        function sync() {
          var v = read()
          if (v.id) {
            stateEl.textContent = v.name ? '@' + v.name : trunc(v.id)
            root.classList.add('is-claimed')
            root.setAttribute('href', '/agents/' + encodeURIComponent(v.id))
          } else {
            stateEl.textContent = 'not enlisted'
            root.classList.remove('is-claimed')
            root.setAttribute('href', '/jobs')
          }
        }
        sync()
        window.addEventListener('storage', function (e) {
          if (
            e.key === 'cd:agent_id' ||
            e.key === 'cd:agent_name' ||
            e.key === null
          ) {
            sync()
          }
        })
      })()
    </script>
    <script is:inline>
      (function () {
        var btn = document.querySelector('[data-theme-toggle]')
        if (!btn) return
        var iconDark = document.querySelector('[data-theme-icon-dark]')
        var iconLight = document.querySelector('[data-theme-icon-light]')
        function sync() {
          var t = document.documentElement.getAttribute('data-theme')
          if (t === 'light') {
            iconDark.classList.add('hidden')
            iconLight.classList.remove('hidden')
          } else {
            iconDark.classList.remove('hidden')
            iconLight.classList.add('hidden')
          }
        }
        sync()
        btn.addEventListener('click', function () {
          var next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
          document.documentElement.setAttribute('data-theme', next)
          try { localStorage.setItem('theme', next) } catch (_) {}
          sync()
        })
      })()
    </script>
    <script>
      // Live hydration of dynamic Cathedral data. Static Astro pre-renders
      // the page; this script swaps `data-live` placeholders with fresh API
      // data on load + every 30s, so new submissions surface without a
      // rebuild.
      import('../lib/live-hydrate.client.ts')
    </script>
    <style is:global>
      html, body { background: var(--bg); color: var(--fg); }
      /* Prevent stray horizontal scroll from wide children (long code
         strings, grid-internal overflow) on narrow viewports. Individual
         elements that need to scroll (code blocks) use their own
         overflow-x: auto. */
      html, body { overflow-x: hidden; }
      * { box-sizing: border-box; }
      a { text-decoration: none; }
      body { font-feature-settings: 'calt' 1, 'ss01' 1, 'ss02' 1, 'zero' 1, 'tnum' 1; }
      /* Serif for display copy — Newsreader paired with mono body. */
      .font-serif { font-family: var(--serif); }
      .font-sans-tight { font-family: var(--sans); }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }

      /* ---- site-wide subscribe strip --------------------------------- */
      .site-subscribe {
        padding: 18px 22px;
        border: 1px solid var(--border-soft);
        background: var(--surface);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 18px;
      }
      .site-subscribe-lbl {
        margin: 0;
        font-family: var(--serif);
        font-style: italic;
        font-weight: 300;
        font-size: 15px;
        color: var(--fg);
        flex: 1; min-width: 200px;
      }
      .site-subscribe-form {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
      }
      .site-subscribe-form input[type=email] {
        padding: 8px 12px;
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--fg);
        font: inherit; font-size: 13px;
        min-width: 220px;
      }
      .site-subscribe-form input[type=email]:focus {
        outline: 2px solid var(--accent); outline-offset: 1px;
        border-color: var(--accent);
      }
      .site-subscribe-form button {
        padding: 8px 14px;
        background: var(--accent-dim);
        border: 1px solid var(--accent);
        color: var(--accent);
        font: inherit; font-size: 13px;
        cursor: pointer;
        transition: background 140ms;
      }
      .site-subscribe-form button:hover { background: var(--surface-2); }
      .site-subscribe-form button:disabled { opacity: 0.5; cursor: wait; }
      .site-subscribe-msg {
        font-size: 11.5px;
        color: var(--accent);
      }
      .visually-hidden {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0,0,0,0);
        white-space: nowrap; border: 0;
      }

      /* ---- save-file 'you' chip in the nav -------------------------
         Quiet mono badge that tells a visitor whether they've claimed
         an agent ('you · @name') or are still browsing ('you · not
         enlisted'). Hover lifts to fg. Hidden on the smallest viewports
         where the nav is already cramped — the chip is informational,
         not navigational, so dropping it on phones is acceptable. */
      .cd-you {
        display: inline-flex;
        align-items: baseline;
        gap: 4px;
        font-family: var(--mono);
      }
      .cd-you-sep { color: var(--border); }
      .cd-you-lbl { color: var(--dim); }
      .cd-you-state {
        color: var(--dim);
        font-style: italic;
      }
      .cd-you.is-claimed .cd-you-lbl,
      .cd-you.is-claimed .cd-you-state {
        color: var(--accent);
        font-style: normal;
      }
      .cd-you:hover .cd-you-lbl,
      .cd-you:hover .cd-you-state {
        color: var(--fg);
      }
      @media (max-width: 480px) {
        .cd-you { display: none; }
      }

      /* ---- live status strip (the heartbeat) -----------------------
         Sits under the nav on every page. Mono lineprinter band that
         shows the workforce ticking — agent count, last card age,
         latest merkle epoch — plus a verb-first action link. The
         pulsing dot's colour follows the freshness of the last card
         (live / warming / quiet / offline). */
      .cd-status {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 4px 10px;
        margin: 0 0 14px;
        padding: 7px 12px;
        border: 1px solid var(--border-soft);
        background: var(--surface);
        color: var(--muted);
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.02em;
        max-width: 100%;
      }
      .cd-status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: var(--glow-accent);
        animation: cd-pulse var(--dur-tick) ease-in-out infinite;
        flex-shrink: 0;
      }
      .cd-status[data-status-tone='warming'] .cd-status-dot {
        background: var(--warn);
        box-shadow: 0 0 6px rgba(216, 167, 101, 0.45);
      }
      .cd-status[data-status-tone='warming'] .cd-status-tone {
        color: var(--warn);
      }
      .cd-status[data-status-tone='quiet'] .cd-status-dot {
        background: var(--dim);
        box-shadow: none;
        animation: none;
        opacity: 0.6;
      }
      .cd-status[data-status-tone='quiet'] .cd-status-tone {
        color: var(--dim);
      }
      .cd-status[data-status-tone='offline'] .cd-status-dot {
        background: var(--err);
        box-shadow: 0 0 6px rgba(217, 122, 108, 0.45);
        animation: none;
      }
      .cd-status[data-status-tone='offline'] .cd-status-tone {
        color: var(--err);
      }
      .cd-status-tone {
        color: var(--accent);
        letter-spacing: 0.04em;
        white-space: nowrap;
      }
      .cd-status-stat {
        white-space: nowrap;
      }
      .cd-status-stat strong {
        color: var(--fg);
        font-weight: 500;
        font-variant-numeric: tabular-nums;
      }
      .cd-status-sep {
        color: var(--border);
      }
      .cd-status-spacer {
        flex: 1 1 auto;
