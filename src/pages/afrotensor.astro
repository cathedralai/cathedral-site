      <button type="button" class="btn primary" id="login-google">Continue with Google</button>
      <div class="sep">or</div>
      <form id="login-magic-form">
        <input type="email" name="email" id="login-email" placeholder="you@example.com" required autocomplete="email" />
        <button type="submit" class="btn">Email me a magic link</button>
      </form>
      <div class="status" id="login-status"></div>
      <button type="button" class="close" id="login-close">Cancel</button>
    </div>
  </div>

  <!--
    Authenticated progression layer.

    Strictly additive: mutates the existing .stage DOM on load to inject
    a checkbox and note-composer affordance into each stone. The page
    renders fine without this script (static read-only arc).

    Auth: Supabase JWT via supabase-js (loaded from esm.sh). Polaris's
    FastAPI backend already accepts the JWT as a bearer token (see
    primitives/auth.py); same flow polaris.computer uses.
  -->
  <script type="module" is:inline>
    // ------------ Configuration ---------------------------------------
    // These values are *public*: the Supabase URL and anon publishable
    // key are meant to be shipped to browsers. API host is already the
    // production Railway endpoint. Overridable at runtime so a preview
    // build can retarget without a rebuild.
    const CFG = Object.assign(
      {
        apiBase: 'https://api.polaris.computer',
        // Polaris Supabase project. The publishable (anon) key is public
        // by design — Supabase RLS is the real security boundary.
        // Overridable at runtime via window.__CATHEDRAL_CONFIG__.
        supabaseUrl: 'https://xuxtkpixggpmzjjogkmt.supabase.co',
        supabasePublishableKey: 'sb_publishable_bOPumgAxK8skthifaNIDkw_VkqjnpbB',
      },
      (typeof window !== 'undefined' && window.__CATHEDRAL_CONFIG__) || {},
    )

    const SESSION_KEY = 'polaris_session'
    const STAGE_COUNT = 8

    const $ = (sel, root) => (root || document).querySelector(sel)
    const $$ = (sel, root) => Array.from((root || document).querySelectorAll(sel))

    const authWidget = $('#auth-widget')
    const signupRoot = $('.signup')
    const signupForm = signupRoot ? signupRoot.querySelector('#cathedral-signup-form') : null
    const signupThanks = signupRoot ? signupRoot.querySelector('.thanks') : null
    const signupAuthed = signupRoot ? signupRoot.querySelector('[data-signup-authed]') : null
    const signupAuthedName = signupRoot ? signupRoot.querySelector('[data-signup-name]') : null
    const signupReveal = signupRoot ? signupRoot.querySelector('[data-signup-reveal]') : null
    const loginModal = $('#login-modal')
    const loginStatus = $('#login-status')

    function hasSignedMarker() {
      try { return localStorage.getItem('afrotensor_signed_up_v1') === '1' } catch (_) { return false }
    }

    function applyJourneyGate(locked) {
      document.documentElement.setAttribute('data-afro-journey', locked ? 'locked' : 'open')
      if (window.__afroStep && typeof window.__afroStep.setLocked === 'function') {
        window.__afroStep.setLocked(locked)
      }
    }

    function setSignupState(mode, displayName) {
      if (!signupRoot) return
      if (signupAuthedName) signupAuthedName.textContent = displayName || 'mason'

      const regClosed = signupRoot.getAttribute('data-registrations') === 'closed'
      const wlPanel = signupRoot.querySelector('[data-waitlist-only]')
      if (regClosed && wlPanel) {
        wlPanel.style.display = mode === 'authed' || mode === 'signed' ? 'none' : 'block'
      }

      if (regClosed) {
        if (mode === 'authed') {
          if (signupReveal) signupReveal.hidden = true
          signupRoot.setAttribute('data-signup-collapsed', 'false')
          if (signupForm) signupForm.style.display = 'none'
          if (signupThanks) signupThanks.classList.remove('show')
          if (signupAuthed) signupAuthed.classList.add('show')
          return
        }
        if (mode === 'signed') {
          if (signupReveal) signupReveal.hidden = true
          signupRoot.setAttribute('data-signup-collapsed', 'false')
          if (signupForm) signupForm.style.display = 'none'
          if (signupAuthed) signupAuthed.classList.remove('show')
          if (signupThanks) signupThanks.classList.add('show')
          return
        }
        if (signupAuthed) signupAuthed.classList.remove('show')
        if (signupThanks) signupThanks.classList.remove('show')
        if (signupReveal) signupReveal.hidden = true
        if (signupForm) signupForm.style.display = 'none'
        return
      }

      if (signupReveal) signupReveal.hidden = true
      signupRoot.setAttribute('data-signup-collapsed', 'false')
      if (mode === 'authed') {
        if (signupForm) signupForm.style.display = 'none'
        if (signupThanks) signupThanks.classList.remove('show')
        if (signupAuthed) signupAuthed.classList.add('show')
        return
      }
      if (signupAuthed) signupAuthed.classList.remove('show')
      if (mode === 'signed') {
        if (signupForm) signupForm.style.display = 'none'
        if (signupThanks) signupThanks.classList.add('show')
      } else {
        if (signupForm) signupForm.style.display = 'block'
        if (signupThanks) signupThanks.classList.remove('show')
        if (signupReveal) signupReveal.hidden = false
        signupRoot.setAttribute('data-signup-collapsed', 'true')
      }
    }

    function escapeHtml(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;')
    }

    // ------------ Inject checkbox into each .stage --------------------
    // Each stage gets a small checkbox in the .n column so masons can
    // mark progress. Notes live in a single journal section after the
    // arc — not per-stage — to keep the arc itself clean.
    const stages = new Map() // stepNum -> root element
    $$('#work .stage').forEach((el) => {
      const nEl = el.querySelector('.n')
      if (!nEl) return
      const step = parseInt((nEl.textContent || '').trim(), 10)
      if (!step || step < 1 || step > STAGE_COUNT) return
      el.setAttribute('data-stage', String(step))
      stages.set(step, el)

      // Checkbox: prepended into the .n column, stacked above the step number.
      const check = document.createElement('button')
      check.type = 'button'
      check.className = 'stage-check'
      check.setAttribute('role', 'checkbox')
      check.setAttribute('aria-checked', 'false')
      check.setAttribute('aria-label', `Mark stage ${step} as complete`)
      check.dataset.check = String(step)
      nEl.insertBefore(check, nEl.firstChild)
    })

    // ------------ Auth UI (Polaris session) -------------------------
    function setAuthLoggedOut() {
      if (authWidget) {
        authWidget.setAttribute('data-state', 'logged-out')
        authWidget.innerHTML = ''
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'sign-in'
        btn.textContent = 'Sign in with Polaris'
        btn.addEventListener('click', openLoginModal)
        authWidget.appendChild(btn)
      }
      setComposeAuthUI()
      const signed = hasSignedMarker()
      applyJourneyGate(!signed)
      setSignupState(signed ? 'signed' : 'form')
    }

    function setAuthUnavailable() {
      // Auth backend not yet configured for this deploy.
      if (authWidget) {
        authWidget.setAttribute('data-state', 'unavailable')
        authWidget.innerHTML = ''
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'sign-in'
        btn.textContent = 'Sign in with Polaris'
        btn.title = 'Login setting up — check back soon'
        btn.addEventListener('click', () => {
          alert('Sign in with Polaris is coming soon. For now, follow the steps below and your progress is saved locally.')
        })
        authWidget.appendChild(btn)
      }
      setComposeAuthUI()
      const signed = hasSignedMarker()
      applyJourneyGate(!signed)
      setSignupState(signed ? 'signed' : 'form')
    }

    function setAuthLoggedIn(me) {
      if (authWidget) {
        authWidget.setAttribute('data-state', 'logged-in')
        const display = me.display_name || me.handle || 'mason'
        const initials = display.slice(0, 2)
        let since = '—'
        try {
          since = new Date(me.mason_since).toLocaleDateString(undefined, { month: 'short', year: 'numeric' })
        } catch (_) {}
        authWidget.innerHTML = `
          <div class="mason">
            <span class="avatar">${escapeHtml(initials)}</span>
            <span class="meta">
              <span class="name">${escapeHtml(display)}</span>
              <span class="since">mason since ${escapeHtml(since)}</span>
            </span>
          </div>
          <button type="button" class="sign-out" id="sign-out-btn">sign out</button>
        `
        const out = $('#sign-out-btn')
        if (out) out.addEventListener('click', signOut)
      }
      setComposeAuthUI()
      applyJourneyGate(false)
      setSignupState('authed', display)
    }

    // ------------ Supabase client (lazy, CDN) -------------------------
    let _sbPromise = null
    async function getSupabase() {
      if (!_sbPromise) {
        _sbPromise = (async () => {
          if (!CFG.supabaseUrl || !CFG.supabasePublishableKey) {
            throw new Error('supabase-not-configured')
          }
          const mod = await import('https://esm.sh/@supabase/supabase-js@2.45.4?target=es2022')
          return mod.createClient(CFG.supabaseUrl, CFG.supabasePublishableKey, {
            auth: {
              persistSession: true,
              autoRefreshToken: true,
              detectSessionInUrl: true,
              storageKey: SESSION_KEY,
            },
          })
        })()
      }
      return _sbPromise
    }

    async function currentAccessToken() {
      try {
        const sb = await getSupabase()
        const { data } = await sb.auth.getSession()
        return data && data.session ? data.session.access_token : null
      } catch (_) {
        return null
      }
    }

    async function authedFetch(path, init) {
      const token = await currentAccessToken()
      if (!token) throw new Error('not-authenticated')
      const headers = new Headers((init && init.headers) || {})
      headers.set('Authorization', `Bearer ${token}`)
      if (init && init.body && !headers.has('Content-Type')) {
        headers.set('Content-Type', 'application/json')
      }
      const resp = await fetch(`${CFG.apiBase}${path}`, Object.assign({}, init, { headers }))
      if (resp.status === 401) {
        try { const sb = await getSupabase(); await sb.auth.signOut() } catch (_) {}
        throw new Error('not-authenticated')
      }
      if (!resp.ok) {
        let detail = ''
        try { detail = (await resp.json()).detail || '' } catch (_) {}
        throw new Error(`api-${resp.status}${detail ? `: ${detail}` : ''}`)
      }
      return resp.json()
    }

    async function publicFetch(path) {
      const resp = await fetch(`${CFG.apiBase}${path}`)
      if (!resp.ok) throw new Error(`api-${resp.status}`)
      return resp.json()
    }

    // ------------ Login modal -----------------------------------------
    function openLoginModal() {
      loginStatus.textContent = ''
      loginStatus.classList.remove('err')
      loginModal.hidden = false
      setTimeout(() => { const f = $('#login-email'); if (f) f.focus() }, 0)
    }
    function closeLoginModal() { loginModal.hidden = true }

    $('#login-close').addEventListener('click', closeLoginModal)
    loginModal.addEventListener('click', (e) => { if (e.target === loginModal) closeLoginModal() })
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !loginModal.hidden) closeLoginModal() })

    $('#login-google').addEventListener('click', async () => {
      try {
        const sb = await getSupabase()
        loginStatus.classList.remove('err')
        loginStatus.textContent = 'Redirecting to Google…'
        const { error } = await sb.auth.signInWithOAuth({
          provider: 'google',
          options: { redirectTo: window.location.origin + window.location.pathname },
        })
        if (error) throw error
      } catch (err) {
        loginStatus.textContent = err.message === 'supabase-not-configured'
          ? 'Sign-in is not configured on this build.'
          : (err.message || 'Google sign-in failed.')
        loginStatus.classList.add('err')
      }
    })

    $('#login-magic-form').addEventListener('submit', async (e) => {
      e.preventDefault()
      const email = ($('#login-email').value || '').trim()
      if (!email) return
      try {
        const sb = await getSupabase()
        loginStatus.classList.remove('err')
        loginStatus.textContent = 'Sending magic link…'
        const { error } = await sb.auth.signInWithOtp({
          email,
          options: { emailRedirectTo: window.location.origin + window.location.pathname },
        })
        if (error) throw error
        loginStatus.textContent = 'Check your inbox for the link.'
      } catch (err) {
        loginStatus.textContent = err.message === 'supabase-not-configured'
          ? 'Sign-in is not configured on this build.'
          : (err.message || 'Failed to send link.')
        loginStatus.classList.add('err')
      }
    })

    async function signOut() {
      try { const sb = await getSupabase(); await sb.auth.signOut() } catch (_) {}
      completedSteps = new Set()
      ownComments = new Map()
      renderProgressAndNotes()
      setAuthLoggedOut()
    }

    const afroSignOut = $('#afro-sign-out')
    if (afroSignOut) afroSignOut.addEventListener('click', () => { void signOut() })

    // ------------ State + rendering -----------------------------------
    let completedSteps = new Set()
    let ownComments = new Map() // step -> [{id, body, created_at}]

    // Snapshot each stage's h3 so the journal's label can show which
    // stone a given tab points at, without hard-coding titles twice.
    const stageTitles = new Map()
    for (const [step, el] of stages.entries()) {
      const h3 = el.querySelector('h3')
      stageTitles.set(step, h3 ? (h3.textContent || '').trim() : `Stone ${step}`)
    }

    function renderProgressAndNotes() {
      for (const [step, el] of stages.entries()) {
        const check = el.querySelector(`[data-check="${step}"]`)
        const done = completedSteps.has(step)
        el.classList.toggle('is-complete', done)
        if (check) check.setAttribute('aria-checked', done ? 'true' : 'false')
      }
      // Keep the step-through indicator's check marks in sync.
      if (window.__afroStep && typeof window.__afroStep.syncIndicator === 'function') {
        window.__afroStep.syncIndicator()
      }
      renderJournal()
    }

    function resetToLoggedOutUI() {
      // After sign-out, keep the local checkmarks — the user still
      // expects their progress to be there when they come back.
      // Own server-side comments drop because they belong to the
      // server's account namespace.
      completedSteps = loadLocalProgress()
      ownComments = new Map()
      renderProgressAndNotes()
    }

    // ------------ Journal: one notes panel for all stages -------------
    let journalStep = 1
    let journalNotesCache = new Map() // step -> {items, fetchedAt}
    const JOURNAL_CACHE_MS = 30_000

    const journalRoot = $('[data-journal]')
    const journalLabel = journalRoot ? journalRoot.querySelector('[data-journal-label]') : null
    const journalHint = journalRoot ? journalRoot.querySelector('[data-journal-hint]') : null
    const journalInput = journalRoot ? journalRoot.querySelector('[data-journal-input]') : null
    const journalActions = journalRoot ? journalRoot.querySelector('[data-journal-actions]') : null
    const journalErr = journalRoot ? journalRoot.querySelector('[data-journal-err]') : null
    const journalNotes = journalRoot ? journalRoot.querySelector('[data-journal-notes]') : null

    function setJournalStep(step) {
      if (!journalRoot) return
      journalStep = step
      journalRoot.querySelectorAll('[data-journal-tab]').forEach((t) => {
        const s = parseInt(t.getAttribute('data-journal-tab'), 10)
        t.setAttribute('aria-selected', s === step ? 'true' : 'false')
      })
      if (journalLabel) journalLabel.textContent = stageTitles.get(step) || `Stone ${step}`
      if (journalErr) journalErr.textContent = ''
      if (journalInput) journalInput.value = ''
      renderJournal()
      loadJournalNotes(step, false)
    }

    async function setComposeAuthUI() {
      if (!journalRoot) return
      const token = await currentAccessToken()
      const authed = !!token
      if (journalHint) journalHint.hidden = authed
      if (journalInput) journalInput.hidden = !authed
      if (journalActions) journalActions.hidden = !authed
    }

    function renderJournal() {
      if (!journalRoot || !journalNotes) return
      const cached = journalNotesCache.get(journalStep)
      const mine = (ownComments.get(journalStep) || [])
      const pieces = []
      for (const c of mine) {
        let when = ''
        try { when = new Date(c.created_at).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) } catch (_) {}
        pieces.push(`<div class="note mine"><div class="who">your note · ${escapeHtml(when)}</div><div class="body">${escapeHtml(c.body)}</div></div>`)
      }
      if (!cached) {
        pieces.push('<div class="loading">Fetching notes…</div>')
      } else {
        const mineIds = new Set(mine.map((c) => c.id).filter(Boolean))
        const others = (cached.items || []).filter((c) => !mineIds.has(c.id))
        if (!others.length && !mine.length) {
          pieces.push('<div class="empty">No notes on this stone yet. Be the first.</div>')
        } else {
          for (const c of others) {
            let when = ''
            try { when = new Date(c.created_at).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) } catch (_) {}
            pieces.push(`<div class="note"><div class="who">${escapeHtml(c.author || 'mason')} · ${escapeHtml(when)}</div><div class="body">${escapeHtml(c.body)}</div></div>`)
          }
        }
      }
      journalNotes.innerHTML = pieces.join('')
    }

    async function loadJournalNotes(step, force) {
      if (!journalNotes) return
      const cached = journalNotesCache.get(step)
      if (!force && cached && (Date.now() - cached.fetchedAt) < JOURNAL_CACHE_MS) {
        renderJournal(); return
      }
      try {
        const items = await publicFetch(`/api/v1/cathedral/comments?step=${step}`)
        journalNotesCache.set(step, { items: Array.isArray(items) ? items : [], fetchedAt: Date.now() })
      } catch (_) {
        journalNotesCache.set(step, { items: [], fetchedAt: Date.now() })
      }
      if (step === journalStep) renderJournal()
    }

    if (journalRoot) {
      journalRoot.addEventListener('click', async (e) => {
        const tab = e.target.closest('[data-journal-tab]')
        if (tab) {
          const step = parseInt(tab.getAttribute('data-journal-tab'), 10)
          if (step && step !== journalStep) setJournalStep(step)
          return
        }
        const signInBtn = e.target.closest('[data-journal-signin]')
        if (signInBtn) { openLoginModal(); return }
        const submit = e.target.closest('[data-journal-submit]')
        if (submit) {
          if (!journalInput) return
          const body = (journalInput.value || '').trim()
          if (journalErr) journalErr.textContent = ''
          if (!body) { if (journalErr) journalErr.textContent = 'Write something first.'; return }
          submit.disabled = true
          try {
            const created = await authedFetch('/api/v1/cathedral/comments', {
              method: 'POST',
              body: JSON.stringify({ step_num: journalStep, body }),
            })
            const prior = ownComments.get(journalStep) || []
            ownComments.set(journalStep, [...prior, created])
            journalInput.value = ''
            journalNotesCache.delete(journalStep) // force refetch next look
            renderJournal()
          } catch (err) {
            if (err.message === 'not-authenticated') { openLoginModal(); return }
            if (journalErr) journalErr.textContent = (err && err.message) || 'Could not lay this note.'
          } finally {
            submit.disabled = false
          }
        }
      })
      // Prime the first stage's notes + auth-aware compose.
      setJournalStep(1)
      setComposeAuthUI()
    }

    // ------------ localStorage fallback for anonymous progress -------
    // Logged-out visitors can check stages off too; we persist to
    // localStorage. On login, /me supersedes this (no merge yet —
    // follow-up if we see people graduate mid-flow often).
    const LOCAL_PROGRESS_KEY = 'afrotensor_progress_v1'
    function loadLocalProgress() {
      try {
        const raw = localStorage.getItem(LOCAL_PROGRESS_KEY)
        if (!raw) return new Set()
        const arr = JSON.parse(raw)
        return new Set(Array.isArray(arr) ? arr.map(Number).filter(Boolean) : [])
      } catch { return new Set() }
    }
    function saveLocalProgress(set) {
      try { localStorage.setItem(LOCAL_PROGRESS_KEY, JSON.stringify(Array.from(set))) } catch {}
    }

    // Seed from localStorage immediately so checkmarks survive reload
    // even before auth decides anything.
    completedSteps = loadLocalProgress()

    // ------------ Interactions (event delegation) ---------------------
    document.addEventListener('click', async (e) => {
      // Checkbox toggle — works offline via localStorage; syncs to
      // the server if signed in.
      const check = e.target.closest('[data-check]')
      if (check) {
        const step = parseInt(check.getAttribute('data-check'), 10)
        if (!step) return
        const wasDone = completedSteps.has(step)
        const willBeDone = !wasDone
        // Optimistic UI update + local persistence first
        if (willBeDone) completedSteps.add(step)
        else completedSteps.delete(step)
        check.setAttribute('aria-checked', willBeDone ? 'true' : 'false')
        saveLocalProgress(completedSteps)
        renderProgressAndNotes()

        // If we have a session, sync to the server. If not, the
        // localStorage write above is the whole story — no modal,
        // no blocker.
        const token = await currentAccessToken()
        if (!token) return
        check.disabled = true
        try {
          const data = await authedFetch('/api/v1/cathedral/progress', {
            method: 'POST',
            body: JSON.stringify({ step_num: step, completed: willBeDone }),
          })
          completedSteps = new Set(data.completed_steps || [])
          saveLocalProgress(completedSteps)
          renderProgressAndNotes()
        } catch (err) {
          // Server round-trip failed; keep the local state. If the
          // failure was auth-specific, nudge the user to sign in to
          // sync, but don't yank their checkmark away.
          if (err.message === 'not-authenticated') {
            // silent — we already saved locally
          }
        } finally {
          check.disabled = false
        }
        return
      }

    })

    // ------------ Bootstrap -------------------------------------------
    (async function boot() {
      let sb
      try {
        sb = await getSupabase()
      } catch (_) {
        // Supabase keys missing or CDN blocked. Page still renders; the
        // checkboxes prompt a sign-in modal (which will surface the same
        // error, so the user understands why).
        setAuthUnavailable()
        return
      }

      // React to auth state changes (magic link return, OAuth callback,
      // silent refresh, sign-out).
      sb.auth.onAuthStateChange(async (_event, session) => {
        if (session && session.access_token) {
          await hydrateFromMe()
        } else {
          resetToLoggedOutUI()
          setAuthLoggedOut()
        }
      })

      const { data } = await sb.auth.getSession()
      if (data && data.session) {
        await hydrateFromMe()
      } else {
        setAuthLoggedOut()
      }
    })()

    window.addEventListener('afro:signup-complete', function () {
      applyJourneyGate(false)
      setSignupState('signed')
    })

    async function hydrateFromMe() {
      try {
        const me = await authedFetch('/api/v1/cathedral/me')
        const serverSteps = new Set(me.completed_steps || [])
        // Merge any local progress the user made while logged out.
        // Local checkmarks become server checkmarks so they don't get
        // "lost on sign-in" — a common frustration pattern. Cheap: at
        // most 8 POSTs on first login.
        const localOnly = Array.from(loadLocalProgress()).filter(
          (s) => !serverSteps.has(s)
        )
        for (const step of localOnly) {
          try {
            const data = await authedFetch('/api/v1/cathedral/progress', {
              method: 'POST',
              body: JSON.stringify({ step_num: step, completed: true }),
            })
            if (data && Array.isArray(data.completed_steps)) {
              for (const s of data.completed_steps) serverSteps.add(s)
            } else {
              serverSteps.add(step)
            }
          } catch (_) { /* keep local state; try again next load */ }
        }
        completedSteps = serverSteps
        // Clear localStorage now that server has the full picture.
        saveLocalProgress(completedSteps)

        ownComments = new Map()
        for (const c of (me.comments || [])) {
          const list = ownComments.get(c.step) || []
          list.push(c)
          ownComments.set(c.step, list)
        }
        setAuthLoggedIn(me)
        renderProgressAndNotes()
      } catch (err) {
        if (err.message === 'not-authenticated') {
          resetToLoggedOutUI()
          setAuthLoggedOut()
          return
        }
        // API down — keep the page usable with local progress.
        setAuthUnavailable()
      }
    }
  </script>
</Base>
