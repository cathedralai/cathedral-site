---
// Afrotensor — onboarding arc for African builders and students.
//
// Portability: This page is a standalone narrative. It lives on
// cathedral.computer today for distribution, but is designed to lift
// directly to afrotensor.com when that domain is ready. The only
// cathedral-specific links are `/` (home), `/mine`, `/roadmap`,
// `/changelog` — all of which become https://cathedral.computer/...
// when we move, and https://polaris.computer links stay as-is.
//
// If moving: copy this file into a standalone Astro project with the
// same Base layout (dark/light theme, same palette tokens), update
// the four internal links to absolute, and deploy.
import Base from '../layouts/Base.astro'
import Attributions from '../components/Attributions.astro'

// Central link map — update once when the page lifts to afrotensor.com.
const LINKS = {
  home: '/',
  mine: '/mine',
  roadmap: '/roadmap',
  changelog: '/changelog',
  minePath: '/mine#02',
  polaris: 'https://polaris.computer',
  faucet: 'https://app.minersunion.ai/testnet-faucet',
  btcliDocs: 'https://docs.bittensor.com/getting-started/installation',
  github: 'https://github.com/bigailabs/cathedral',
  githubIssues: 'https://github.com/bigailabs/cathedral/issues',
}

// Polaris API base — same backend that serves /api/v1/cathedral/machines
// above. An env override exists in case a staging preview wants to point
// at a Railway review deploy, but in production this is always
// api.polaris.computer.
const API_BASE = (import.meta.env.PUBLIC_POLARIS_API_BASE as string | undefined)
  ?? 'https://api.polaris.computer'

// When false: hide full signup, show waitlist + "new slots soon". Mirror on API with
// CATHEDRAL_SIGNUPS_ENABLED=true to reopen POST /api/v1/cathedral/signup.
const AFTROTENSOR_REGISTRATIONS_OPEN = false

// Live mason roster used to be fetched here at build/request time (blocking
// dev + static builds for up to several seconds). It now hydrates client-side
// after first paint — see inline script after #intro.
---

<Base title="afrotensor · cathedral">
  <style>
    .eyebrow {
      font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--dim); display: flex; align-items: baseline; gap: 10px;
    }
    .eyebrow .num { font-variant-numeric: tabular-nums; color: var(--accent); }
    .eyebrow .rule {
      flex: 1;
      height: 1px;
      background: var(--border-soft);
    }
    /* Intro label: title voice (Newsreader), not body mono. Keeps caps rhythm readable. */
    #intro .eyebrow {
      font-family: var(--serif);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.14em;
    }
    #intro .eyebrow .num {
      font-family: var(--serif);
      font-weight: 500;
    }
    /* Section rhythm — match home (index) */
    .sec { padding: 72px 0; border-bottom: 1px solid var(--border-soft); }
    .sec:last-of-type { border-bottom: 0; }
    .sec .wrap { display: grid; grid-template-columns: 160px 1fr; gap: 48px; }
    /* min-width: 0 on grid children lets the 1fr track actually shrink
       instead of being padded out by intrinsic content widths (long
       code strings, max-width: min(60ch, 100%) prose). Without this, CSS grid
       expands the track and causes horizontal body overflow on mobile. */
    .sec .wrap > * { min-width: 0; }
    @media (max-width: 900px) {
      .sec { padding: 56px 0; }
      .sec .wrap { grid-template-columns: 1fr; gap: 24px; }
    }
    /* Hero band — home-like: breathing room under the nav, single column edge-to-edge. */
    #intro.afro-hero-sec {
      padding-top: clamp(56px, 9vw, 112px);
      padding-bottom: clamp(24px, 3vw, 36px);
      margin-top: 0;
      border-bottom: 0;
    }
    /* No `.wrap` on this section — we want the content to fill the main column
       directly without the default 160/1fr sidebar grid. */
    #intro .afro-intro-wrap {
      display: block;
      width: 100%;
    }

    /* Prose defaults — promote body to --fg, breathe at 1.7, cap at 60ch. */
    .prose { max-width: min(60ch, 100%); font-size: 13px; line-height: 1.7; color: var(--fg); }
    .prose + .prose { margin-top: 14px; }
    .prose a { color: var(--fg); text-decoration: underline; text-decoration-color: var(--dim); text-underline-offset: 2px; }
    .prose a:hover { text-decoration-color: var(--accent); }
    .prose strong { color: var(--fg); font-weight: 500; }
    .prose em { color: var(--muted); font-style: italic; }
    .caption { max-width: 28ch; font-size: 11px; line-height: 1.6; color: var(--dim); }

    .lede {
      font-family: var(--serif);
      font-size: 26px; font-weight: 300; line-height: 1.35; color: var(--fg);
      max-width: 36ch; margin: 0;
    }
    .lede em { font-style: italic; color: var(--muted); }

    .tag {
      display: inline-block; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
      padding: 2px 6px; margin-left: 8px; vertical-align: middle; border: 1px solid var(--border);
    }
    .tag.testnet { color: var(--ok); border-color: var(--ok); }
    .tag.mainnet { color: var(--accent); border-color: var(--accent); }

    /* Live mason line — a single sentence, serif, quiet. */
    .live-masons {
      margin-top: 22px; font-family: var(--serif);
      font-size: 16px; line-height: 1.55; color: var(--fg); max-width: min(60ch, 100%);
      font-weight: 300; font-style: italic;
    }
    .live-masons .uid { font-family: 'JetBrains Mono', ui-monospace, monospace; font-style: normal; color: var(--accent); font-size: 14px; letter-spacing: 0.02em; }
    .live-masons .you { color: var(--accent); font-style: normal; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 14px; letter-spacing: 0.02em; text-transform: uppercase; }

    /* Step-through mode: only the active stage is visible. Others stay in
       the DOM (so progress/comments wiring still finds them) but are
       hidden via CSS. */
    .stage[data-stage-hidden="true"] { display: none !important; }

    /* Stage indicator: a horizontal row of 8 numbered nodes above the
       active stage. Highlights current, marks completed. Clickable to
       jump between stones. */
    .stage-indicator {
      display: flex; flex-wrap: wrap; gap: 6px;
      margin-bottom: 28px; padding-bottom: 18px;
      border-bottom: 1px solid var(--border-soft);
    }
    .stage-indicator .pip {
      font: inherit; cursor: pointer;
      padding: 6px 10px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.18em;
      background: transparent; color: var(--dim);
      border: 1px solid var(--border-soft); border-radius: 2px;
      transition: color 120ms ease, border-color 120ms ease, background 120ms ease;
      font-variant-numeric: tabular-nums;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .stage-indicator .pip:hover { color: var(--fg); border-color: var(--border); }
    .stage-indicator .pip[aria-current="step"] {
      color: var(--accent); border-color: var(--accent);
      background: var(--accent-dim);
    }
    .stage-indicator .pip.is-complete { color: var(--ok); border-color: var(--ok); }
    .stage-indicator .pip.is-complete::before {
      content: '\2713'; font-size: 10px; line-height: 1;
    }
    .stage-indicator .pip[aria-current="step"].is-complete { color: var(--ok); }

    /* Step-through navigation: prev / mark-complete-and-next. Sits at
       the bottom of the active stage. */
    .stage-nav {
      display: flex; gap: 10px; margin-top: 24px; padding-top: 18px;
      border-top: 1px solid var(--border-soft); flex-wrap: wrap;
      align-items: center;
    }
    .stage-nav button {
      font: inherit; cursor: pointer;
      padding: 9px 16px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      background: transparent; color: var(--fg);
      border: 1px solid var(--border); border-radius: 2px;
      transition: color 120ms ease, border-color 120ms ease, background 120ms ease;
    }
    .stage-nav button:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
    .stage-nav button:disabled { opacity: 0.4; cursor: not-allowed; }
    .stage-nav .next { border-color: var(--accent); color: var(--accent); }
    .stage-nav .next:hover:not(:disabled) { background: var(--accent-dim); }
    .stage-nav .spacer { flex: 1; }
    .stage-nav .progress {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.18em; color: var(--dim);
      font-variant-numeric: tabular-nums;
    }

    /* Tightened stages — title + one-line body + optional code/link card.
       The first column holds a checkbox + step number, stacked. No
       absolute positioning — column is wide enough to keep both aligned
       at any viewport, and content starts flush on the right. */
    .stage {
      display: grid; grid-template-columns: 44px 1fr; gap: 18px;
      padding: 22px 0;
      border-top: 1px solid var(--border-soft);
    }
    .stage > *,
    .stage > div > * { min-width: 0; max-width: 100%; }
    .stage:first-child { border-top: 0; padding-top: 6px; }
    /* In step-through mode each visible stage stands alone: no top border. */
    .stage[data-stage] { border-top: 0; padding-top: 0; }
    .stage .n {
      font-variant-numeric: tabular-nums; color: var(--accent);
      font-size: 12px; letter-spacing: 0.2em;
      display: flex; flex-direction: column; align-items: flex-start; gap: 10px;
      padding-top: 3px;
    }
    .stage h3 {
      margin: 0; font-size: 15px; font-weight: 500;
      color: var(--fg); letter-spacing: 0.01em; line-height: 1.35;
    }
    .stage .body {
      margin: 8px 0 0 0; font-size: 13px; line-height: 1.7;
      color: var(--fg); max-width: min(60ch, 100%);
    }
    .stage .body strong { color: var(--fg); font-weight: 500; }
    .stage a {
      color: var(--fg); text-decoration: underline;
      text-decoration-color: var(--dim); text-underline-offset: 2px;
    }
    .stage a:hover { text-decoration-color: var(--accent); }

    /* Code / link block — a separated item, not buried in prose. */
    .block {
      margin-top: 12px; padding: 10px 12px;
      border: 1px solid var(--border-soft); background: var(--surface);
      font-size: 12px; line-height: 1.6; color: var(--fg);
      max-width: min(60ch, 100%); overflow-x: auto;
    }
    .block code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--fg); }
    .block + .block { margin-top: 8px; }
    .block .label {
      display: block; font-size: 9px; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--dim); margin-bottom: 6px;
    }
    .block.link a {
      color: var(--accent); text-decoration: none;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
    }
    .block.link a:hover { text-decoration: underline; text-underline-offset: 2px; }

    /* How-they-meet flow — text-led, two columns, arrows in slate accent. */
    .flow {
      border: 1px solid var(--border); background: var(--surface);
      padding: 24px;
    }
    .flow-head {
      display: grid; grid-template-columns: 1fr 40px 1fr; gap: 16px;
      align-items: center; padding-bottom: 16px;
      border-bottom: 1px solid var(--border-soft);
    }
    .flow-head h4 {
      margin: 0; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--dim); font-weight: 400;
    }
    .flow-head .col { display: flex; flex-direction: column; gap: 2px; }
    .flow-head .role {
      font-family: var(--serif);
      font-size: 18px; color: var(--fg); font-weight: 400; font-style: italic;
    }
    .flow-arrow {
      text-align: center; color: var(--accent);
      font-size: 18px; letter-spacing: 0.1em;
    }
    .flow-rows { display: grid; grid-template-columns: 1fr 40px 1fr; gap: 16px; margin-top: 14px; }
    .flow-rows .step {
      font-size: 12px; line-height: 1.65; color: var(--fg);
      padding: 10px 0;
    }
    .flow-rows .step .k {
      display: block; font-size: 9px; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--dim); margin-bottom: 4px;
    }
    .flow-rows .arr {
      text-align: center; color: var(--accent); font-size: 14px;
      padding-top: 30px; letter-spacing: 0.1em;
    }
    @media (max-width: 700px) {
      .flow-head, .flow-rows { grid-template-columns: 1fr; }
      .flow-arrow, .flow-rows .arr { display: none; }
    }

    /* -----------------------------------------------------------
       Signup form — sits inside the numbered hero block.
       All colours via tokens so both themes read right.
       ----------------------------------------------------------- */
    .signup { max-width: 520px; margin: 0 auto; }
    .signup .lede-form {
      font-family: var(--serif);
      font-size: clamp(1.05rem, 3.8vw + 0.45rem, 1.25rem);
      font-weight: 300;
      line-height: 1.35;
      color: var(--fg);
      margin: 0 0 6px 0;
      text-wrap: balance;
    }
    .signup .lede-form em { color: var(--muted); font-style: italic; }
    .signup .intro {
      font-size: 12px; line-height: 1.6; color: var(--muted);
      margin: 4px 0 20px 0; max-width: min(62ch, 100%);
      text-wrap: balance;
    }
    .signup .lede-form,
    .signup .intro { text-align: center; }
    .signup .reveal-wrap {
      display: flex; justify-content: center; margin: 8px 0 22px 0;
    }
    .signup .reveal-signup {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 10px 20px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      background: transparent; color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 2px;
      cursor: pointer;
      transition: background 120ms ease, color 120ms ease;
      -webkit-tap-highlight-color: transparent;
    }
    .signup .reveal-signup:hover {
      background: var(--accent-dim); color: var(--fg);
    }
    .signup[data-signup-collapsed="true"] form { display: none; }
    .signup[data-signup-collapsed="true"] .reveal-wrap { display: flex; }
    .signup[data-signup-collapsed="false"] .reveal-wrap { display: none; }

    /* Waitlist reveal — mirror the full signup collapse/expand pattern. */
    [data-waitlist-collapsed="true"] #cathedral-waitlist-form,
    [data-waitlist-collapsed="true"] .waitlist-thanks { display: none; }
    [data-waitlist-collapsed="true"] [data-waitlist-reveal-wrap] { display: flex; }
    [data-waitlist-collapsed="false"] [data-waitlist-reveal-wrap] { display: none; }

    .signup form { display: block; }
    .signup .field { display: block; margin-bottom: 16px; }
    .signup .field > label {
      display: block; font-size: 9px; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--dim); margin-bottom: 6px;
      font-weight: 400;
    }

    .signup input[type="text"],
    .signup input[type="email"],
    .signup textarea {
      display: block; width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--fg);
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12.5px; line-height: 1.55;
      padding: 10px 14px;
      border-radius: 2px;
      transition: border-color 120ms ease;
    }
    .signup textarea { min-height: 90px; resize: vertical; }
    .signup input::placeholder,
    .signup textarea::placeholder { color: var(--dim); }
    .signup input:focus,
    .signup textarea:focus {
      outline: none;
      border-color: var(--accent);
    }
    .signup .field.err input,
    .signup .field.err textarea { border-color: var(--err); }
    .signup .field .err-msg {
      display: none; margin-top: 6px;
      font-size: 11px; color: var(--err); line-height: 1.5;
    }
    .signup .field.err .err-msg { display: block; }

    /* Hardware radio group — visual chips, not browser defaults. */
    .signup .radios {
      display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    }
    @media (max-width: 520px) { .signup .radios { grid-template-columns: 1fr; } }
    .signup .radios label {
      display: flex; align-items: center; gap: 10px;
      border: 1px solid var(--border); padding: 10px 12px;
      background: var(--surface);
      font-size: 12px; line-height: 1.45; color: var(--fg);
      cursor: pointer;
      border-radius: 2px;
      transition: border-color 120ms ease, background 120ms ease;
    }
    .signup .radios label:hover { border-color: var(--accent); }
    .signup .radios input[type="radio"] {
      appearance: none; -webkit-appearance: none;
      width: 12px; height: 12px; margin: 0;
      border: 1px solid var(--border); border-radius: 50%;
      background: var(--bg);
      flex-shrink: 0;
      position: relative;
      transition: border-color 120ms ease;
    }
    .signup .radios input[type="radio"]:checked {
      border-color: var(--accent);
    }
    .signup .radios input[type="radio"]:checked::after {
      content: ''; position: absolute;
      top: 2px; left: 2px; width: 6px; height: 6px;
      border-radius: 50%; background: var(--accent);
    }
    .signup .radios label:has(input:checked) {
      border-color: var(--accent);
      background: var(--accent-dim);
    }

    .signup button[type="submit"] {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      width: 100%;
      max-width: 320px;
      margin: 18px auto 0;
      padding: 10px 20px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--fg); background: var(--surface);
      border: 1px solid var(--accent);
      border-radius: 2px;
      cursor: pointer;
      transition: background 120ms ease, color 120ms ease;
      -webkit-tap-highlight-color: transparent;
    }
    .signup button[type="submit"]:hover:not(:disabled) {
      background: var(--accent-dim); color: var(--fg);
    }
    .signup button[type="submit"]:disabled {
      opacity: 0.6; cursor: wait;
    }
    .signup .form-error {
      display: none; margin-top: 14px; padding: 10px 12px;
      border-left: 2px solid var(--err); background: var(--err-dim);
      font-size: 12px; line-height: 1.55; color: var(--fg);
    }
    .signup .form-error.show { display: block; }

    /* Thank-you panel — replaces the form on success. */
    .signup .thanks { display: none; }
    .signup .thanks.show { display: block; }
    .signup .thanks p {
      font-family: var(--serif);
      font-size: 20px; line-height: 1.45; font-weight: 300;
      color: var(--fg); margin: 0 0 12px 0; max-width: 36ch;
    }
    .signup .thanks p em { color: var(--muted); font-style: italic; }
    .signup .thanks ul {
      list-style: none; padding: 0; margin: 16px 0 0 0;
    }
    .signup .thanks li {
      font-size: 12.5px; line-height: 1.7; color: var(--muted);
      padding-left: 16px; position: relative;
    }
    .signup .thanks li::before {
      content: '—'; position: absolute; left: 0; color: var(--dim);
    }
    .signup .thanks a {
      color: var(--fg); text-decoration: underline;
      text-decoration-color: var(--dim); text-underline-offset: 2px;
    }
    .signup .thanks a:hover { text-decoration-color: var(--accent); }
    .signup .signed-in-state {
      display: none; margin-top: 14px; padding: 12px 14px;
      border-left: 2px solid var(--ok); background: var(--ok-dim);
      font-size: 12px; line-height: 1.6; color: var(--fg);
    }
    .signup .signed-in-state.show { display: block; }
    .signup .signed-in-state .sign-out {
      display: block;
      margin-top: 14px;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      color: var(--dim);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-family: inherit;
    }
    .signup .signed-in-state .sign-out:hover { color: var(--fg); }
    .signup .signed-in-state .who {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--dim); margin-bottom: 4px;
    }
    .signup .signed-in-state a {
      color: var(--accent); text-decoration: underline; text-underline-offset: 2px;
    }

    /* Closed cohort: waitlist replaces full signup (see AFTROTENSOR_REGISTRATIONS_OPEN). */
    .signup [data-waitlist-only] { display: none; }
    .signup[data-registrations="closed"][data-already-signed="false"] [data-full-signup-only] {
      display: none !important;
    }
    .signup[data-registrations="closed"][data-already-signed="false"] [data-waitlist-only] {
      display: block;
    }
    .signup[data-registrations="closed"][data-already-signed="true"] [data-waitlist-only],
    .signup[data-registrations="closed"][data-already-signed="true"] [data-full-signup-only] {
      display: none !important;
    }
    .signup .waitlist-thanks {
      display: none; margin-top: 18px; padding-top: 8px;
      border-top: 1px solid var(--border-soft);
    }
    .signup .waitlist-thanks.show { display: block; }
    .signup .waitlist-thanks p {
      font-family: var(--serif);
      font-size: 20px; line-height: 1.45; font-weight: 300;
      color: var(--fg); margin: 0; max-width: 36ch;
    }
    .signup .waitlist-thanks p em { color: var(--muted); font-style: italic; }
    .signup .wl-opt {
      font-size: 10px; letter-spacing: 0.08em; text-transform: none; color: var(--dim);
      font-weight: 400;
    }

    .callout { border-left: 2px solid var(--accent); background: var(--accent-dim); padding: 14px 16px; font-size: 13px; color: var(--fg); line-height: 1.7; max-width: min(60ch, 100%); }
    .callout.ok { border-color: var(--ok); background: var(--ok-dim); }

    /* Cards in the yard & guild section — untouched. */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; font-size: 12px; }
    @media (max-width: 700px) { .two-col { grid-template-columns: 1fr; } }
    .card {
      border: 1px solid var(--border); padding: 18px;
      background: var(--surface); color: var(--fg);
    }
    .card h4 { margin: 0 0 8px 0; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dim); font-weight: 400; }
    .card p { font-size: 12.5px; line-height: 1.55; color: var(--muted); margin: 0; }
    .card a.go {
      display: inline-block; margin-top: 14px; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--accent); text-decoration: none; padding-bottom: 1px; border-bottom: 1px solid var(--accent);
    }

    /* Photographic plate — a single image with a thin border and a
       whisper of a caption underneath. The plate is tuned down so it
       sits next to the mono/serif prose without shouting. */
    .plate { margin: 0 0 28px 0; max-width: min(64ch, 100%); }
    .plate img {
      display: block; width: 100%; height: auto;
      border: 1px solid var(--border-soft);
      /* Light touch: preserve the photograph's colour; just a hair of
         grayscale + contrast to sit with the slate palette. Heavier
         treatment made the dark rock-hewn shots look underexposed. */
      filter: grayscale(0.15) contrast(1.05);
      transition: filter 600ms ease;
    }
    html[data-theme='light'] .plate img { filter: grayscale(0.2) contrast(1.02); }
    .plate .cap {
      margin-top: 8px; font-size: 10.5px; color: var(--dim);
      letter-spacing: 0.04em; line-height: 1.5;
    }
    .plate.tall img { aspect-ratio: 4 / 3; object-fit: cover; }
    /* Wide plates default to ~12:7 so portrait subjects (rock-hewn
       monoliths, facades) keep vertical drama instead of being sliced
       into a narrow strip. */
    .plate.wide img { aspect-ratio: 12 / 7; object-fit: cover; }

    /* Intro — same column grammar as home hero thesis (center stack, serif). */
    #intro .intro-body {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-top: 0;
      width: 100%;
    }
    #intro .afro-hero-eyebrow {
      align-self: stretch;
      width: 100%;
      margin-bottom: 2px;
    }
    /* Lineprinter strip — one centered line across the main column.
       Uses a container query so the font shrinks to fit whatever width
       the strip actually renders at, instead of relying on viewport width. */
    .afro-hero-quote {
      position: relative;
      z-index: 0;
      display: block;
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: 8px 14px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-weight: 400;
      line-height: 1.4;
      letter-spacing: 0.02em;
      color: var(--fg);
      background: var(--surface-2);
      border: 1px solid var(--border);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
      overflow: hidden;
      container-type: inline-size;
    }
    .afro-hero-quote__line {
      margin: 0;
      white-space: nowrap;
      text-align: center;
      /* 920px container @ ~10.5px → full line ≈ 900px. Clamp so the text
         never overflows its strip, even on narrower windows. */
      font-size: clamp(0.55rem, 1.15cqw, 0.72rem);
    }
    @container (max-width: 620px) {
      .afro-hero-quote__line {
        white-space: normal;
        font-size: clamp(0.62rem, 2.2cqw, 0.78rem);
      }
    }
    .afro-hero-quote cite {
      display: inline;
      margin: 0;
      font-family: inherit;
      font-size: 0.88em;
      font-weight: 500;
      font-style: normal;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .afro-hero-quote cite::before {
      content: '  ·  ';
      letter-spacing: 0.06em;
      color: var(--border);
    }
    #intro .intro-body .lede {
      margin-top: clamp(24px, 3.3vw, 38px);
      margin-left: auto;
      margin-right: auto;
      text-align: center;
      max-width: 36ch;
      font-size: clamp(1.35rem, 2.1vw + 0.45rem, 1.85rem);
      font-weight: 500;
      line-height: 1.28;
      color: var(--fg);
    }
    #intro .intro-body .prose,
    #intro .intro-body .live-masons {
      text-align: left;
      align-self: stretch;
      width: 100%;
      max-width: min(62ch, 100%);
    }
    #intro .intro-body .afro-intro-prose {
      margin-top: clamp(14px, 2.5vw, 22px);
    }
    #intro .intro-body .afro-mission {
      align-self: stretch;
      width: 100%;
      max-width: 100%;
      text-align: center;
      margin-top: clamp(24px, 3.3vw, 38px);
      padding: clamp(18px, 2.6vw, 26px) clamp(20px, 3vw, 32px);
      border: 1px solid var(--border-soft);
      border-radius: 6px;
      background: var(--surface);
    }

    /* Same accent signal as home thesis "commons". */
    #intro .accent {
      color: var(--accent);
      font-style: normal;
      font-weight: 500;
    }

    /* Mission stack — same rhythm as home .thesis.thesis-stack */
    .afro-mission__kicker {
      margin: 0 0 clamp(8px, 1.2vw, 14px) 0;
      font-family: var(--serif);
      font-size: 13px;
      font-weight: 300;
      font-style: italic;
      color: var(--muted);
      letter-spacing: 0.02em;
    }
    .afro-mission-stack {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: clamp(4px, 0.8vw, 10px);
    }
    .afro-mission-line {
