      background: transparent; color: var(--fg);
      border: 1px solid var(--border); border-radius: 2px; cursor: pointer;
      font-family: inherit;
      font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
      text-align: center;
    }
    .login-card .btn:hover { border-color: var(--accent); color: var(--accent); }
    .login-card .btn.primary { border-color: var(--accent); color: var(--accent); }
    .login-card input[type=email] {
      width: 100%; padding: 10px 12px;
      background: var(--bg); color: var(--fg);
      border: 1px solid var(--border); border-radius: 0;
      font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px;
    }
    .login-card input[type=email]:focus-visible { outline: 1px solid var(--accent); outline-offset: 1px; border-color: var(--accent); }
    .login-card .sep {
      text-align: center; color: var(--dim);
      font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      margin: 16px 0 6px 0;
    }
    .login-card .close {
      margin-top: 14px; background: none; border: 0; padding: 0; cursor: pointer;
