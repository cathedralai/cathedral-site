  <!--
    Signup submission — plain client-side fetch, no framework.
    The API base is rendered onto the .signup element so this script can
    stay a generic is:inline block. Validation mirrors the server's
    required set; the server is still authoritative.
  -->
  <script is:inline>
    (function () {
      var root = document.querySelector('.signup')
      if (!root) return
      if (root.getAttribute('data-registrations') === 'closed') return
      var form = root.querySelector('#cathedral-signup-form')
      if (!form) return
      var apiBase = root.getAttribute('data-api-base') || 'https://api.polaris.computer'
      var formError = root.querySelector('.form-error')
      var thanks = root.querySelector('.thanks')
      var revealBtn = root.querySelector('[data-signup-reveal]')
      var submitBtn = form.querySelector('button[type="submit"]')

      function setCollapsed(on) {
        root.setAttribute('data-signup-collapsed', on ? 'true' : 'false')
      }

      if (!root.hasAttribute('data-signup-collapsed')) setCollapsed(true)
      if (revealBtn) {
        revealBtn.addEventListener('click', function () {
          setCollapsed(false)
          var first = form.querySelector('input[name="name"]')
          if (first) first.focus()
        })
      }

      // Required text fields. Hardware is validated separately (radio group).
      var TEXT_FIELDS = ['name', 'email', 'country', 'excites', 'blocker']
      var EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/

      function fieldEl(key) { return root.querySelector('[data-field="' + key + '"]') }
      function markError(key, on) {
        var el = fieldEl(key)
        if (!el) return
        if (on) el.classList.add('err')
        else el.classList.remove('err')
      }
      function getVal(key) {
        var input = form.querySelector('[name="' + key + '"]')
        return input ? String(input.value || '').trim() : ''
      }
      function validateOne(key) {
        var val = getVal(key)
        if (!val) { markError(key, true); return false }
        if (key === 'email' && !EMAIL_RE.test(val)) { markError(key, true); return false }
        markError(key, false)
        return true
      }

      // Blur validation — only fires after the user interacts with a field.
      TEXT_FIELDS.forEach(function (key) {
        var input = form.querySelector('[name="' + key + '"]')
        if (!input) return
        input.addEventListener('blur', function () { validateOne(key) })
        input.addEventListener('input', function () {
          // Clear the error as the user fixes it; final check on submit.
          if (fieldEl(key) && fieldEl(key).classList.contains('err')) markError(key, false)
        })
      })

      form.querySelectorAll('input[name="hardware"]').forEach(function (r) {
        r.addEventListener('change', function () { markError('hardware', false) })
      })

      function showFormError(msg) {
        if (!formError) return
        formError.textContent = msg
        formError.classList.add('show')
      }
      function hideFormError() {
        if (!formError) return
        formError.textContent = ''
        formError.classList.remove('show')
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault()
        hideFormError()

        var ok = true
        TEXT_FIELDS.forEach(function (k) { if (!validateOne(k)) ok = false })
        var hw = form.querySelector('input[name="hardware"]:checked')
        if (!hw) { markError('hardware', true); ok = false }
        if (!ok) {
          var firstBad = root.querySelector('.field.err input, .field.err textarea')
          if (firstBad) firstBad.focus()
          return
        }

        var payload = {
          name: getVal('name'),
          email: getVal('email').toLowerCase(),
          country: getVal('country'),
          hardware: hw.value,
          excites: getVal('excites'),
          blocker: getVal('blocker'),
        }

        submitBtn.disabled = true
        var originalLabel = submitBtn.textContent
        submitBtn.textContent = 'Signing...'

        try {
          var res = await fetch(apiBase + '/api/v1/cathedral/signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
          var data = null
          try { data = await res.json() } catch (_) { data = null }

          if (!res.ok || !data || !data.ok) {
            var msg = (data && (data.detail || data.error))
              || (res.status === 429 ? 'Too many requests. Give it a minute.' : 'Could not save your signup. Try again shortly.')
            showFormError(typeof msg === 'string' ? msg : 'Could not save your signup. Try again shortly.')
            return
          }

          // Success — persist "signed up" and swap form for thank-you panel.
          try {
            localStorage.setItem('afrotensor_signed_up_v1', '1')
            document.documentElement.setAttribute('data-afro-journey', 'open')
            window.dispatchEvent(new CustomEvent('afro:signup-complete'))
          } catch (_) {}
          setCollapsed(false)
          form.style.display = 'none'
          if (thanks) thanks.classList.add('show')
          if (thanks && 'scrollIntoView' in thanks) {
            thanks.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
        } catch (err) {
          showFormError('Network error. Check your connection and try again.')
        } finally {
          submitBtn.disabled = false
          submitBtn.textContent = originalLabel
        }
      })
    })()
  </script>

  <script is:inline>
    (function () {
      var root = document.querySelector('.signup')
      if (!root || root.getAttribute('data-registrations') !== 'closed') return
      var form = root.querySelector('#cathedral-waitlist-form')
      if (!form) return
      var apiBase = root.getAttribute('data-api-base') || 'https://api.polaris.computer'
      var errEl = form.querySelector('.wl-form-error')
      var thanks = root.querySelector('#cathedral-waitlist-thanks')
      var submitBtn = form.querySelector('button[type="submit"]')
      var EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/
      // Reveal form on click of the "Join the waitlist" button; keep collapsed otherwise.
      var waitlistRoot = root.querySelector('[data-waitlist-only]')
      var revealBtn = root.querySelector('[data-waitlist-reveal]')
      if (waitlistRoot && revealBtn) {
        revealBtn.addEventListener('click', function () {
          waitlistRoot.setAttribute('data-waitlist-collapsed', 'false')
          var first = form.querySelector('input[name="email"]')
          if (first) first.focus()
        })
      }

      function fieldEl(key) {
        return root.querySelector('[data-field="' + key + '"]')
      }
      function markErr(key, on) {
        var el = fieldEl(key)
        if (!el) return
        if (on) el.classList.add('err')
        else el.classList.remove('err')
      }
      function showErr(msg) {
        if (!errEl) return
        errEl.textContent = msg
        errEl.classList.add('show')
      }
      function hideErr() {
        if (!errEl) return
        errEl.textContent = ''
        errEl.classList.remove('show')
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault()
        hideErr()
        var email = (form.querySelector('[name="email"]') && String(form.querySelector('[name="email"]').value || '').trim().toLowerCase()) || ''
        var nameRaw = form.querySelector('[name="name"]')
        var name = nameRaw ? String(nameRaw.value || '').trim() : ''
        if (!email || !EMAIL_RE.test(email)) {
          markErr('wl-email', true)
          showErr('Add a valid email.')
          return
        }
        markErr('wl-email', false)
        submitBtn.disabled = true
        var orig = submitBtn.textContent
        submitBtn.textContent = 'Sending...'
        try {
          var res = await fetch(apiBase + '/api/v1/cathedral/waitlist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, name: name || undefined }),
          })
          var data = null
          try { data = await res.json() } catch (_) { data = null }
          if (!res.ok || !data || !data.ok) {
            var msg = (data && (data.detail || data.error)) || 'Could not join the waitlist. Try again shortly.'
            showErr(typeof msg === 'string' ? msg : 'Could not join the waitlist. Try again shortly.')
            return
          }
          form.style.display = 'none'
          if (thanks) thanks.classList.add('show')
        } catch (_) {
          showErr('Network error. Check your connection and try again.')
        } finally {
          submitBtn.disabled = false
          submitBtn.textContent = orig
        }
      })
    })()
  </script>

  <!--
    Step-through controller.

    The work section renders all eight stages in the DOM, but only the
    active stage is visible. Active stage is driven by:
      · ?s=N URL param, if 1-8
      · otherwise the first incomplete stage from localStorage progress
      · falls back to 1

    Exposed on window as __afroStep so the progression script below can
    re-sync the indicator when a stage is checked off. Runs inline
    before the Supabase module script so prev/next UX is snappy and
    doesn't depend on supabase-js loading from the CDN.
  -->
  <script is:inline>
    (function () {
      var STAGE_COUNT = 8
      var LOCAL_PROGRESS_KEY = 'afrotensor_progress_v1' // same key as progression script
      var locked = document.documentElement.getAttribute('data-afro-journey') === 'locked'
      var stages = document.querySelectorAll('#work [data-stage]')
      if (!stages.length) return
      var pips = document.querySelectorAll('[data-stage-link]')
      var prevBtn = document.querySelector('[data-stage-prev]')
      var nextBtn = document.querySelector('[data-stage-next]')
      var progressLbl = document.querySelector('[data-stage-progress]')

      function loadProgress() {
        try {
          var raw = localStorage.getItem(LOCAL_PROGRESS_KEY)
          if (!raw) return new Set()
          var arr = JSON.parse(raw)
          return new Set(Array.isArray(arr) ? arr.map(Number).filter(Boolean) : [])
        } catch (_) { return new Set() }
      }

      function pickDefaultStage() {
        if (locked) return 1
        var params = new URLSearchParams(window.location.search)
        var requested = parseInt(params.get('s') || '0', 10)
        if (requested >= 1 && requested <= STAGE_COUNT) return requested
        var done = loadProgress()
        for (var i = 1; i <= STAGE_COUNT; i++) {
          if (!done.has(i)) return i
        }
        return STAGE_COUNT // all done, show the last stone
      }

      var activeStage = pickDefaultStage()

      function syncIndicator() {
        var done = loadProgress()
        pips.forEach(function (pip) {
          var s = parseInt(pip.getAttribute('data-stage-link'), 10)
          if (locked && s > 1) pip.setAttribute('disabled', 'true')
          else pip.removeAttribute('disabled')
          if (s === activeStage) pip.setAttribute('aria-current', 'step')
          else pip.removeAttribute('aria-current')
          pip.classList.toggle('is-complete', done.has(s))
        })
      }

      function syncNavButtons() {
        if (prevBtn) prevBtn.disabled = activeStage <= 1
        if (nextBtn) {
          nextBtn.disabled = !!locked
          if (activeStage >= STAGE_COUNT) {
            nextBtn.textContent = 'complete task ✓'
          } else {
            nextBtn.textContent = 'complete task + next →'
          }
        }
        if (progressLbl) progressLbl.textContent = 'stage ' + activeStage + ' of ' + STAGE_COUNT
      }

      function syncJournal(step) {
        // Click the matching journal tab so notes switch to this stone.
        // Handler in the progression script is idempotent if step is
        // already selected.
        var tab = document.querySelector('[data-journal-tab="' + step + '"]')
        if (tab) tab.click()
      }

      function setActive(step, opts) {
        opts = opts || {}
        if (locked && step > 1) step = 1
        if (step < 1) step = 1
        if (step > STAGE_COUNT) step = STAGE_COUNT
        activeStage = step
        stages.forEach(function (el) {
          var s = parseInt(el.getAttribute('data-stage'), 10)
          if (s === step) el.removeAttribute('data-stage-hidden')
          else el.setAttribute('data-stage-hidden', 'true')
        })
        syncIndicator()
        syncNavButtons()
        syncJournal(step)
        // Reflect in URL. replaceState so back-button doesn't walk
        // every stage the user clicked through.
        try {
          var url = new URL(window.location.href)
          url.searchParams.set('s', String(step))
          window.history.replaceState({}, '', url.toString())
        } catch (_) {}
        if (opts.scroll !== false) {
          var work = document.getElementById('work')
          if (work && 'scrollIntoView' in work) {
            work.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
        }
      }

      // Indicator clicks: jump to any stage.
      pips.forEach(function (pip) {
        pip.addEventListener('click', function () {
          var s = parseInt(pip.getAttribute('data-stage-link'), 10)
          if (locked && s > 1) {
            var signup = document.getElementById('signup')
            if (signup && 'scrollIntoView' in signup) signup.scrollIntoView({ behavior: 'smooth', block: 'start' })
            return
          }
          if (s) setActive(s)
        })
      })

      // Prev button.
      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          if (activeStage > 1) setActive(activeStage - 1)
        })
      }

      // Next button: mark the current stage complete, then advance to
      // the next stone. We click the existing inline checkbox so the
      // progression script's server-sync runs. We also write to
      // localStorage directly as a belt-and-braces fallback in case the
      // module script hasn't yet registered its click handler.
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          var done = loadProgress()
          if (!done.has(activeStage)) {
            // Update local store immediately so indicator reflects it
            // even if the progression script isn't loaded yet.
            done.add(activeStage)
            try { localStorage.setItem(LOCAL_PROGRESS_KEY, JSON.stringify(Array.from(done))) } catch (_) {}
            var check = document.querySelector('[data-check="' + activeStage + '"]')
            if (check) {
              // Only click if the checkbox isn't already marked, to
              // avoid toggling it back off.
              if (check.getAttribute('aria-checked') !== 'true') check.click()
            }
          }
          if (activeStage < STAGE_COUNT) {
            setActive(activeStage + 1)
          } else {
            // On the last stone, just refresh indicator so the check shows.
            setTimeout(syncIndicator, 50)
          }
        })
      }

      // Expose a small API so the progression script can tell us when
      // progress changes (e.g. user clicks the inline stage checkbox
      // inside the active stage).
      window.__afroStep = {
        setActive: setActive,
        syncIndicator: syncIndicator,
        setLocked: function (v) {
          locked = !!v
          if (locked && activeStage > 1) activeStage = 1
          setActive(activeStage, { scroll: false })
        },
        get activeStage() { return activeStage },
      }

      // Initial paint: no scroll so landing page load doesn't jump.
      setActive(activeStage, { scroll: false })
    })()
  </script>

  <!-- Login modal for the authenticated progression layer. Hidden by
       default; opened when an unauthenticated visitor clicks a checkbox
       or the "leave a note" link, or the hero's "Sign in" button. -->
  <div class="login-modal" id="login-modal" hidden role="dialog" aria-modal="true" aria-labelledby="login-heading">
    <div class="login-card">
      <h2 id="login-heading">Sign in as a mason</h2>
