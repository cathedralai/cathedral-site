    }
    .login-card .close:hover { color: var(--fg); }
    .login-card .status { font-size: 11px; margin-top: 12px; color: var(--muted); line-height: 1.55; }
    .login-card .status.err { color: var(--err); }
  </style>

  <script is:inline>
    (function () {
      var signed = false
      try { signed = localStorage.getItem('afrotensor_signed_up_v1') === '1' } catch (_) {}
      document.documentElement.setAttribute('data-afro-journey', signed ? 'open' : 'locked')
      function markSignupRoot() {
        var su = document.querySelector('.signup')
        if (!su) return
        su.setAttribute('data-already-signed', signed ? 'true' : 'false')
        if (signed && su.getAttribute('data-registrations') === 'closed') {
          var th = su.querySelector('.thanks')
          if (th) th.classList.add('show')
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', markSignupRoot)
      } else {
        markSignupRoot()
      }
    })()
  </script>

  <!-- 00 — Hero (single column like home thesis band; quote rides up under the nav chrome) -->
  <section class="sec afro-hero-sec" id="intro">
    <div class="afro-intro-wrap">
      <div class="intro-body">
        <div class="eyebrow afro-hero-eyebrow"><span class="num">00</span><span>Afrotensor</span><span class="rule" aria-hidden="true"></span></div>
        <blockquote class="afro-hero-quote" cite="https://en.wikiquote.org/wiki/Nelson_Mandela">
          <p class="afro-hero-quote__line">
            There is no passion to be found playing small—in settling for a life that is less than the one you are capable of living.
            <cite>Nelson Mandela</cite>
          </p>
        </blockquote>
        <p class="lede">Lay a stone.<br/><em>Become a mason of the cathedral.</em></p>

        <p class="prose afro-intro-prose">
          An invitation to builders, students, and cooperatives across Africa to pick up
          a chisel. No GPU required — a laptop, cheap VPS, or spare desktop is a stone.
          Three stages: <strong>apprentice</strong> on testnet, <strong>journeyman</strong>
          on mainnet, <strong>build</strong> on top.
        </p>

        <div class="afro-mission" aria-labelledby="afro-mission-label">
          <div id="afro-mission-label" class="afro-mission__kicker">Mission</div>
          <div class="afro-mission-stack">
            <p class="afro-mission-line">Intelligence is evenly distributed, infrastructure is not.</p>
            <p class="afro-mission-line">
              <span class="accent">Cathedral</span> pays for intelligence.
              <span class="brand">Polaris</span> provides infrastructure.
            </p>
            <p class="afro-mission-line afro-mission-line--break">
              <span class="brand">AfroTensor</span> is the bridge.
            </p>
            <p class="afro-mission-line">
              It connects people who can <strong class="afro-mission-em">think, code, and learn</strong> to an on-chain economy that will pay them for it.
            </p>
            <p class="afro-mission-line afro-mission-line--tail">
              No money, no hardware, no CS degree required.
            </p>
          </div>
        </div>

        <p
          class="live-masons"
          id="afro-live-masons"
          hidden
          aria-live="polite"
          data-registry-url={`${API_BASE}/api/substrate/validator/registry`}
          data-machines-url={`${API_BASE}/api/v1/cathedral/machines`}
        ></p>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      function pretty(loc) {
        if (!loc) return ''
        var parts = String(loc).split('/').map(function (s) { return s.trim() }).filter(Boolean)
        if (parts.length >= 2) return parts[0] + ', ' + parts[parts.length - 1]
        return parts[0] || ''
      }
      function fillLiveMasons() {
        var el = document.getElementById('afro-live-masons')
        if (!el) return
        var regUrl = el.getAttribute('data-registry-url')
        var machUrl = el.getAttribute('data-machines-url')
        if (!regUrl || !machUrl) return
        var ctrl = new AbortController()
        var t = setTimeout(function () { ctrl.abort() }, 2500)
        Promise.all([
          fetch(regUrl, { signal: ctrl.signal, cache: 'no-store' }),
          fetch(machUrl, { signal: ctrl.signal, cache: 'no-store' }),
        ])
          .then(function (rs) {
            clearTimeout(t)
            return Promise.all(rs.map(function (r) { return r.ok ? r.json() : null }))
          })
          .then(function (payloads) {
            var reg = payloads[0]
            var mach = payloads[1]
            var miners = (reg && reg.data && reg.data.miners ? reg.data.miners : []).filter(function (m) {
              return m && m.status === 'verified'
            })
            var machines = mach && mach.machines ? mach.machines : []
            var n = Math.min(miners.length, machines.length)
            var masons = []
            for (var i = 0; i < n; i++) {
              var loc = pretty(machines[i] && machines[i].location)
              if (loc) masons.push({ uid: miners[i].uid, location: loc })
            }
            if (masons.length < 1) return
            var html =
              'Right now, <span class="uid">UID ' +
              masons[0].uid +
              '</span> lays stone from ' +
              masons[0].location +
              '.'
            if (masons[1]) {
              html +=
                ' <span class="uid">UID ' +
                masons[1].uid +
                '</span> from ' +
                masons[1].location +
                '.'
            }
            if (masons[2]) {
              html +=
                ' <span class="uid">UID ' +
                masons[2].uid +
                '</span> from ' +
                masons[2].location +
                '.'
            }
            html += ' <span class="you">you\'re next</span>.'
            el.innerHTML = html
            el.removeAttribute('hidden')
          })
          .catch(function () {
            clearTimeout(t)
          })
      }
      function schedule() {
        if (typeof requestIdleCallback === 'function') {
          requestIdleCallback(
            function () {
              fillLiveMasons()
            },
            { timeout: 1500 },
          )
        } else {
          setTimeout(fillLiveMasons, 0)
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', schedule)
      } else {
        schedule()
      }
    })()
  </script>

  <!-- 01 — Signup. Becoming a mason is a public act; the form is the door. -->
  <section class="sec" id="signup">
