    }
    .stage .stage-check[disabled] { opacity: 0.55; cursor: not-allowed; }

    /* Login modal */
    .login-modal[hidden] { display: none; }
    .login-modal {
      position: fixed; inset: 0; background: rgba(0,0,0,0.6);
