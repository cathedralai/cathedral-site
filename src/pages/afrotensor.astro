    }
    html[data-afro-journey="locked"] #intro .eyebrow {
      display: none;
    }
    html[data-afro-journey="locked"] #intro .afro-hero-quote {
      font-weight: 400;
      color: var(--fg);
      max-width: 100%;
    }
    html[data-afro-journey="locked"] #intro .prose,
    html[data-afro-journey="locked"] #intro .afro-intro-prose,
