      line-height: 1.25;
    }
    html[data-afro-journey="locked"] #signup {
      padding-top: clamp(24px, 3.3vw, 38px);
      padding-bottom: clamp(20px, 3vw, 32px);
    }
    html[data-afro-journey="locked"] #signup .wrap {
      display: block;
      grid-template-columns: 1fr;
      gap: 0;
      max-width: 100%;
      margin: 0;
    }
    html[data-afro-journey="locked"] #signup .wrap > div:first-child {
      display: none;
    }
    html[data-afro-journey="locked"] #signup .signup {
      margin-top: 0;
    }
    [data-locked-stepbar] {
      display: none;
    }
    html[data-afro-journey="locked"] [data-journey-locked-hide] {
      display: none;
    }
    html[data-afro-journey="locked"] #work .stage-indicator .pip:not([data-stage-link="1"]) {
      opacity: 0.35; pointer-events: none;
    }
    html[data-afro-journey="locked"] #work .stage-nav .next {
      opacity: 0.5; pointer-events: none;
    }
    html[data-afro-journey="locked"] #journal {
      display: none;
    }
    html[data-afro-journey="locked"] #signup .signup .lede-form {
      color: var(--fg);
    }
    html[data-afro-journey="locked"] #signup .signup .lede-form em {
