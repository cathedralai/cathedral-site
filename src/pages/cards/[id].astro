---
import Base from '../../layouts/Base.astro'
import { cards, sourceById, workerById } from '../../data/regulatoryIntelligence'

export function getStaticPaths() {
  return cards.map((card) => ({ params: { id: card.id }, props: { card } }))
}

const { card } = Astro.props
const worker = workerById(card.workerId)
const cardSources = card.sourceIds.map(sourceById).filter(Boolean)
---

<Base title={`${card.title} · cathedral`}>
  <article class="card-page">
    <a class="back" href="/intelligence">back to intelligence</a>
    <p class="label">{card.country} · {card.topic}</p>
    <h1>{card.title}</h1>
    <p class="lede">{card.summary}</p>

    <section class="facts">
      <div><span>Status</span><strong>{card.status}</strong></div>
      <div><span>Score</span><strong>{card.score}</strong></div>
      <div><span>Confidence</span><strong>{Math.round(card.confidence * 100)}%</strong></div>
      <div><span>Updated</span><strong>{card.updated}</strong></div>
    </section>

    <section class="body-grid">
      <div>
        <h2>What changed</h2>
        <p>{card.whatChanged}</p>
      </div>
      <div>
        <h2>Why it matters</h2>
        <p>{card.whyItMatters}</p>
      </div>
    </section>

    <section class="section">
      <h2>Next checks</h2>
      <ul>
        {card.nextChecks.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="section">
      <h2>Worker</h2>
      {worker ? (
        <p>
          <a href={`/workers/${worker.id}`}>{worker.name}</a> runs on {worker.runtime}. Current reputation is {worker.reputation}.
        </p>
      ) : (
        <p>This card is open for a miner to claim.</p>
      )}
    </section>

    <section class="section">
      <h2>Official sources</h2>
      <div class="sources">
        {cardSources.map((source) => (
          <a href={source.url}>
            <span>{source.authority}</span>
            <strong>{source.title}</strong>
            <small>{source.tier}</small>
          </a>
        ))}
      </div>
    </section>
  </article>

  <style>
    .card-page {
      padding: 48px 0;
    }
    .back {
      display: inline-block;
      margin-bottom: 28px;
      color: var(--muted);
      font-size: 12px;
      text-decoration: underline;
      text-decoration-color: var(--dim);
      text-underline-offset: 3px;
    }
    .back:hover {
      color: var(--fg);
      text-decoration-color: var(--accent);
    }
    .label {
      margin: 0 0 12px;
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    h1, h2 {
      margin: 0;
      color: var(--fg);
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-weight: 300;
      line-height: 1.1;
    }
    h1 {
      max-width: 820px;
      font-size: clamp(38px, 7vw, 78px);
    }
    h2 {
      font-size: 26px;
    }
    .lede {
      max-width: 760px;
      margin: 20px 0 0;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.6;
    }
    .facts {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      margin: 30px 0;
      border: 1px solid var(--border-soft);
      background: var(--border-soft);
    }
    .facts div {
      background: var(--surface);
      padding: 16px;
    }
    .facts span {
      display: block;
      color: var(--dim);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .facts strong {
      display: block;
      margin-top: 8px;
      color: var(--fg);
      font-size: 18px;
      font-weight: 500;
    }
    .body-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
      padding: 32px 0;
      border-top: 1px solid var(--border-soft);
      border-bottom: 1px solid var(--border-soft);
    }
    .body-grid p,
    .section p,
    .section li {
      color: var(--muted);
      font-size: 15px;
      line-height: 1.7;
    }
    .section {
      padding: 32px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .section ul {
      margin: 16px 0 0;
      padding: 0;
      list-style: none;
    }
    .section li {
      padding: 10px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .section a {
      color: var(--fg);
      text-decoration: underline;
      text-decoration-color: var(--dim);
      text-underline-offset: 3px;
    }
    .sources {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 18px;
    }
    .sources a {
      display: block;
      padding: 16px;
      border: 1px solid var(--border);
      background: var(--surface);
    }
    .sources span,
    .sources small {
      display: block;
      color: var(--dim);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .sources strong {
      display: block;
      margin: 10px 0;
      color: var(--fg);
      font-size: 14px;
      line-height: 1.35;
    }
    @media (max-width: 760px) {
      .facts,
      .body-grid,
      .sources {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Base>
