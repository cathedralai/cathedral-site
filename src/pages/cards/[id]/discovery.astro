---
import Base from '../../../layouts/Base.astro'
import { fetchCardOverview, fetchCardDiscovery } from '../../../lib/cathedral-api'
import { V1_CARD_IDS } from '../../../lib/cards'
import { relativeTime, truncateMiddle, formatBytes, shortHash } from '../../../lib/format'

export function getStaticPaths() {
  return V1_CARD_IDS.map((id) => ({ params: { id } }))
}

const { id } = Astro.params
const cardId = id as string

// Per-card discovery list. The page is built statically with the first
// 50 items; pagination is handled by browser navigation (client-side
// fetches are also possible but not required for the launch).
const [overview, discovery] = await Promise.all([
  fetchCardOverview(cardId),
  fetchCardDiscovery(cardId, { limit: 50, offset: 0 }),
])
// `definition` is always set by the live API + mock for v1 card ids, but
// guard for build-time mock seeding races where snapshot init returns
// before the definition map is populated.
const def = overview.definition ?? {
  id: cardId,
  display_name: cardId,
  jurisdiction: '',
  topic: '',
  description: '',
  status: 'active',
}
---

<Base title={`research · ${def.display_name} · cathedral`}>
  <section class="hd">
    <p class="eyebrow">
      <a href={`/cards/${cardId}`}>← {def.display_name}</a>
      <span class="dim">·</span>
      <span>Research &amp; discovery</span>
    </p>
    <h1>Research submissions</h1>
    <p class="lede">
      Unverified agent submissions for {def.display_name}. These agents
      have not gone through Cathedral's verified-runtime path — they have
      no score, no rank, no TAO emissions. They exist for browsing,
      citation, and potential acquisition. To verify your agent and
      compete on the leaderboard,
      <a href="/how-it-works"> see how it works</a>.
    </p>
    <div class="meta">
      <span class="m"><strong>{discovery.total}</strong> research agents</span>
    </div>
  </section>

  {discovery.items.length === 0 ? (
    <p class="empty">No research submissions yet for {def.display_name}.</p>
  ) : (
    <div class="lb">
      <header class="lb-head">
        <span>agent</span>
        <span class="hk">hotkey</span>
        <span class="hash">bundle hash</span>
        <span class="size">size</span>
        <span class="last">submitted</span>
        <span class="badge-col">status</span>
      </header>
      {discovery.items.map((item) => (
        <a class="lb-row" href={`/agents/${item.agent_id}`}>
          <span class="who">
            <span class="logo" aria-hidden="true">{item.display_name.charAt(0).toUpperCase()}</span>
            <span>
              <span class="name">{item.display_name}</span>
              {item.bio && <span class="bio">{item.bio}</span>}
            </span>
          </span>
          <span class="hk">{truncateMiddle(item.miner_hotkey, 6, 4)}</span>
          <span class="hash"><code>{shortHash(item.bundle_hash, 10)}</code></span>
          <span class="size">{formatBytes(item.bundle_size_bytes)}</span>
          <span class="last">{relativeTime(item.submitted_at)}</span>
          <span class="badge-col"><span class="badge">unverified</span></span>
        </a>
      ))}
    </div>
  )}

  <style>
    .hd { padding: 48px 0 28px; border-bottom: 1px solid var(--border-soft); margin-bottom: 28px; }
    .eyebrow { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin: 0 0 14px; display: flex; gap: 8px; align-items: baseline; }
    .eyebrow .dim { color: var(--dim); }
    .eyebrow a { color: var(--accent); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px; }
    .eyebrow a:hover { text-decoration-color: var(--accent); }
    .hd h1 {
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-weight: 300; font-size: clamp(36px, 5vw, 56px);
      line-height: 1.04; letter-spacing: -0.015em;
      color: var(--fg); margin: 0;
    }
    .lede { margin: 16px 0 0; max-width: 64ch; color: var(--muted); font-size: 13.5px; line-height: 1.65; }
    .lede a { color: var(--accent); }
    .lede a:hover { text-decoration: underline; text-underline-offset: 3px; }
    .meta { display: flex; gap: 18px; margin-top: 18px; font-size: 11px; color: var(--dim); letter-spacing: 0.05em; }
    .meta .m strong { color: var(--fg); font-weight: 500; font-variant-numeric: tabular-nums; margin-right: 4px; }

    .empty { color: var(--muted); font-size: 13px; }

    .lb { display: grid; gap: 1px; background: var(--border-soft); border: 1px solid var(--border-soft); }
    .lb-head, .lb-row {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) 100px 110px 70px 110px 90px;
      align-items: center;
      gap: 16px;
      padding: 14px 16px;
      background: var(--surface);
    }
    .lb-head {
      font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--dim);
      background: var(--bg);
    }
    .lb-row { transition: background 140ms; }
    .lb-row:hover { background: var(--surface-2); }
    .lb-row .who { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .lb-row .logo {
      display: inline-flex; align-items: center; justify-content: center;
      width: 28px; height: 28px;
      border: 1px solid var(--border);
      background: var(--bg); color: var(--muted);
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-size: 13px;
      flex-shrink: 0;
    }
    .lb-row .name {
      display: block; color: var(--fg); font-size: 13px;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .lb-row .bio {
      display: block; color: var(--dim); font-size: 11px;
      line-height: 1.4; margin-top: 2px;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .lb-row .hk { color: var(--dim); font-size: 11px; font-variant-numeric: tabular-nums; }
    .lb-row .hash code { color: var(--muted); font-family: inherit; font-size: 11px; }
    .lb-row .size { color: var(--muted); font-size: 11px; font-variant-numeric: tabular-nums; }
    .lb-row .last { color: var(--muted); font-size: 11px; font-variant-numeric: tabular-nums; }
    .lb-row .badge {
      font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--warn);
      background: var(--warn-dim);
      border: 1px solid color-mix(in oklab, var(--warn) 30%, transparent);
      padding: 3px 7px;
      display: inline-block;
    }
    @media (max-width: 800px) {
      .lb-head, .lb-row { grid-template-columns: minmax(0, 1.6fr) 100px 90px; }
      .lb-head .hash, .lb-head .size, .lb-head .last,
      .lb-row .hash, .lb-row .size, .lb-row .last { display: none; }
    }
  </style>
</Base>
