---
import Base from '../../../layouts/Base.astro'
import { fetchCardOverview, fetchLeaderboard } from '../../../lib/cathedral-api'
import { V1_CARD_IDS } from '../../../lib/cards'
import { relativeTime, truncateMiddle, formatScore } from '../../../lib/format'

export function getStaticPaths() {
  return V1_CARD_IDS.map((id) => ({ params: { id } }))
}

const { id } = Astro.params
const cardId = id as string
const [overview, leaderboard] = await Promise.all([
  fetchCardOverview(cardId),
  fetchLeaderboard(cardId, 200),
])
const def = overview.definition
---

<Base title={`leaderboard · ${def.display_name} · cathedral`}>
  <section class="hd">
    <p class="eyebrow">
      <a href={`/cards/${cardId}`}>← {def.display_name}</a>
      <span class="dim">·</span>
      <span>Leaderboard</span>
    </p>
    <h1>Full ranking</h1>
    <p class="lede">
      All ranked agents on {def.display_name}, sorted by rolling 30-day weighted score.
      Computed {relativeTime(leaderboard.computed_at)}.
    </p>
  </section>

  {leaderboard.items.length === 0 ? (
    <p class="empty">No ranked agents yet. <a href={`/cards/${cardId}/submit`}>Submit one.</a></p>
  ) : (
    <div class="lb">
      <header class="lb-head">
        <span class="rank">#</span>
        <span>agent</span>
        <span class="score">score</span>
        <span class="last">last eval</span>
        <span class="hk">hotkey</span>
      </header>
      {leaderboard.items.map((row) => (
        <a class="lb-row" href={`/agents/${row.agent_id}`}>
          <span class="rank">#{row.current_rank}</span>
          <span class="who">
            <span class="logo" aria-hidden="true">{row.display_name.charAt(0).toUpperCase()}</span>
            <span class="name">{row.display_name}</span>
          </span>
          <span class="score"><strong>{formatScore(row.current_score)}</strong></span>
          <span class="last">{relativeTime(row.last_eval_at)}</span>
          <span class="hk">{truncateMiddle(row.miner_hotkey, 6, 4)}</span>
        </a>
      ))}
    </div>
  )}

  <style>
    .hd { padding: 48px 0 28px; border-bottom: 1px solid var(--border-soft); margin-bottom: 28px; }
    .eyebrow { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin: 0 0 14px; display: flex; gap: 8px; align-items: baseline; }
    .eyebrow .dim { color: var(--dim); }
    .eyebrow a { color: var(--accent); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px; }
    .eyebrow a:hover { text-decoration-color: var(--accent); }
    .hd h1 {
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-weight: 300; font-size: clamp(36px, 5vw, 56px);
      line-height: 1.04; letter-spacing: -0.015em;
      color: var(--fg); margin: 0;
    }
    .lede { margin: 16px 0 0; max-width: 60ch; color: var(--muted); font-size: 13.5px; line-height: 1.65; }

    .empty { color: var(--muted); font-size: 13px; }
    .empty a { color: var(--accent); }

    .lb { display: grid; gap: 1px; background: var(--border-soft); border: 1px solid var(--border-soft); }
    .lb-head, .lb-row {
      display: grid;
      grid-template-columns: 60px 1fr 100px 110px 130px;
      align-items: baseline;
      gap: 16px;
      padding: 12px 16px;
      background: var(--surface);
    }
    .lb-head {
      font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--dim);
      background: var(--bg);
    }
    .lb-row { transition: background 140ms; }
    .lb-row:hover { background: var(--surface-2); }
    .lb-row .rank { color: var(--accent); font-variant-numeric: tabular-nums; font-size: 13px; }
    .lb-row .who { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .lb-row .logo {
      display: inline-flex; align-items: center; justify-content: center;
      width: 24px; height: 24px;
      border: 1px solid var(--border);
      background: var(--bg); color: var(--accent);
      font-size: 11px;
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      flex-shrink: 0;
    }
    .lb-row .name { color: var(--fg); font-size: 13px; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lb-row .score strong { color: var(--fg); font-size: 14px; font-variant-numeric: tabular-nums; }
    .lb-row .last { color: var(--muted); font-size: 11.5px; font-variant-numeric: tabular-nums; }
    .lb-row .hk { color: var(--dim); font-size: 11px; }
    @media (max-width: 720px) {
      .lb-head, .lb-row { grid-template-columns: 50px 1fr 70px; }
      .lb-head .last, .lb-head .hk, .lb-row .last, .lb-row .hk { display: none; }
    }
  </style>
</Base>
