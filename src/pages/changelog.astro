---
import Base from '../layouts/Base.astro'
import { marked } from 'marked'

async function fetchChangelog(): Promise<{ md: string; ok: boolean }> {
  try {
    const headers: Record<string, string> = { 'Accept': 'application/vnd.github.v3.raw', 'User-Agent': 'cathedral-site' }
    const token = import.meta.env.GITHUB_TOKEN || process.env.GITHUB_TOKEN
    if (token) headers.Authorization = `Bearer ${token}`
    const r = await fetch('https://api.github.com/repos/bigailabs/cathedral/contents/CHANGELOG.md', { headers })
    if (!r.ok) return { md: '', ok: false }
    const md = await r.text()
    return { md, ok: true }
  } catch { return { md: '', ok: false } }
}

const { md, ok } = await fetchChangelog()
const cleaned = md.replace(/^#\s+Changelog\s*\n+/i, '')
marked.setOptions({ gfm: true, breaks: false })
const html = ok ? marked.parse(cleaned) : ''
---

<Base title="changelog · cathedral">
  <style>
    .eyebrow {
      font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--dim); display: flex; align-items: baseline; gap: 10px;
    }
    .eyebrow .num { font-variant-numeric: tabular-nums; color: var(--accent); }
    .sec { padding: 56px 0; border-bottom: 1px solid var(--border-soft); }
    .sec:last-of-type { border-bottom: 0; }
    .sec .wrap { display: grid; grid-template-columns: 160px 1fr; gap: 48px; }
    @media (max-width: 900px) {
      .sec { padding: 44px 0; } .sec .wrap { grid-template-columns: 1fr; gap: 20px; }
    }
    .lede {
      font-family: var(--serif);
      font-size: 20px; font-weight: 300; line-height: 1.45; color: var(--fg);
      max-width: 34ch; margin: 0;
    }
    .lede em { font-style: italic; color: var(--muted); }

    /* Thin banner — workers setting a marble block in place. */
    .banner {
      width: 100%; height: 80px; margin-bottom: 24px;
      background-image: url('/images/stonework-nypl.jpg');
      background-size: cover; background-position: center 55%;
      filter: grayscale(1) contrast(0.95) brightness(0.95);
      opacity: 0.32;
      border-bottom: 1px solid var(--border-soft);
      mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
    }
    html[data-theme='light'] .banner { opacity: 0.24; filter: grayscale(1) contrast(0.9) brightness(1.04); }

    .stone-line {
      margin-top: 14px; font-family: var(--serif);
      font-style: italic; font-weight: 300; font-size: 14px;
      color: var(--muted); max-width: 56ch;
    }
  </style>

  <div class="banner" role="presentation" aria-hidden="true"></div>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">00</span><span>Changelog</span></div></div>
      <div>
        <p class="lede">What shipped, in date order.<br/><em>Canonical record on GitHub.</em></p>
        <p class="stone-line">Each entry is a stone laid.</p>
        <p class="text-[12px] text-muted leading-relaxed mt-4 max-w-[56ch]">
          Source of truth is
          <a href="https://github.com/bigailabs/cathedral/blob/main/CHANGELOG.md" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">CHANGELOG.md</a>
          on the cathedral repo. Releases are tagged
          <a href="https://github.com/bigailabs/cathedral/releases" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">there</a>.
        </p>
      </div>
    </div>
  </section>

  {!ok && (
    <section class="sec">
      <div class="wrap">
        <div></div>
        <div class="border border-border bg-surface px-4 py-3">
          <p class="text-[12px] text-muted leading-relaxed">
            Couldn't reach GitHub at build time. Read the canonical
            <a href="https://github.com/bigailabs/cathedral/blob/main/CHANGELOG.md" class="text-fg hover:text-accent underline underline-offset-2 decoration-dim ml-1">CHANGELOG.md</a>.
          </p>
        </div>
      </div>
    </section>
  )}

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">01</span><span>Entries</span></div></div>
      <article class="changelog-body" set:html={html}></article>
    </div>
  </section>
</Base>

<style is:global>
  .changelog-body h2 {
    font-family: var(--serif);
    font-size: 22px; font-weight: 300; color: var(--fg);
    margin-top: 2.25rem; margin-bottom: 0.75rem;
    padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);
    letter-spacing: 0;
  }
  .changelog-body h2:first-child { margin-top: 0; }
  .changelog-body h3 {
    font-size: 10px; color: var(--dim);
    text-transform: uppercase; letter-spacing: 0.18em;
    margin-top: 1.5rem; margin-bottom: 0.5rem;
  }
  .changelog-body p {
    font-size: 12px; color: var(--muted);
    line-height: 1.7; margin-bottom: 0.6rem; max-width: 72ch;
  }
  .changelog-body ul { list-style: none; padding: 0; margin: 0 0 1rem; }
  .changelog-body li {
    font-size: 12px; color: var(--fg); line-height: 1.7;
    padding-left: 1rem; position: relative;
    margin-bottom: 0.35rem; max-width: 72ch;
  }
  .changelog-body li::before {
    content: '—'; color: var(--accent); position: absolute; left: 0;
  }
  .changelog-body li strong { color: var(--fg); font-weight: 500; }
  .changelog-body a {
    color: var(--fg); text-decoration: underline;
    text-decoration-color: var(--dim); text-underline-offset: 2px;
  }
  .changelog-body a:hover { color: var(--accent); text-decoration-color: var(--accent); }
  .changelog-body code {
    font-family: inherit; color: var(--muted);
    background: var(--surface); padding: 0 0.25rem;
    border-radius: 2px; font-size: 11.5px;
  }
</style>
