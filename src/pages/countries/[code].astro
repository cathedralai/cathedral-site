---
import Base from '../../layouts/Base.astro'
import { cards, sources } from '../../data/regulatoryIntelligence'

export function getStaticPaths() {
  const codes = [...new Set(cards.map((card) => card.jurisdiction.toLowerCase()))]
  return codes.map((code) => ({ params: { code } }))
}

const { code } = Astro.params
const countryCards = cards.filter((card) => card.jurisdiction.toLowerCase() === code)
const country = countryCards[0]?.country ?? code?.toUpperCase()
const countrySources = sources.filter((source) => source.jurisdiction.toLowerCase() === code)
---

<Base title={`${country} · cathedral`}>
  <section class="head">
    <a class="back" href="/intelligence">back to intelligence</a>
    <p class="label">{code?.toUpperCase()}</p>
    <h1>{country}</h1>
    <p>Regulatory intelligence cards and approved official sources for this jurisdiction.</p>
  </section>

  <section class="section">
    <h2>Cards</h2>
    <div class="grid">
      {countryCards.map((card) => (
        <a class="card" href={`/cards/${card.id}`}>
          <span>{card.status}</span>
          <h3>{card.title}</h3>
          <p>{card.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Sources</h2>
    <div class="grid">
      {countrySources.map((source) => (
        <a class="card" href={source.url}>
          <span>{source.authority}</span>
          <h3>{source.title}</h3>
          <p>{source.tier}</p>
        </a>
      ))}
    </div>
  </section>

  <style>
    .head,
    .section {
      padding: 46px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .back {
      display: inline-block;
      margin-bottom: 24px;
      color: var(--muted);
      font-size: 12px;
      text-decoration: underline;
      text-decoration-color: var(--dim);
      text-underline-offset: 3px;
    }
    .label {
      margin: 0 0 12px;
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    h1, h2 {
      margin: 0;
      color: var(--fg);
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-weight: 300;
      line-height: 1.1;
    }
    h1 {
      font-size: clamp(40px, 7vw, 78px);
    }
    h2 {
      font-size: 30px;
      margin-bottom: 18px;
    }
    .head p:not(.label),
    .card p {
      color: var(--muted);
      font-size: 15px;
      line-height: 1.65;
      max-width: 720px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .card {
      display: block;
      min-height: 160px;
      padding: 18px;
      border: 1px solid var(--border);
      background: var(--surface);
    }
    .card:hover,
    .card:focus-visible {
      border-color: var(--accent);
      outline: 2px solid transparent;
    }
    .card span {
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .card h3 {
      margin: 14px 0 10px;
      color: var(--fg);
      font-size: 18px;
      line-height: 1.25;
    }
    @media (max-width: 760px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Base>
