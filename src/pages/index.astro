---
import Base from '../layouts/Base.astro'
import { cards, metrics } from '../data/regulatoryIntelligence'

const liveCards = cards.filter((card) => card.status === 'sample live')
const openCards = cards.filter((card) => card.status === 'open')
---

<Base title="cathedral">
  <section class="hero">
    <p class="label">SN39 · Cathedral</p>
    <h1>Persistent workers that maintain public intelligence.</h1>
    <p class="lede">
      Polaris runs the Hermes workers. Cathedral assigns cards, validates evidence, tracks reputation, and routes rewards to useful work.
    </p>
    <div class="actions">
      <a href="/intelligence">View cards</a>
      <a href="/mine">Run a worker</a>
      <a href="/validators">Validator spec</a>
    </div>
  </section>

  <section class="panel-grid" aria-label="system loop">
    <article class="panel">
      <p class="label">Demand</p>
      <h2>People need reliable answers by country.</h2>
      <p>
        AI teams, operators, and investors need regulatory updates that are sourced, current, and easy to scan.
      </p>
    </article>
    <article class="panel">
      <p class="label">Polaris</p>
      <h2>Hermes workers run the daily job.</h2>
      <p>
        Workers run on Polaris, keep state, call inference, store artifacts, and expose a deployable identity.
      </p>
    </article>
    <article class="panel">
      <p class="label">Cathedral</p>
      <h2>Validators score the evidence.</h2>
      <p>
        Cathedral checks sources, freshness, citations, maintenance, and downstream usage before rewards matter.
      </p>
    </article>
  </section>

  <section class="metrics" aria-label="current status">
    <div>
      <strong>{metrics.cardsTotal}</strong>
      <span>seed cards</span>
    </div>
    <div>
      <strong>{metrics.cardsLive}</strong>
      <span>local sample live</span>
    </div>
    <div>
      <strong>{metrics.openCards}</strong>
      <span>open cards</span>
    </div>
    <div>
      <strong>{metrics.sourceCount}</strong>
      <span>official sources</span>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="label">First baseline</p>
      <h2>Regulatory intelligence cards</h2>
      <p>
        One miner gets one country card and updates it daily. The first topic is AI regulation, using official government and regulator sources.
      </p>
    </div>
    <div class="cards">
      {liveCards.map((card) => (
        <a class="card live" href={`/cards/${card.id}`}>
          <span>{card.country}</span>
          <h3>{card.title}</h3>
          <p>{card.summary}</p>
          <small>score {card.score} · confidence {Math.round(card.confidence * 100)}%</small>
        </a>
      ))}
      {openCards.slice(0, 4).map((card) => (
        <a class="card" href={`/cards/${card.id}`}>
          <span>{card.country}</span>
          <h3>{card.title}</h3>
          <p>{card.summary}</p>
          <small>open for miner · {card.cadence}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section truth">
    <div>
      <p class="label">Truthful state</p>
      <h2>What works today</h2>
    </div>
    <ul>
      <li>Local validator preflight passes the sample EU AI Act card.</li>
      <li>Invalid fixtures fail for missing citations, weak text, and missing Polaris attribution.</li>
      <li>The website shows a coherent product surface for miners and validators.</li>
      <li>Production still needs real Hermes deploy links, signed Polaris events, and downstream usage attribution.</li>
    </ul>
  </section>

  <style>
    .hero {
      padding: 56px 0 44px;
      border-bottom: 1px solid var(--border-soft);
    }
    .label {
      margin: 0 0 14px;
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    h1 {
      margin: 0;
      max-width: 880px;
      color: var(--fg);
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-size: clamp(44px, 8vw, 92px);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
    }
    .lede {
      max-width: 720px;
      margin: 24px 0 0;
      color: var(--muted);
      font-size: 18px;
      line-height: 1.55;
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
    }
    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 28px;
    }
    .actions a {
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--fg);
      padding: 10px 14px;
      font-size: 12px;
      transition: border-color 140ms, background 140ms;
    }
    .actions a:hover,
    .actions a:focus-visible {
      border-color: var(--accent);
      background: var(--surface-2);
      outline: 2px solid transparent;
    }
    .panel-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      margin: 32px 0;
      border: 1px solid var(--border-soft);
      background: var(--border-soft);
    }
    .panel {
      min-height: 220px;
      padding: 24px;
      background: var(--bg);
    }
    .panel h2,
    .section h2 {
      margin: 0;
      color: var(--fg);
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-size: 30px;
      font-weight: 300;
      line-height: 1.1;
    }
    .panel p:not(.label),
    .section-head p,
    .truth li,
    .card p {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }
    .metrics {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      margin-bottom: 44px;
      border: 1px solid var(--border-soft);
      background: var(--border-soft);
    }
    .metrics div {
      background: var(--surface);
      padding: 18px;
    }
    .metrics strong {
      display: block;
      color: var(--fg);
      font-size: 28px;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .metrics span {
      display: block;
      margin-top: 8px;
      color: var(--dim);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .section {
      padding: 48px 0;
      border-top: 1px solid var(--border-soft);
    }
    .section-head {
      max-width: 760px;
      margin-bottom: 24px;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .card {
      display: block;
      min-height: 190px;
      padding: 20px;
      border: 1px solid var(--border);
      background: var(--surface);
      transition: border-color 140ms, transform 140ms;
    }
    .card:hover,
    .card:focus-visible {
      border-color: var(--accent);
      transform: translateY(-1px);
      outline: 2px solid transparent;
    }
    .card.live {
      border-color: var(--accent);
      background: var(--accent-dim);
    }
    .card span {
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .card h3 {
      margin: 12px 0 10px;
      color: var(--fg);
      font-size: 18px;
      line-height: 1.25;
    }
    .card small {
      display: block;
      margin-top: 18px;
      color: var(--dim);
      font-size: 11px;
      font-variant-numeric: tabular-nums;
    }
    .truth {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 32px;
    }
    .truth ul {
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .truth li {
      padding: 12px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    @media (max-width: 900px) {
      .panel-grid,
      .metrics,
      .cards,
      .truth {
        grid-template-columns: 1fr;
      }
      .panel {
        min-height: 0;
      }
    }
  </style>
</Base>
