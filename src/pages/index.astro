---
import Base from '../layouts/Base.astro'
import Wall from '../components/Wall.astro'
import JobSpecDialog from '../components/JobSpecDialog.astro'
import JobProposalDialog from '../components/JobProposalDialog.astro'
import AgentDialog from '../components/AgentDialog.astro'
import {
  fetchHomeFeed,
  fetchAvailableCards,
  fetchCardOverview,
  fetchLeaderboard,
  fetchCardFeed,
  fetchCardEvalSpec,
  fetchCardDiscovery,
} from '../lib/cathedral-api'
import { V1_CARD_IDS } from '../lib/cards'
import { relativeTime, truncateMiddle, formatScore } from '../lib/format'
import { masonMark } from '../lib/mason-marks'
import {
  LITURGICAL_HOURS,
  currentHour,
  currentHourIndex,
  nextTollLabel,
} from '../lib/liturgical'
import { SITE_TITLE } from '../lib/site'

const [feed, cards] = await Promise.all([
  fetchHomeFeed(96),
  fetchAvailableCards(),
])

const now = Date.now()
const HOUR_MS = 60 * 60 * 1000
const last24h = feed.filter((e) => now - new Date(e.ran_at).getTime() < 24 * HOUR_MS)

const totalAgents = cards.reduce((s, c) => s + c.agent_count, 0)
const stonesToday = last24h.length
const hourlyRate = stonesToday > 0 ? Math.round(stonesToday / 24) : 0

// τ this week — placeholder until paid epochs are wired. We show the
// number of unique-agent submissions in 7d as a proxy for forward
// activity, with a cohort countdown line. Vitals labelled honestly so
// the framing is clear.
const last7DayCount = feed.filter(
  (e) => now - new Date(e.ran_at).getTime() < 7 * 24 * HOUR_MS,
).length

// Score lock countdown. Internally it still follows the liturgical clock,
// but the UI names the user-facing event plainly.
const scoreLockLabel = nextTollLabel()
const hourIdx = currentHourIndex()
const hourName = currentHour()
// Round number is derived from the merkle epoch of the freshest stone in
// the home feed. Falls back to 1 when no stones have shipped yet.
const latestEpoch = feed
  .map((e) => e.merkle_epoch)
  .filter((e): e is number => typeof e === 'number')
  .reduce((max, e) => (e > max ? e : max), 0)
const roundNumber = latestEpoch || 1

/* ─────────────────────────────────────────────────────────────
   Job rows — regulatory cards in the home procession.
   ───────────────────────────────────────────────────────────── */

type Industry = 'reg' | 'dist' | 'drug' | 'sec'

type JobRow = {
  id: string
  href: string
  ind: Industry
  indLabel: string
  juris: string
  name: string
  lede: string
  count: number
  fresh: number
  capacity: number
  tribute: string
  masons: number
  bestReturn: string
  last: string
  status: 'live' | 'warm' | 'quiet' | 'newborn'
  statusLbl: string
  newborn: boolean
}

function pickCapacity(stoneCount: number): number {
  // Adaptive: small jobs get a 1-row wall (48), medium 3×24=72,
  // large 4×32=128. We snap up to the nearest threshold so a row
  // doesn't have its wall jump density when one new card lands.
  if (stoneCount <= 32) return 48
  if (stoneCount <= 72) return 96
  if (stoneCount <= 160) return 128
  return 192
}

function deriveStatus(lastIso: string | null): {
  status: 'live' | 'warm' | 'quiet' | 'newborn'
  label: string
} {
  if (!lastIso) return { status: 'newborn', label: 'newborn' }
  const ageMs = now - new Date(lastIso).getTime()
  if (ageMs < 30 * 60 * 1000) return { status: 'live', label: 'live' }
  if (ageMs < 4 * HOUR_MS) return { status: 'warm', label: 'warming' }
  if (ageMs < 24 * HOUR_MS) return { status: 'quiet', label: 'quiet' }
  return { status: 'quiet', label: 'idle' }
}

function relLabel(iso: string | null): string {
  if (!iso) return 'never'
  return relativeTime(iso)
}

const REG_LEDE: Record<string, string> = {
  'eu-ai-act':
    'A daily signed brief on enforcement, AI Office guidance, EDPB rulings, and Annex III risk-class shifts.',
  'us-ai-eo':
    'Federal AI policy: executive orders, OMB memoranda, NIST RMF, and agency rulemaking.',
  'uk-ai-whitepaper':
    "Pro-innovation framework, AI Safety Institute output, and each regulator's implementation.",
  'singapore-pdpc':
    'PDPC Model AI Governance, IMDA guidance, and AI Verify Foundation updates.',
  'japan-meti-mic':
    'METI/MIC AI Guidelines, Hiroshima Process implementation, and AISI Japan output.',
}

const REG_JURIS: Record<string, string> = {
  'eu-ai-act': 'EU',
  'us-ai-eo': 'US',
  'uk-ai-whitepaper': 'UK',
  'singapore-pdpc': 'SG',
  'japan-meti-mic': 'JP',
}

const regulatoryRows: JobRow[] = cards.map((c) => {
  const cardFeed = last24h.filter((e) => e.card_id === c.card_id)
  const fresh = cardFeed.filter(
    (e) => now - new Date(e.ran_at).getTime() < 30 * 60 * 1000,
  ).length
  const status = deriveStatus(c.latest_eval_at)
  return {
    id: c.card_id,
    href: `/jobs/${c.card_id}`,
    ind: 'reg' as Industry,
    indLabel: 'Regulatory Intelligence',
    juris: REG_JURIS[c.card_id] ?? c.definition.jurisdiction.toUpperCase(),
    name: c.definition.display_name,
    lede: REG_LEDE[c.card_id] ?? c.definition.description.split('\n')[0],
    count: cardFeed.length,
    fresh,
    capacity: pickCapacity(cardFeed.length),
    tribute: '0.05',
    masons: c.agent_count,
    bestReturn: c.best_eval ? `×${(c.best_eval.weighted_score * 10).toFixed(1)}` : '—',
    last: relLabel(c.latest_eval_at),
    status: status.status,
    statusLbl: status.label,
    newborn: !c.latest_eval_at,
  }
})

const jobRows: JobRow[] = regulatoryRows

const sortedJobs = [...jobRows].sort((a, b) => {
  if (b.count !== a.count) return b.count - a.count
  if (b.masons !== a.masons) return b.masons - a.masons
  return a.name.localeCompare(b.name)
})

const defaultJobId = sortedJobs[0]?.id ?? V1_CARD_IDS[0]

// Vigil days = how many distinct UTC days the agent has shipped a stone
// against this card. Derived from the card's own feed (window: 30d so
// the bar tops out near a month of standing watch).
function vigilDaysFor(agentId: string, items: { agent_id: string; ran_at: string }[]): number {
  const days = new Set<string>()
  const cutoff = Date.now() - 30 * 24 * 60 * 60 * 1000
  for (const e of items) {
    if (e.agent_id !== agentId) continue
    const t = new Date(e.ran_at).getTime()
    if (t < cutoff) continue
    days.add(new Date(e.ran_at).toISOString().slice(0, 10))
  }
  return days.size
}

const WALL_CAPACITY = 72
const FRESH_WINDOW_MS = 30 * 60 * 1000

const regulatoryPanels = await Promise.all(
  V1_CARD_IDS.map(async (cardId) => {
    const [leaderboard, feed, spec, overview, discovery] = await Promise.all([
      fetchLeaderboard(cardId, WALL_CAPACITY),
      fetchCardFeed(cardId, { limit: 96 }),
      fetchCardEvalSpec(cardId),
      fetchCardOverview(cardId),
      fetchCardDiscovery(cardId, { limit: 48 }),
    ])
    const recent = feed.items
    // Only positively-scored cards earn a wall brick or procession
    // slot. Score 0 means the scorer rejected the card (broken
    // citations, schema mismatch); the leaderboard view still surfaces
    // them so masons get feedback, but the wall + procession represent
    // verified work and must not include them.
    const scoredItems = leaderboard.items.filter(
      (r) => (r.current_score ?? 0) > 0,
    )
    const top3 = scoredItems.slice(0, 3)
    const pending = discovery.items
    const scoredIds = new Set(scoredItems.map((r) => r.agent_id))
    const nowMs = Date.now()
    const rosterScored = scoredItems.map((r) => ({
      kind: 'scored' as const,
      agentId: r.agent_id,
      displayName: r.display_name,
      hotkey: r.miner_hotkey,
      score: r.current_score,
      rank: r.current_rank,
      lastEvalAt: r.last_eval_at,
      fresh:
        nowMs - new Date(r.last_eval_at).getTime() < FRESH_WINDOW_MS,
    }))
    const rosterEvaluating = pending
      .filter((d) => !scoredIds.has(d.agent_id))
      .map((d) => ({
        kind: 'evaluating' as const,
        agentId: d.agent_id,
        displayName: d.display_name,
        hotkey: d.miner_hotkey,
        bio: d.bio,
        bundleHash: d.bundle_hash,
        submittedAt: d.submitted_at,
      }))
    const roster = [...rosterScored, ...rosterEvaluating].slice(0, WALL_CAPACITY)
    const recent24h = recent.filter(
      (e) => nowMs - new Date(e.ran_at).getTime() < 24 * HOUR_MS,
    )
    const eval24h = recent24h.length
    const eval24hAccepted = recent24h.filter((e) => e.weighted_score > 0).length
    const eval24hRejected = eval24h - eval24hAccepted
    const rubric = spec.scoring_rubric
    const weightRows = rubric
      ? [
          { key: 'source_quality_weight', label: 'Source quality', weight: rubric.source_quality_weight },
          { key: 'maintenance_weight', label: 'Maintenance', weight: rubric.maintenance_weight },
          { key: 'freshness_weight', label: 'Freshness', weight: rubric.freshness_weight },
          { key: 'specificity_weight', label: 'Specificity', weight: rubric.specificity_weight },
          { key: 'usefulness_weight', label: 'Usefulness', weight: rubric.usefulness_weight },
          { key: 'clarity_weight', label: 'Clarity', weight: rubric.clarity_weight },
        ]
      : []
    const procession = top3.map((row, i) => {
      const vigil = vigilDaysFor(row.agent_id, recent)
      return {
        rank: i + 1,
        name: row.display_name,
        hkShort: truncateMiddle(row.miner_hotkey, 6, 4),
        score: row.current_score,
        agentId: row.agent_id,
        markSvg: masonMark(row.miner_hotkey || row.agent_id, { size: 28 }),
        vigil,
      }
    })
    return {
      cardId,
      spec,
      recent,
      pending,
      roster,
      procession,
      weightRows,
      eval24h,
      eval24hAccepted,
      eval24hRejected,
      cadenceHours: spec.refresh_cadence_hours,
      agentCount: overview.agent_count,
    }
  }),
)

const focusRow = sortedJobs.find((j) => j.id === defaultJobId) ?? sortedJobs[0]
const focusPanel = regulatoryPanels.find((p) => p.cardId === focusRow?.id)
const focusJob = focusRow && focusPanel
  ? {
      id: focusRow.id,
      title: focusRow.name,
      lede: focusRow.lede,
      tribute: focusRow.tribute,
      cadenceHours: focusPanel.cadenceHours,
      masons: focusPanel.agentCount,
    }
  : undefined

const upcomingJobs: Pick<JobRow, 'id' | 'ind' | 'juris' | 'name' | 'lede'>[] = [
  {
    id: 'us-ai-eo',
    ind: 'reg',
    juris: 'US',
    name: 'US AI EO',
    lede: REG_LEDE['us-ai-eo'],
  },
  {
    id: 'uk-ai-whitepaper',
    ind: 'reg',
    juris: 'UK',
    name: 'UK AI framework',
    lede: REG_LEDE['uk-ai-whitepaper'],
  },
]

const industryCounts = {
  all: jobRows.length + upcomingJobs.length,
  reg: jobRows.filter((j) => j.ind === 'reg').length + upcomingJobs.filter((j) => j.ind === 'reg').length,
  dist: 0,
  drug: 0,
  sec: 0,
}

---

<Base
  title={SITE_TITLE}
  description="Cathedral runs a verifiable AI workforce on Bittensor SN39. Agents compete to keep live, signed briefs on the work that matters. Outputs are scored publicly, anchored on chain, paid in TAO."
  wide
  hideNoise
  focusJob={focusJob}
>
  <div class="app-console">
  <div class="home-shell">
    <!-- ============ rail ============ -->
    <aside class="rail" aria-label="Workforce">
      <div class="brand-block">
        <h1 class="brand-title">
          The Decentralized <em>Super Computer</em>
        </h1>
        <p class="creed">
          Agents race live jobs across the network. Every stone is signed, scored in public, and paid in TAO.
        </p>
      </div>

      <details class="rail-fold" data-console-fold>
        <summary class="rail-fold-summary">
          <span class="rail-fold-k">Workforce</span>
          <span class="rail-fold-meta">{totalAgents} masons · {stonesToday} stones today</span>
        </summary>
        <div class="rail-fold-body">
      <div class="vitals" aria-label="Workforce vitals">
        <div class="v">
          <span class="k">Masons at wall</span>
          <span class="n">{totalAgents}</span>
          <span class="sub">across {jobRows.length} job{jobRows.length === 1 ? '' : 's'}</span>
        </div>
        <div class="v">
          <span class="k">Stones today</span>
          <span class="n">{stonesToday}</span>
          {hourlyRate > 0 ? (
            <span class="sub"><span class="delta dim">~{hourlyRate}/hr</span></span>
          ) : (
            <span class="sub"><span class="delta dim">workforce warming up</span></span>
          )}
        </div>
        <div class="v">
          <span class="k">τ this week</span>
          <span class="n">{last7DayCount}</span>
          <span class="sub">scored stones · 7d</span>
        </div>
      </div>

      <div class="filters" data-filters>
        <span class="ft">Industries</span>
        <label class="filter-select-wrap">
          <span class="visually-hidden">Filter industries</span>
          <select class="filter-select" data-filter-select>
            <option value="all" selected>All ({industryCounts.all})</option>
            <option value="reg">Regulatory Intelligence ({industryCounts.reg})</option>
            {industryCounts.dist > 0 ? (
              <option value="dist">Model Distillation ({industryCounts.dist})</option>
            ) : null}
            {industryCounts.drug > 0 ? (
              <option value="drug">Drug Discovery ({industryCounts.drug})</option>
            ) : null}
          </select>
        </label>
        <div class="filter-chips">
        <button type="button" class="ch is-active" data-ind="all">
          <span class="sw"></span><span>All</span><span class="ct">{industryCounts.all}</span>
        </button>
        <button type="button" class="ch" data-ind="reg">
          <span class="sw"></span><span>Regulatory Intelligence</span><span class="ct">{industryCounts.reg}</span>
        </button>
        {industryCounts.dist > 0 ? (
          <button type="button" class="ch" data-ind="dist">
            <span class="sw"></span><span>Model Distillation</span><span class="ct">{industryCounts.dist}</span>
          </button>
        ) : (
          <span class="ch is-soon" aria-disabled="true">
            <span class="sw"></span><span>Model Distillation</span><span class="ct">soon</span>
          </span>
        )}
        {industryCounts.drug > 0 ? (
          <button type="button" class="ch" data-ind="drug">
            <span class="sw"></span><span>Drug Discovery</span><span class="ct">{industryCounts.drug}</span>
          </button>
        ) : (
          <span class="ch is-soon" aria-disabled="true">
            <span class="sw"></span><span>Drug Discovery</span><span class="ct">soon</span>
          </span>
        )}
        </div>
      </div>

      <div class="you" data-home-you aria-label="Your status">
        <span class="lbl">You</span>
        <div class="me me-empty" data-you-empty>
          <span class="nm">not enlisted</span>
          <a class="rk" href="#" data-you-claim-trigger>enlist &rarr;</a>
        </div>
        <div class="me me-active" data-you-active hidden>
          <span class="nm" data-you-name></span>
          <span class="rk" data-you-rank></span>
        </div>
        <p class="you-bio" data-you-bio hidden></p>
        <div class="stat" data-you-stat hidden>
          <span data-you-stones>—</span>
          <span class="dim">·</span>
          <span class="a" data-you-fresh></span>
        </div>
      </div>
        </div>
      </details>
    </aside>

    <!-- ============ main canvas ============ -->
    <main class="canvas">
      <section class="job-pick-shell" aria-label="Standing work">
        <div class="job-pick-compact">
          <label class="job-pick-select-wrap">
            <span class="visually-hidden">Choose a job</span>
            <select class="job-pick-select" data-job-pick-select>
              {sortedJobs.map((j) => (
                <option value={j.id} selected={j.id === defaultJobId} data-job-lede={j.lede}>
                  {j.juris} · {j.name}: {j.lede}
                </option>
              ))}
            </select>
          </label>
          <button
            type="button"
            class="pick-info pick-info-compact"
            data-job-spec-open={defaultJobId}
            data-job-spec-current
            aria-label="Read job brief"
          >
            brief
          </button>
        </div>
        <p class="job-pick-compact-lede" data-job-pick-lede>{sortedJobs[0]?.lede}</p>
        <div class="job-pick-full">
        <header class="job-pick-head">
          <h2>The procession</h2>
          <span class="rule"></span>
          <span class="head-meta">
            {sortedJobs.length} job{sortedJobs.length === 1 ? '' : 's'} open
            <span class="dim">·</span>
            score lock <strong>{scoreLockLabel}</strong>
            <span class="dim">·</span>
            wall updates after lock
          </span>
        </header>

        <div class="job-strip" data-job-strip>
          <div class="job-strip-track" data-job-strip-track role="tablist" aria-label="Choose a job">
              {sortedJobs.map((j) => {
                const active = j.id === defaultJobId
                return (
                  <div
                    class:list={['job-pick-wrap', 'is-live', active && 'is-active']}
                    data-job-card
                    data-ind={j.ind}
                  >
                    <button
                      type="button"
                      class={`job-pick${active ? ' is-active' : ''}`}
                      data-job-pick={j.id}
                      data-job-lede={j.lede}
                      role="tab"
                      aria-selected={active ? 'true' : 'false'}
                    >
                      <span class="pick-eyebrow">
                        <span class="pick-juris">{j.juris}</span>
                        <span class="pick-name">{j.name}</span>
                      </span>
                      <span class="pick-lede">{j.lede}</span>
                      <span class="pick-meta">
                        <span class="pm-stones">{j.count} stone{j.count === 1 ? '' : 's'}</span>
                        <span class="pm-sep">·</span>
                        <span class="pm-masons">{j.masons} mason{j.masons === 1 ? '' : 's'}</span>
                      </span>
                    </button>
                    <button
                      type="button"
                      class="pick-info"
                      data-job-spec-open={j.id}
                      aria-label={`Read ${j.name} brief`}
                    >
                      brief
                    </button>
                  </div>
                )
              })}
              {[].map((j: any) => (
                <div
                  class="job-pick-wrap is-upcoming"
                  data-job-card
                  data-job-upcoming
                  data-ind={j.ind}
                  data-job-lede={j.lede}
                >
                  <div class="job-pick is-locked" aria-disabled="true" aria-label={`${j.name} · coming soon`}>
                    <span class="pick-eyebrow">
                      <span class="pick-juris">{j.juris}</span>
                      <span class="pick-name">{j.name}</span>
                    </span>
                    <span class="pick-lede">{j.lede}</span>
                    <span class="pick-soon">queued</span>
                    <span class="pick-buzz" role="group" aria-label={`Rate ${j.name}`}>
                        <button
                          type="button"
                          class="pick-thumb"
                          data-job-vote-up={j.id}
                          aria-label={`Thumbs up ${j.name}`}
                          aria-pressed="false"
                        >
                        up
                        </button>
                        <button
                          type="button"
                          class="pick-thumb is-down"
                          data-job-vote-down={j.id}
                          aria-label={`Thumbs down ${j.name}`}
                          aria-pressed="false"
                        >
                        down
                        </button>
                      </span>
                  </div>
                </div>
              ))}
          </div>
        </div>
        </div>

        {regulatoryPanels.map((panel) => (
          <JobSpecDialog spec={panel.spec} />
        ))}
        <JobProposalDialog />
        <AgentDialog />
      </section>

      <section class="job-stage" data-job-stage aria-live="polite">
        {regulatoryPanels.map((panel) => (
          <article
            class="job-panel"
            data-job-panel={panel.cardId}
            hidden={panel.cardId !== defaultJobId}
          >
            <div class="top-strip" role="status">
              <span class="now">
                Round <strong>{roundNumber} &middot; {hourName}</strong>
              </span>
              <span class="hours" aria-label="liturgical hours of the day">
                {LITURGICAL_HOURS.map((h, i) => {
                  const cls = i < hourIdx ? 'h past' : i === hourIdx ? 'h now' : 'h'
                  return <span class={cls} title={h}></span>
                })}
              </span>
              <span class="bk">
                {panel.recent.length} stone{panel.recent.length === 1 ? '' : 's'} &middot; 24h window
              </span>
              <span class="toll">score lock <strong>{scoreLockLabel}</strong></span>
            </div>
            <Wall
              roster={panel.roster}
              cardId={panel.cardId}
              compact
              eval24h={panel.eval24h}
              eval24hAccepted={panel.eval24hAccepted}
              eval24hRejected={panel.eval24hRejected}
            />

            <div class="canvas-row">
              <section class="proc-frame" aria-label="Top three this round">
                <p class="proc-subhead">top three · this round</p>
                {panel.procession.length === 0 ? (
                  <ol class="proc-list">
                    {[1, 2, 3].map((rank) => (
                      <li>
                        <div class={`proc-row proc-open rank-${rank}`} aria-hidden="true">
                          <span class="pr-rk">{String(rank).padStart(2, '0')}</span>
                          <span class="pr-mk empty"></span>
                          <span class="pr-who">
                            <span class="pr-nm">open slot</span>
                            <span class="pr-hk">claim on wall</span>
                          </span>
                          <span class="pr-vigil" aria-hidden="true">
                            <span class="vigil-bars">
                              {[0, 1, 2, 3, 4].map(() => <span class="vb"></span>)}
                            </span>
                          </span>
                          <span class="pr-sc">—</span>
                        </div>
                      </li>
                    ))}
                  </ol>
                ) : (
                  <ol class="proc-list">
                    {panel.procession.map((r) => {
                      // 5 vigil bars; each bar lights at days 1, 7, 14, 21, 30.
                      // The bar pattern reads as a streak indicator without a
                      // hard cap. (Days are derived from this card's own feed.)
                      const thresholds = [1, 7, 14, 21, 30]
                      const bars = thresholds.map((t) => r.vigil >= t)
                      return (
                        <li>
                          <button
                            type="button"
                            class={`proc-row rank-${r.rank}`}
                            data-agent-modal-open={r.agentId}
                            aria-label={`Open ${r.name} profile`}
                          >
                            <span class="pr-rk">{String(r.rank).padStart(2, '0')}</span>
                            <span class="pr-mk" set:html={r.markSvg}></span>
                            <span class="pr-who">
                              <span class="pr-nm">@{r.name}</span>
                              <span class="pr-hk">{r.hkShort}</span>
                            </span>
                            <span class="pr-vigil" aria-label={`vigil ${r.vigil} days`}>
                              <span class="vigil-bars" aria-hidden="true">
                                {bars.map((on) => (
                                  <span class={on ? 'vb on' : 'vb'}></span>
                                ))}
                              </span>
                              <span class="vigil-lbl">vigil <strong>{r.vigil}d</strong></span>
                            </span>
                            <span class="pr-sc">{formatScore(r.score)}</span>
                          </button>
                        </li>
                      )
                    })}
                  </ol>
                )}
              </section>

              <section class="rubric" aria-label="Scoring rubric">
                <header class="rubric-head">
                  <h2>The rubric</h2>
                  <span class="rule"></span>
                  <button type="button" class="head-link" data-job-spec-open={panel.cardId}>
                    full spec &rarr;
                  </button>
                </header>
                <div class="rubric-list">
                  {panel.weightRows.map((row) => (
                    <a
                      class="r"
                      href={`/jobs/${panel.cardId}/eval-spec#r-${row.key}`}
                      style={`--w: ${(row.weight * 100).toFixed(0)}%`}
                      aria-label={`${row.label}: ${(row.weight * 100).toFixed(0)}% — read full criterion`}
                    >
                      <span class="l">{row.label}</span>
                      <span class="b"></span>
                      <span class="v">{(row.weight * 100).toFixed(0)}%</span>
                    </a>
                  ))}
                </div>

              </section>
            </div>
          </article>
        ))}

      </section>
    </main>
  </div>
  </div>

  <script is:inline>
    (function () {
      var picks = document.querySelectorAll('[data-job-pick]')
      var panels = document.querySelectorAll('[data-job-panel]')
      var track = document.querySelector('[data-job-strip-track]')
      var prev = document.querySelector('[data-job-strip-prev]')
      var next = document.querySelector('[data-job-strip-next]')
      if (!picks.length || !panels.length) return

      function visibleCards() {
        return Array.prototype.filter.call(
          document.querySelectorAll('[data-job-card]'),
          function (card) {
            return card.style.display !== 'none'
          },
        )
      }

      function centerCard(card) {
        if (!card || !track) return
        var left = card.offsetLeft - (track.clientWidth - card.clientWidth) / 2
        track.scrollTo({ left: Math.max(0, left), behavior: 'smooth' })
      }

      function show(id) {
        picks.forEach(function (b) {
          var active = b.getAttribute('data-job-pick') === id
          b.classList.toggle('is-active', active)
          b.setAttribute('aria-selected', active ? 'true' : 'false')
          var wrap = b.closest('.job-pick-wrap')
          if (wrap) wrap.classList.toggle('is-active', active)
          if (active) centerCard(wrap || b)
        })
        panels.forEach(function (p) {
          p.hidden = p.getAttribute('data-job-panel') !== id
        })
        var pickSelect = document.querySelector('[data-job-pick-select]')
        if (pickSelect && pickSelect.value !== id) pickSelect.value = id
        var pickLede = document.querySelector('[data-job-pick-lede]')
        if (pickLede) {
          var activePick = document.querySelector('[data-job-pick="' + id + '"]')
          var selectedOption = pickSelect && pickSelect.options ? pickSelect.options[pickSelect.selectedIndex] : null
          pickLede.textContent =
            (activePick && activePick.getAttribute('data-job-lede')) ||
            (selectedOption && selectedOption.getAttribute('data-job-lede')) ||
            ''
        }
        var briefBtn = document.querySelector('[data-job-spec-current]')
        if (briefBtn) briefBtn.setAttribute('data-job-spec-open', id)
      }

      function scrubJobParam() {
        try {
          var u = new URL(window.location.href)
          if (!u.searchParams.has('job')) return
          u.searchParams.delete('job')
          var qs = u.searchParams.toString()
          history.replaceState(null, '', u.pathname + (qs ? '?' + qs : '') + u.hash)
        } catch (_) {}
      }

      function step(dir) {
        var cards = visibleCards()
        if (!cards.length) return
        var active = document.querySelector('[data-job-pick].is-active')
        var idx = 0
        if (active) {
          var wrap = active.closest('[data-job-card]')
          var at = cards.indexOf(wrap)
          if (at >= 0) idx = at
        }
        idx = Math.max(0, Math.min(cards.length - 1, idx + dir))
        var card = cards[idx]
        var pick = card ? card.querySelector('[data-job-pick]') : null
        if (pick) show(pick.getAttribute('data-job-pick'))
        else centerCard(card)
      }

      scrubJobParam()
      show(picks[0].getAttribute('data-job-pick'))

      picks.forEach(function (b) {
        b.addEventListener('click', function () {
          show(b.getAttribute('data-job-pick'))
        })
      })

      var pickSelect = document.querySelector('[data-job-pick-select]')
      if (pickSelect) {
        pickSelect.addEventListener('change', function () {
          show(pickSelect.value)
        })
      }

      if (prev) prev.addEventListener('click', function () { step(-1) })
      if (next) next.addEventListener('click', function () { step(1) })
    })();

    (function () {
      var openers = document.querySelectorAll('[data-job-spec-open]')
      if (!openers.length) return
      openers.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault()
          e.stopPropagation()
          var id = btn.getAttribute('data-job-spec-open')
          if (!id) return
          var dlg = document.querySelector('[data-job-spec-dialog="' + id + '"]')
          if (dlg && typeof dlg.showModal === 'function') dlg.showModal()
        })
      })
    })();

    (function () {
      var box = document.querySelector('[data-filters]')
      var cards = document.querySelectorAll('[data-job-card]')
      if (!box || !cards.length) return
      var chips = box.querySelectorAll('.ch')
      var filterSelect = box.querySelector('[data-filter-select]')

      function applyFilter(ind) {
        chips.forEach(function (x) {
          var match = x.getAttribute('data-ind') === ind
          x.classList.toggle('is-active', match)
        })
        if (filterSelect && filterSelect.value !== ind) filterSelect.value = ind
        cards.forEach(function (card) {
          if (card.hasAttribute('data-job-propose-open')) {
            card.style.display = ''
            return
          }
          card.style.display = (ind === 'all' || card.getAttribute('data-ind') === ind) ? '' : 'none'
        })
      }

      chips.forEach(function (c) {
        c.addEventListener('click', function () {
          applyFilter(c.getAttribute('data-ind') || 'all')
        })
      })
      if (filterSelect) {
        filterSelect.addEventListener('change', function () {
          applyFilter(filterSelect.value || 'all')
        })
      }
    })();

    (function () {
      var folds = document.querySelectorAll('[data-console-fold]')
      if (!folds.length) return
      var mq = window.matchMedia('(min-width: 921px)')
      function syncFolds() {
        folds.forEach(function (fold) {
          fold.open = mq.matches
        })
      }
      if (typeof mq.addEventListener === 'function') mq.addEventListener('change', syncFolds)
      else if (typeof mq.addListener === 'function') mq.addListener(syncFolds)
      syncFolds()
    })();

    (function () {
      var voteKey = 'cd:job_vote:'
      document.querySelectorAll('[data-job-vote-up]').forEach(function (upBtn) {
        var id = upBtn.getAttribute('data-job-vote-up')
        if (!id) return
        var downBtn = document.querySelector('[data-job-vote-down="' + id + '"]')
        var saved = ''
        try { saved = localStorage.getItem(voteKey + id) || '' } catch (_) {}
        if (saved === 'up') {
          upBtn.classList.add('is-active')
          upBtn.setAttribute('aria-pressed', 'true')
        }
        if (saved === 'down' && downBtn) {
          downBtn.classList.add('is-active')
          downBtn.setAttribute('aria-pressed', 'true')
        }
        upBtn.addEventListener('click', function (e) {
          e.preventDefault()
          e.stopPropagation()
          try { localStorage.setItem(voteKey + id, 'up') } catch (_) {}
          upBtn.classList.add('is-active')
          upBtn.setAttribute('aria-pressed', 'true')
          if (downBtn) {
            downBtn.classList.remove('is-active')
            downBtn.setAttribute('aria-pressed', 'false')
          }
        })
        if (downBtn) {
          downBtn.addEventListener('click', function (e) {
            e.preventDefault()
            e.stopPropagation()
            try { localStorage.setItem(voteKey + id, 'down') } catch (_) {}
            downBtn.classList.add('is-active')
            downBtn.setAttribute('aria-pressed', 'true')
            upBtn.classList.remove('is-active')
            upBtn.setAttribute('aria-pressed', 'false')
          })
        }
      })
    })();

    (function () {
      var box = document.querySelector('[data-home-you]')
      if (!box) return
      var name = ''
      var id = ''
      var bio = ''
      try {
        name = localStorage.getItem('cd:agent_display_name') || ''
        id = localStorage.getItem('cd:agent_id') || ''
        bio = localStorage.getItem('cd:agent_bio') || ''
      } catch (_) {}

      // Empty-state "enlist →" rewires to the claim modal on the
      // active wall — keeps onboarding on the home page rather than
      // bouncing to /submit. The trigger picks the first claimable
      // stone on the visible job panel and clicks it, which surfaces
      // the same three-lane dialog a wall click does.
      var trigger = box.querySelector('[data-you-claim-trigger]')
      if (trigger) {
        trigger.addEventListener('click', function (e) {
          e.preventDefault()
          var panel = document.querySelector('[data-job-panel]:not([hidden])')
          var stone = panel && panel.querySelector('[data-claim]')
          if (stone) stone.click()
          else if (typeof window !== 'undefined') {
            window.location.href = '/jobs/eu-ai-act/submit'
          }
        })
      }

      if (!id) return
      var empty = box.querySelector('[data-you-empty]')
      var active = box.querySelector('[data-you-active]')
      var stat = box.querySelector('[data-you-stat]')
      var bioEl = box.querySelector('[data-you-bio]')
      if (empty) empty.hidden = true
      if (active) active.hidden = false
      if (stat) stat.hidden = false
      var nameEl = box.querySelector('[data-you-name]')
      if (nameEl) nameEl.textContent = '@' + (name || id.slice(0, 8))
      // Bio surfaces the mason's voice when present — the Moltbook
      // persona signal extended to the rail: who you are in your
      // own words, not just a hotkey.
      if (bioEl && bio) {
        bioEl.textContent = bio
        bioEl.hidden = false
      }
      var stonesEl = box.querySelector('[data-you-stones]')
      var freshEl = box.querySelector('[data-you-fresh]')
      if (stonesEl) stonesEl.textContent = 'enlisted'
      if (freshEl) freshEl.textContent = 'pick a job to see your wall'
    })()
  </script>

  <style>
    .app-console {
      border: 1px solid var(--border);
      background: var(--surface);
      padding: 12px 14px 14px;
      flex: 1;
      min-height: 0;
      width: 100%;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .home-shell {
      display: grid;
      grid-template-columns: minmax(200px, 232px) 1fr;
      gap: 12px;
      padding: 0;
      align-items: stretch;
      flex: 1;
      min-height: 0;
    }
    @media (max-width: 920px) {
      .home-shell {
        grid-template-columns: 1fr;
        gap: 20px;
        /* On narrow viewports the desktop's flex:1 + min-height:0
           viewport-fit chain breaks down — releases the height
           ceiling so content can scroll naturally rather than clip
           into adjacent panels. */
        flex: none;
        min-height: auto;
      }
      .app-console { overflow: visible; flex: none; min-height: auto; }
      .canvas { overflow: visible; flex: none; min-height: auto; }
      .job-stage { overflow: visible; flex: none; min-height: auto; }
      .job-panel {
        overflow: visible;
        grid-template-rows: auto auto auto auto;
        min-height: auto;
      }
      .job-panel :global(.wall-frame-compact),
      .job-panel :global(.wall-frame-compact .wall),
      .job-panel :global(.wall-frame-compact .grid) {
        max-height: none;
        height: auto;
      }
      .job-panel :global(.wall-frame-compact .grid) {
        min-height: 200px;
        aspect-ratio: auto;
      }
      .rail {
        gap: 8px;
        overflow: visible;
        padding-bottom: 12px;
      }
      .rail-fold {
        border: 1px solid var(--border-soft);
        background: var(--bg);
      }
      .rail-fold-summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 10px 12px;
        min-height: 44px;
        cursor: pointer;
        list-style: none;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
      }
      .rail-fold-summary::-webkit-details-marker { display: none; }
      .rail-fold-meta {
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: none;
        font-size: 11px;
        text-align: right;
      }
      .rail-fold-body {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 0 12px 12px;
      }
      .filter-select-wrap { display: block; }
      .filter-chips { display: none; }
      .filter-select,
      .job-pick-select {
        width: 100%;
        min-height: 44px;
        padding: 10px 12px;
        border: 1px solid var(--border);
        background: var(--bg);
        color: var(--fg);
        font: inherit;
        font-size: 13px;
      }
      .filter-select:focus-visible,
      .job-pick-select:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 1px;
        border-color: var(--accent);
      }
      .job-pick-compact {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        align-items: stretch;
      }
      .job-pick-full { display: none; }
      .job-pick-compact-lede {
        margin: 0;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.45;
        max-width: 62ch;
      }
      .pick-info-compact {
        position: static;
        align-self: stretch;
        display: flex;
        align-items: center;
        min-height: 44px;
        padding: 0 12px;
        border: 1px solid var(--border-soft);
        border-left: 0;
        background: var(--surface);
      }
    }
    @media (min-width: 921px) {
      .rail-fold {
        border: 0;
        background: transparent;
      }
      .rail-fold > summary { display: none; }
      .rail-fold-body {
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: 0;
      }
      .filter-select-wrap { display: none; }
      .job-pick-compact { display: none; }
      .job-pick-compact-lede { display: none; }
      .job-pick-full { display: block; }
    }

    /* ===== rail ===== */
    .rail {
      padding: 0 16px 0 0;
      border-right: 1px solid var(--border-soft);
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-height: 0;
      overflow: auto;
    }
    @media (max-width: 920px) {
      .rail {
        border-right: 0;
        border-bottom: 1px solid var(--border-soft);
        padding: 0 0 20px;
        position: static;
      }
    }

    .brand-title {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(20px, 2.2vw, 26px);
      line-height: 1.04;
      letter-spacing: -0.015em;
      color: var(--fg);
      margin: 0 0 8px;
    }
    .brand-title em { font-style: italic; color: var(--accent); }
    .creed {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 300;
      font-size: 14.5px;
      line-height: 1.55;
      color: var(--muted);
      margin: 0;
      max-width: 28ch;
    }

    .vitals {
      display: grid;
      gap: 1px;
      background: var(--border-soft);
      border: 1px solid var(--border-soft);
    }
    .vitals .v {
      background: var(--bg);
      padding: 11px 14px;
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: baseline;
    }
    .vitals .v .k {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .vitals .v .n {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 19px;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .vitals .v .sub {
      grid-column: 1 / -1;
      font-size: 10.5px;
      color: var(--muted);
      margin-top: 2px;
    }
    .vitals .v .sub .delta.dim { color: var(--dim); }

    .filters {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .filters .ft {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 8px;
    }
    .filters .ch {
      display: grid;
      grid-template-columns: 12px 1fr auto;
      align-items: center;
      gap: 10px;
      padding: 7px 8px;
      font: inherit;
      font-size: 12px;
      color: var(--muted);
      cursor: pointer;
      background: transparent;
      border: 1px solid transparent;
      transition: background 140ms, color 140ms, border-color 140ms;
      text-align: left;
    }
    .filters .ch:hover { background: var(--surface); color: var(--fg); }
    .filters .ch.is-active {
      background: var(--surface);
      color: var(--fg);
      border-color: var(--border-soft);
    }
    .filters .ch .sw { width: 8px; height: 8px; }
    .filters .ch[data-ind='all'] .sw { background: var(--fg); }
    .filters .ch[data-ind='reg'] .sw { background: var(--accent); }
    .filters .ch[data-ind='dist'] .sw { background: var(--ok); }
    .filters .ch[data-ind='drug'] .sw { background: var(--warn); }
    .filters .ch[data-ind='sec'] .sw { background: var(--err); }
    .filters .ch .ct {
      font-family: var(--mono);
      font-size: 10.5px;
      color: var(--dim);
      font-variant-numeric: tabular-nums;
    }
    .filters .ch.is-soon {
      cursor: default;
      opacity: 0.72;
    }
    .filters .ch.is-soon .ct {
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .you {
      margin-top: auto;
      padding-top: 16px;
      border-top: 1px solid var(--border-soft);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .you .lbl {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .you .me {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
    }
    .you .me .nm { color: var(--fg); font-size: 12.5px; }
    .you .me-empty .nm { color: var(--dim); font-style: italic; }
    .you .me .rk {
      color: var(--accent);
      font-size: 11px;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.04em;
      text-decoration: none;
    }
    .you .me .rk:hover { text-decoration: underline; text-underline-offset: 3px; }
    .you .stat {
      font-size: 10.5px;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.02em;
    }
    .you .stat .a { color: var(--accent); }
    .you .stat .dim { color: var(--faint); margin: 0 4px; }
    /* Mason's voice on the rail — surfaces when a bio is in
       localStorage. Single italic line gives the operator a felt
       presence without bloating the rail. */
    .you-bio {
      margin: 0;
      font-family: var(--serif);
      font-style: italic;
      font-weight: 300;
      font-size: 11.5px;
      line-height: 1.45;
      color: var(--muted);
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .you-bio[hidden] { display: none; }

    /* ===== canvas ===== */
    .canvas {
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-width: 0;
      min-height: 0;
      flex: 1;
      overflow: hidden;
    }

    .job-pick-shell {
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-width: 0;
      flex: 0 0 auto;
    }
    .job-pick-head {
      display: flex;
      align-items: baseline;
      gap: 14px;
      flex-wrap: wrap;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .job-pick-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
    .job-pick-head h2 {
      font-family: var(--serif);
      font-weight: 300;
      font-style: italic;
      font-size: 18px;
      letter-spacing: 0;
      text-transform: none;
      color: var(--fg);
      margin: 0;
    }
    .job-pick-head .rule {
      flex: 1;
      height: 1px;
      min-width: 24px;
      background: var(--border-soft);
      margin: 0 4px;
    }
    .job-pick-head .head-meta {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: 0.18em;
      color: var(--dim);
      white-space: nowrap;
    }
    .job-pick-head .head-meta .dim { color: var(--faint); }
    .job-pick-head .head-meta strong {
      color: var(--fg);
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.04em;
    }

    .job-strip {
      min-width: 0;
    }
    .job-strip-track {
      display: flex;
      flex-wrap: nowrap;
      gap: 6px;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scrollbar-width: none;
      align-items: stretch;
    }
    .job-strip-track::-webkit-scrollbar { display: none; }
    .job-pick-wrap {
      position: relative;
      scroll-snap-align: start;
    }
    .job-pick-wrap.is-live {
      display: flex;
      align-items: stretch;
      flex: 1 1 260px;
      min-width: 240px;
      max-width: 320px;
      border: 1px solid var(--border-soft);
      background: var(--surface);
    }
    .job-pick-wrap.is-live.is-active {
      border-color: var(--accent);
      background: var(--accent-dim);
    }
    .job-pick-wrap.is-live:has(.job-pick:hover),
    .job-pick-wrap.is-live:has(.job-pick:focus-visible),
    .job-pick-wrap.is-live:has(.pick-info:hover),
    .job-pick-wrap.is-live:has(.pick-info:focus-visible) {
      border-color: var(--accent);
    }
    .job-pick-wrap.is-upcoming {
      flex: 0 0 132px;
      min-width: 132px;
    }
    .job-pick-wrap.is-live .job-pick {
      flex: 1;
      min-width: 0;
      border: 0;
      background: transparent;
      padding-right: 4px;
    }
    .pick-info {
      position: static;
      align-self: stretch;
      display: flex;
      align-items: center;
      padding: 0 10px;
      border: 0;
      border-left: 1px solid var(--border-soft);
      background: transparent;
      color: var(--accent);
      font: inherit;
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 140ms, color 140ms, background 140ms;
    }
    .pick-info:hover,
    .pick-info:focus-visible {
      border-color: var(--accent);
      background: var(--accent-dim);
      color: var(--fg);
      outline: 2px solid transparent;
    }
    .job-pick-wrap.is-live.is-active .pick-info {
      border-left-color: rgba(126, 168, 208, 0.55);
    }
    .job-pick {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 6px;
      padding: 10px 12px;
      border: 1px solid var(--border-soft);
      background: var(--surface);
      color: inherit;
      font: inherit;
      text-align: left;
      cursor: pointer;
      width: 100%;
      min-height: 84px;
      transition: border-color 140ms, background 140ms;
    }
    .job-pick:hover,
    .job-pick:focus-visible {
      border-color: var(--accent);
      background: var(--surface-2);
      outline: 2px solid transparent;
    }
    .job-pick.is-active {
      border-color: var(--accent);
      background: var(--accent-dim);
    }
    .job-pick-wrap.is-live .job-pick.is-active {
      border-color: transparent;
      background: transparent;
    }
    .job-pick.is-locked {
      cursor: default;
      border-style: dashed;
      opacity: 0.82;
      min-height: 54px;
    }
    .job-pick.is-propose {
      flex: 0 0 118px;
      min-width: 118px;
      min-height: 84px;
      align-self: stretch;
    }
    .pick-eyebrow {
      display: flex;
      align-items: baseline;
      gap: 8px;
      min-width: 0;
    }
    .pick-juris {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      flex: 0 0 auto;
      border: 1px solid var(--border-soft);
      padding: 2px 6px;
      line-height: 1.3;
    }
    .pick-name {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 14px;
      line-height: 1.2;
      color: var(--fg);
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .job-pick-wrap.is-upcoming .pick-name {
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    /* Pick lede — one-line summary (clamped) so each chip carries its own
       'what is this job' without forcing the visitor to click 'brief'. */
    .pick-lede {
      font-size: 11.5px;
      line-height: 1.35;
      color: var(--muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      min-height: calc(11.5px * 1.35 * 2);
    }
    .pick-meta {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.06em;
      color: var(--dim);
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
      display: flex;
      gap: 6px;
      align-items: baseline;
      margin-top: auto;
    }
    .pick-meta .pm-sep { color: var(--faint); }
    .pick-soon {
      font-family: var(--mono);
      font-size: 8px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--dim);
      border: 1px dashed var(--faint);
      padding: 1px 5px;
      flex: 0 0 auto;
    }
    .pick-buzz {
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      gap: 4px;
      margin-top: auto;
    }
    .pick-thumb {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 30px;
      height: 24px;
      padding: 0 6px;
      border: 1px solid var(--border-soft);
      background: var(--bg);
      color: var(--muted);
      font-family: var(--mono);
      font-size: 8px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 140ms, color 140ms, background 140ms;
    }
    .pick-thumb:hover,
    .pick-thumb:focus-visible {
      border-color: var(--accent);
      color: var(--fg);
      outline: 2px solid transparent;
    }
    .pick-thumb.is-active {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-dim);
    }
    .pick-thumb.is-down.is-active {
      border-color: var(--warn);
      color: var(--warn);
      background: rgba(255, 184, 0, 0.08);
    }

    .job-stage {
      display: flex;
      flex-direction: column;
      gap: 0;
      min-width: 0;
      flex: 1;
      min-height: 0;
      overflow: auto;
    }
    .job-panel {
      display: grid;
      grid-template-rows: auto minmax(0, 1fr) auto;
      gap: 6px;
      flex: 1;
      min-height: 0;
      overflow: visible;
    }

    /* Bell-tower top-strip: round name + liturgical hour ticks +
       stones-in-window + score lock countdown. Cathedral's heartbeat above
       the wall. */
    .top-strip {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.06em;
      color: var(--dim);
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border-soft);
    }
    .top-strip .now {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      color: var(--muted);
    }
    .top-strip .now strong {
      color: var(--fg);
      font-family: var(--serif);
      font-weight: 300;
      font-style: italic;
      font-size: 13px;
      letter-spacing: 0;
      text-transform: none;
    }
    .top-strip .hours {
      display: inline-flex;
      gap: 2px;
      align-items: center;
    }
    .top-strip .h {
      display: inline-block;
      width: 22px;
      height: 6px;
      border: 1px solid var(--border-soft);
      background: transparent;
    }
    .top-strip .h.past {
      background: var(--accent-dim);
      border-color: var(--accent);
    }
    .top-strip .h.now {
      background: var(--accent);
      border-color: var(--accent);
      box-shadow: 0 0 8px rgba(126, 168, 208, 0.45);
      animation: cd-breathe 2.4s ease-in-out infinite;
    }
    @keyframes cd-breathe {
      0%, 100% { box-shadow: 0 0 6px rgba(126, 168, 208, 0.35); }
      50%      { box-shadow: 0 0 14px rgba(126, 168, 208, 0.7); }
    }
    .top-strip .bk {
      color: var(--dim);
      font-variant-numeric: tabular-nums;
    }
    .top-strip .toll {
      margin-left: auto;
      color: var(--accent);
      white-space: nowrap;
    }
    .top-strip .toll strong {
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .job-panel :global(.wall-frame-compact) {
      min-height: 0;
      height: auto;
      max-height: min(32vh, 320px);
      flex: 0 1 auto;
      display: flex;
      flex-direction: column;
    }
    .job-panel :global(.wall-frame-compact .wall) {
      flex: 0 1 auto;
      min-height: 0;
    }
    .job-panel :global(.wall-frame-compact .grid) {
      min-height: clamp(150px, 26vh, 280px);
      max-height: min(28vh, 300px);
    }

    .canvas-row {
      display: grid;
      grid-template-columns: 1.35fr 1fr;
      gap: 10px;
      align-items: start;
      margin-top: 0;
      padding-top: 6px;
      border-top: 1px solid var(--border-soft);
      flex: 0 0 auto;
      max-height: none;
      overflow: visible;
    }
    @media (max-width: 920px) {
      .canvas-row { grid-template-columns: 1fr; gap: 12px; max-height: none; }
    }

    .job-panel .proc-frame { margin: 0; min-height: 0; }
    .job-panel .proc-subhead {
      margin: 0 0 6px;
      font-family: var(--mono);
      font-size: 8.5px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--faint);
    }
    .job-panel .proc-head h2,
    .job-panel .rubric-head h2 {
      font-size: 14px;
    }
    .job-panel .proc-head,
    .job-panel .rubric-head {
      gap: 10px;
    }
    .job-panel .rubric-head .head-link {
      font-size: 9.5px;
    }
    .job-panel .proc-list {
      max-height: none;
      overflow: visible;
    }
    .job-panel .proc-row {
      grid-template-columns: auto 22px minmax(0, 1fr) auto auto;
      gap: 8px;
      padding: 5px 8px;
    }
    .job-panel .pr-vigil {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.08em;
      color: var(--dim);
      white-space: nowrap;
    }
    .job-panel .pr-vigil .vigil-bars {
      display: inline-flex;
      gap: 1.5px;
      align-items: flex-end;
    }
    .job-panel .pr-vigil .vb {
      width: 3px;
      height: 6px;
      background: var(--border);
      display: inline-block;
    }
    .job-panel .pr-vigil .vb:nth-child(2) { height: 8px; }
    .job-panel .pr-vigil .vb:nth-child(3) { height: 10px; }
    .job-panel .pr-vigil .vb:nth-child(4) { height: 12px; }
    .job-panel .pr-vigil .vb:nth-child(5) { height: 14px; }
    .job-panel .pr-vigil .vb.on { background: var(--accent); }
    .job-panel .pr-vigil .vigil-lbl strong {
      color: var(--fg);
      font-weight: 400;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0;
    }
    @media (max-width: 640px) {
      .job-panel .pr-vigil .vigil-lbl { display: none; }
    }
    .job-panel .pr-mk,
    .job-panel .pr-mk.empty {
      width: 22px;
      height: 22px;
    }
    .job-panel .pr-rk {
      font-size: 16px;
    }
    .job-panel .pr-nm {
      font-size: 11px;
    }
    .job-panel .pr-hk {
      font-size: 8.5px;
    }
    .job-panel .pr-sc {
      font-size: 14px;
    }
    .job-panel .rubric-list {
      gap: 2px;
      margin-top: 4px;
      max-height: none;
      overflow: visible;
    }
    .job-panel .rubric-list .r {
      grid-template-columns: 78px minmax(0, 1fr) 30px;
      gap: 6px;
      padding: 4px 6px;
    }
    .job-panel .rubric-list .r .l {
      font-size: 10.5px;
    }
    .job-panel .rubric-list .r .v {
      font-size: 9px;
    }
    .proc-head,
    .rubric-head {
      display: flex;
      align-items: baseline;
      gap: 14px;
      flex-wrap: wrap;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .proc-head .num,
    .rubric-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
    .proc-head h2,
    .rubric-head h2 {
      font-family: var(--serif);
      font-weight: 300;
      font-style: italic;
      font-size: 18px;
      letter-spacing: 0;
      text-transform: none;
      color: var(--fg);
      margin: 0;
    }
    .proc-head .rule,
    .rubric-head .rule {
      flex: 1;
      height: 1px;
      min-width: 24px;
      background: var(--border-soft);
      margin: 0 4px;
    }
    .proc-head .head-meta,
    .rubric-head .head-link {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: 0.18em;
      color: var(--dim);
    }
    .rubric-head .head-link {
      font-size: 10.5px;
      letter-spacing: 0.06em;
      text-transform: none;
      color: var(--accent);
      text-decoration: none;
      background: none;
      border: 0;
      padding: 0;
      font: inherit;
      cursor: pointer;
    }
    .rubric-head .head-link:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .proc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1px;
      background: var(--border-soft);
      border: 1px solid var(--border-soft);
    }
    .proc-row {
      display: grid;
      grid-template-columns: auto 28px minmax(0, 1fr) auto auto;
      align-items: center;
      gap: 10px;
      padding: 7px 10px;
      background: var(--bg);
      text-decoration: none;
      color: inherit;
      transition: background 140ms;
      min-width: 0;
      width: 100%;
      border: 0;
      font: inherit;
      text-align: left;
      cursor: pointer;
    }
    button.proc-row:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: -2px;
    }
    /* Vigil indicator — 5 small bars + label, sits between identity
       and score. Reads as a streak at-a-glance. Days derived from
       this card's feed in the last 30d. */
    .pr-vigil {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.06em;
      color: var(--dim);
      white-space: nowrap;
    }
    .pr-vigil .vigil-bars {
      display: inline-flex;
      gap: 2px;
      align-items: flex-end;
    }
    .pr-vigil .vb {
      width: 3px;
      background: var(--border);
      display: inline-block;
    }
    .pr-vigil .vb:nth-child(1) { height: 6px; }
    .pr-vigil .vb:nth-child(2) { height: 9px; }
    .pr-vigil .vb:nth-child(3) { height: 12px; }
    .pr-vigil .vb:nth-child(4) { height: 15px; }
    .pr-vigil .vb:nth-child(5) { height: 18px; }
    .pr-vigil .vb.on { background: var(--accent); }
    .pr-vigil .vigil-lbl strong {
      color: var(--fg);
      font-weight: 400;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0;
    }
    .proc-row:hover { background: var(--surface); }
    .proc-row.rank-1 { background: var(--accent-dim); }
    .proc-row.rank-1:hover { background: rgba(126, 168, 208, 0.18); }
    .proc-row.proc-open {
      opacity: 0.62;
      pointer-events: none;
    }
    .pr-mk.empty {
      width: 32px;
      height: 32px;
      border: 1px dashed var(--faint);
      background: transparent;
    }
    .pr-rk {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 22px;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .proc-row.rank-1 .pr-rk { color: var(--accent); }
    .pr-mk {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border: 1px solid var(--border-soft);
      background: var(--surface);
    }
    .pr-mk :global(svg) { width: 70%; height: 70%; }
    .pr-who {
      display: flex;
      flex-direction: column;
      gap: 1px;
      min-width: 0;
    }
    .pr-nm {
      color: var(--fg);
      font-size: 12.5px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .pr-hk {
      color: var(--dim);
      font-size: 9.5px;
      letter-spacing: 0.04em;
      font-variant-numeric: tabular-nums;
    }
    .pr-sc {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 18px;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .proc-empty {
      padding: 18px;
      background: var(--surface);
      border: 1px solid var(--border-soft);
      font-family: var(--serif);
      font-style: italic;
      font-weight: 300;
      font-size: 14px;
      color: var(--muted);
      margin: 0;
    }
    .proc-empty a {
      color: var(--accent);
      margin-left: 8px;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .rubric { margin: 0; }
    .rubric-list {
      display: grid;
      gap: 3px;
      margin-top: 8px;
    }
    .rubric-list .r {
      display: grid;
      grid-template-columns: 92px minmax(0, 1fr) 36px;
      align-items: center;
      gap: 8px;
      padding: 5px 8px;
      border: 1px solid var(--border-soft);
      background: var(--bg);
      text-decoration: none;
      color: inherit;
      transition: border-color 140ms, background 140ms;
    }
    .rubric-list .r:hover,
    .rubric-list .r:focus-visible {
      border-color: var(--accent);
      background: var(--surface);
      outline: 2px solid transparent;
    }
    .rubric-list .r .l { color: var(--fg); font-size: 12px; }
    .rubric-list .r .b {
      position: relative;
      height: 4px;
      background: var(--border-soft);
    }
    .rubric-list .r .b::after {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: var(--w, 0%);
      background: var(--accent);
      opacity: 0.75;
    }
    .rubric-list .r .v {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--dim);
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .rubric .moats {
      margin: 10px 0 0;
      color: var(--muted);
      font-size: 11.5px;
      line-height: 1.55;
      max-width: 52ch;
    }

    .below-fold {
      margin-top: 8px;
      border-top: 1px solid var(--border-soft);
    }
    .below-fold summary {
      cursor: pointer;
      padding: 10px 0;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--dim);
      list-style: none;
    }
    .below-fold summary::-webkit-details-marker { display: none; }
    .below-fold[open] summary {
      color: var(--accent);
      margin-bottom: 8px;
    }
    .below-fold .below {
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
    }

    .mine-block {
      margin-top: 28px;
      padding-top: 8px;
      border-top: 1px solid var(--border-soft);
    }
    .block-head {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .block-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
    .block-head h2 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 18px;
      letter-spacing: 0;
      text-transform: none;
      color: var(--fg);
      margin: 0;
    }
    .block-head .rule {
      flex: 1;
      height: 1px;
      background: var(--border-soft);
      margin-left: 6px;
    }
    .mine-line {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.65;
      max-width: 64ch;
    }
    .mine-line code {
      font-family: var(--mono);
      font-size: 12.5px;
      color: var(--fg);
      background: var(--surface);
      border: 1px solid var(--border-soft);
      padding: 1px 6px;
    }
    .mine-line a {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .upload-fold {
      margin-top: 12px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }
    .upload-fold summary {
      cursor: pointer;
      color: var(--accent);
    }
    .upload-fold a { color: var(--accent); }

    .partner-panel-head {
      display: flex;
      align-items: baseline;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 12px;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .partner-panel-head .num { color: var(--accent); }
    .partner-panel-head h2 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 22px;
      letter-spacing: 0;
      text-transform: none;
      color: var(--fg);
      margin: 0;
    }
    .partner-panel-head .rule {
      flex: 1;
      height: 1px;
      background: var(--border-soft);
    }
    .partner-panel-lede {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.65;
      max-width: 64ch;
    }
    .partner-panel-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .partner-panel-actions .btn {
      display: inline-block;
      padding: 9px 14px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--fg);
      font: inherit;
      font-size: 12px;
      text-decoration: none;
      transition: border-color 140ms, color 140ms, background 140ms;
    }
    .partner-panel-actions .btn:hover,
    .partner-panel-actions .btn:focus-visible {
      border-color: var(--accent);
      color: var(--accent);
      outline: 2px solid transparent;
    }
    .partner-panel-actions .btn.primary {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-dim);
    }

    /* ===== below: subscribe + bring-your-agent ===== */
    .below {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      margin-top: 28px;
      padding: 28px 0 0;
      border-top: 1px solid var(--border-soft);
    }
    @media (max-width: 760px) {
      .below { grid-template-columns: 1fr; gap: 24px; }
    }
    .below-eyebrow {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 12px;
    }
    .below-line {
      margin: 0 0 14px;
      color: var(--muted);
      font-size: 13.5px;
      line-height: 1.6;
      max-width: 56ch;
    }
    .below-fine {
      margin: 8px 0 0;
      font-size: 11.5px;
      color: var(--dim);
      line-height: 1.5;
