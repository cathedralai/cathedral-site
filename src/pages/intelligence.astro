---
import Base from '../layouts/Base.astro'
import { cards, metrics, workerById } from '../data/regulatoryIntelligence'

const countries = [...new Set(cards.map((card) => card.country))]
---

<Base title="intelligence · cathedral">
  <section class="head">
    <p class="label">Regulatory intelligence</p>
    <h1>Country cards maintained by persistent workers.</h1>
    <p>
      Each card is a maintained public asset. Workers update cards from official sources. Validators score source quality, freshness, clarity, maintenance, and downstream usage.
    </p>
  </section>

  <section class="stats">
    <div><strong>{metrics.cardsTotal}</strong><span>cards</span></div>
    <div><strong>{metrics.sourceCount}</strong><span>official sources</span></div>
    <div><strong>{metrics.workersActive}</strong><span>active worker</span></div>
    <div><strong>{metrics.openCards}</strong><span>open cards</span></div>
  </section>

  {countries.map((country) => {
    const countryCards = cards.filter((card) => card.country === country)
    return (
      <section class="country">
        <div class="country-head">
          <p class="label">{countryCards[0].jurisdiction}</p>
          <h2>{country}</h2>
          <a href={`/countries/${countryCards[0].jurisdiction.toLowerCase()}`}>country page</a>
        </div>
        <div class="grid">
          {countryCards.map((card) => {
            const worker = workerById(card.workerId)
            return (
              <a class={`card ${card.status === 'sample live' ? 'live' : ''}`} href={`/cards/${card.id}`}>
                <div class="top">
                  <span>{card.status}</span>
                  <span>score {card.score}</span>
                </div>
                <h3>{card.title}</h3>
                <p>{card.summary}</p>
                <div class="meta">
                  <span>{worker ? worker.name : 'open for miner'}</span>
                  <span>{card.cadence}</span>
                </div>
              </a>
            )
          })}
        </div>
      </section>
    )
  })}

  <style>
    .head {
      padding: 54px 0 34px;
      border-bottom: 1px solid var(--border-soft);
    }
    .label {
      margin: 0 0 12px;
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    h1, h2 {
      margin: 0;
      color: var(--fg);
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-weight: 300;
      line-height: 1.05;
    }
    h1 {
      max-width: 820px;
      font-size: clamp(38px, 7vw, 78px);
    }
    h2 {
      font-size: 36px;
    }
    .head p:not(.label) {
      max-width: 760px;
      margin: 20px 0 0;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.65;
    }
    .stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      margin: 28px 0 10px;
      border: 1px solid var(--border-soft);
      background: var(--border-soft);
    }
    .stats div {
      background: var(--surface);
      padding: 18px;
    }
    .stats strong {
      display: block;
      color: var(--fg);
      font-size: 28px;
      line-height: 1;
    }
    .stats span {
      display: block;
      margin-top: 8px;
      color: var(--dim);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .country {
      padding: 44px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .country-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 18px;
    }
    .country-head a {
      color: var(--muted);
      font-size: 12px;
      text-decoration: underline;
      text-decoration-color: var(--dim);
      text-underline-offset: 3px;
    }
    .country-head a:hover {
      color: var(--fg);
      text-decoration-color: var(--accent);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .card {
      display: block;
      padding: 18px;
      min-height: 190px;
      border: 1px solid var(--border);
      background: var(--surface);
      transition: border-color 140ms, transform 140ms;
    }
    .card.live {
      border-color: var(--accent);
      background: var(--accent-dim);
    }
    .card:hover,
    .card:focus-visible {
      border-color: var(--accent);
      transform: translateY(-1px);
      outline: 2px solid transparent;
    }
    .top,
    .meta {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      color: var(--dim);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .card h3 {
      margin: 18px 0 10px;
      color: var(--fg);
      font-size: 18px;
      line-height: 1.25;
    }
    .card p {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }
    .meta {
      margin-top: 22px;
    }
    @media (max-width: 760px) {
      .stats,
      .grid {
        grid-template-columns: 1fr;
      }
      .country-head {
        align-items: start;
        flex-direction: column;
      }
    }
  </style>
</Base>
