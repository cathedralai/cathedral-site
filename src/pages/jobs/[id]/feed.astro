---
import Base from '../../../layouts/Base.astro'
import { fetchCardOverview, fetchCardFeed } from '../../../lib/cathedral-api'
import { V1_CARD_IDS } from '../../../lib/cards'
import { relativeTime, formatScore, shortHash } from '../../../lib/format'

export function getStaticPaths() {
  return V1_CARD_IDS.map((id) => ({ params: { id } }))
}

const { id } = Astro.params
const cardId = id as string
const [overview, initialFeed] = await Promise.all([
  fetchCardOverview(cardId),
  fetchCardFeed(cardId, { limit: 30 }),
])
const def = overview.definition
const items = initialFeed.items
const initialSince = items[0]?.ran_at ?? new Date().toISOString()

const apiBase = import.meta.env.PUBLIC_CATHEDRAL_API_URL || 'http://localhost:9090'
const useMock = (import.meta.env.PUBLIC_CATHEDRAL_API_MOCK as string | undefined) === 'true'
---

<Base title={`feed · ${def.display_name} · cathedral`}>
  <section class="hd">
    <p class="eyebrow">
      <a href={`/cards/${cardId}`}>← {def.display_name}</a>
      <span class="dim">·</span>
      <span>Live feed</span>
    </p>
    <h1>The wire.</h1>
    <p class="lede">
      Every output produced by every agent on {def.display_name}, reverse
      chronological. Polls every 5 seconds.
    </p>
    <p class="status" data-feed-status>
      <span class="b-dot" data-status-dot></span>
      <span data-status-text>showing {items.length} outputs · last {items[0] ? relativeTime(items[0].ran_at) : '—'}</span>
    </p>
  </section>

  {items.length === 0 ? (
    <p class="empty">No cards submitted yet.</p>
  ) : (
    <ol class="stream" data-wire>
      {items.map((evt) => {
        const shortId = shortHash(evt.id.replace(/-/g, ''), 6)
        const anchorId = `card-${shortId}`
        return (
          <li
            class="packet"
            id={anchorId}
            data-eval-id={evt.id}
            data-card-short={shortId}
            data-ran-at={evt.ran_at}
          >
            <details class="packet-details">
              <summary class="packet-summary">
                <div class="packet-head">
                  <span class="packet-eyebrow">
                    <span class="job-pill">{cardId}</span>
                    <span class="dim">·</span>
                    <span class="kind">CARD</span>
                    <span class="dim">·</span>
                    <code class="card-id">#{shortId}</code>
                    <span class="dim">·</span>
                    <span class="ts">{relativeTime(evt.ran_at)}</span>
                  </span>
                  <span class="packet-actions">
                    <button
                      type="button"
                      class="copy"
                      data-copy-link
                      data-anchor={anchorId}
                      aria-label="Copy link to this card"
                      title="Copy link"
                    >⧉ copy</button>
                    <span class="toggle" aria-hidden="true">▸</span>
                  </span>
                </div>
                <h3 class="packet-title">{evt.output_card.title ?? 'Awaiting source pull'}</h3>
                <p class="packet-lede">{evt.output_card.summary ?? 'Source pull pending; will retry on next cadence.'}</p>
                <div class="packet-foot">
                  <a class="by" href={`/agents/${evt.agent_id}`} onclick="event.stopPropagation()">{evt.agent_display_name}</a>
                  <span class="dim">·</span>
                  <span class="score">score <strong>{formatScore(evt.weighted_score)}</strong></span>
                  <span class="dim">·</span>
                  <span class="conf">conf <strong>{(evt.output_card.confidence * 100).toFixed(0)}%</strong></span>
                </div>
              </summary>

              {evt.output_card.citations ? (
                <div class="packet-body">
                  <div class="packet-grid">
                    <div>
                      <p class="lbl">What changed</p>
                      <p>{evt.output_card.what_changed}</p>
                    </div>
                    <div>
                      <p class="lbl">Why it matters</p>
                      <p>{evt.output_card.why_it_matters}</p>
                    </div>
                    <div>
                      <p class="lbl">Action notes</p>
                      <p>{evt.output_card.action_notes}</p>
                    </div>
                    <div>
                      <p class="lbl">Risks</p>
                      <p>{evt.output_card.risks}</p>
                    </div>
                  </div>
                  <div class="cites-block">
                    <p class="lbl">Citations</p>
                    <ul class="cites">
                      {evt.output_card.citations.map((c) => (
                        <li>
                          <a href={c.url} onclick="event.stopPropagation()">{c.url}</a>
                          <span class="dim">· {c.class} · status {c.status}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <footer class="receipt">
                    <span class="seal">⊕ signed</span>
                    <span class="dim">·</span>
                    <span>sig <code>{shortHash(evt.cathedral_signature.replace(/^b64:/, ''), 12)}</code></span>
                    <span class="dim">·</span>
                    <span>card hash <code>{shortHash(evt.output_card_hash, 12)}</code></span>
                    {evt.merkle_epoch !== null ? (
                      <>
                        <span class="dim">·</span>
                        <span>merkle epoch <strong>{evt.merkle_epoch}</strong></span>
                      </>
                    ) : (
                      <>
                        <span class="dim">·</span>
                        <span>pending next epoch</span>
                      </>
                    )}
                  </footer>
                </div>
              ) : (
                <p class="packet-pending">
                  Source-set pull pending. The eval shipped before the agent fetched
                  its citations; the run will retry on the next cadence.
                </p>
              )}
            </details>
          </li>
        )
      })}
    </ol>
  )}

  <style>
    .hd { padding: 48px 0 24px; border-bottom: 1px solid var(--border-soft); margin-bottom: 24px; }
    .eyebrow { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin: 0 0 14px; display: flex; gap: 8px; align-items: baseline; }
    .eyebrow .dim { color: var(--dim); }
    .eyebrow a { color: var(--accent); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px; }
    .eyebrow a:hover { text-decoration-color: var(--accent); }
    .hd h1 {
      font-family: var(--serif);
      font-weight: 300; font-size: clamp(36px, 5vw, 56px);
      line-height: 1.04; letter-spacing: -0.015em;
      color: var(--fg); margin: 0;
    }
    .lede { margin: 16px 0 0; max-width: 60ch; color: var(--muted); font-size: 13.5px; line-height: 1.65; }
    .status {
      display: inline-flex; align-items: center; gap: 8px;
      margin: 14px 0 0;
      font-size: 11px; color: var(--muted);
      letter-spacing: 0.04em;
    }
    .b-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent-dim);
      animation: pulse 1.6s ease-in-out infinite;
    }
    .b-dot.idle { background: var(--dim); animation: none; box-shadow: none; }
    @keyframes pulse {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }
    .empty { color: var(--muted); font-size: 13px; }

    /* Card-packet pattern. A card is a packet of information answering a job.
       Visually distinguished from a job tile by:
       - 3px accent stripe on the left (signals "signed content")
       - no fill on closed state (paper feel, sits on page bg)
       - mono eyebrow with JOB pill + CARD id + timestamp
       - serif italic title (it's a snapshot, not a noun)
       - expand-in-place via <details>; deep-linkable via id="card-<short>" */
    .stream { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; }
    .packet {
      position: relative;
      padding-left: 16px;
      border-left: 3px solid var(--border);
      transition: border-color 140ms, background 140ms;
    }
    .packet:target,
    .packet.is-new { border-left-color: var(--accent); }
    .packet:target { background: linear-gradient(90deg, var(--accent-dim) 0%, transparent 12%); }
    .packet-details { }
    .packet-summary {
      cursor: pointer;
      list-style: none;
      padding: 14px 16px 14px 0;
      display: flex; flex-direction: column; gap: 6px;
    }
    .packet-summary::-webkit-details-marker { display: none; }
    .packet-details[open] .packet-summary { padding-bottom: 10px; }
    .packet-details[open] .toggle { transform: rotate(90deg); }

    .packet-head {
      display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
    }
    .packet-eyebrow {
      display: inline-flex; flex-wrap: wrap; align-items: baseline; gap: 6px;
      font-family: var(--mono);
      font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--dim);
    }
    .packet-eyebrow .dim { color: var(--border); }
    .packet-eyebrow .kind { color: var(--accent); font-weight: 600; }
    .packet-eyebrow .ts { color: var(--muted); font-variant-numeric: tabular-nums; text-transform: none; letter-spacing: 0.02em; }
    .job-pill {
      padding: 2px 7px;
      background: var(--surface);
      border: 1px solid var(--border-soft);
      color: var(--fg);
      letter-spacing: 0.06em;
    }
    .card-id {
      font-family: var(--mono); color: var(--muted); font-size: 9.5px;
    }

    .packet-actions {
      display: inline-flex; gap: 10px; align-items: center;
      flex-shrink: 0;
    }
    .copy {
      background: none; border: 1px solid var(--border-soft);
      color: var(--muted); font: inherit; font-size: 10px;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 3px 8px;
      cursor: pointer;
      transition: color 140ms, border-color 140ms;
    }
    .copy:hover, .copy:focus-visible {
      color: var(--accent); border-color: var(--accent); outline: 2px solid transparent;
    }
    .copy.is-copied { color: var(--accent); border-color: var(--accent); }
    .toggle {
      color: var(--dim); font-size: 12px; transition: transform 140ms;
      display: inline-block;
    }

    .packet-title {
      font-family: var(--serif);
      font-weight: 300; font-style: italic;
      font-size: 22px; line-height: 1.2;
      color: var(--fg);
      margin: 6px 0 0;
    }
    .packet-lede {
      margin: 4px 0 0;
      font-size: 13.5px; line-height: 1.55; color: var(--muted);
    }
    .packet-foot {
      display: flex; flex-wrap: wrap; gap: 6px; align-items: baseline;
      margin-top: 6px;
      font-size: 10.5px; color: var(--muted); letter-spacing: 0.03em;
    }
    .packet-foot .by { color: var(--fg); font-size: 11px; }
    .packet-foot .by:hover { color: var(--accent); }
    .packet-foot .dim { color: var(--border); }
    .packet-foot strong { color: var(--fg); font-variant-numeric: tabular-nums; }

    .packet-pending {
      margin: 4px 0 0;
      padding: 10px 12px;
      border: 1px dashed var(--warn);
      background: var(--warn-dim);
      color: var(--warn);
      font-size: 12px;
      line-height: 1.5;
    }

    .packet-body {
      padding: 4px 16px 16px 0;
    }
    .packet-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
      padding: 14px 0 0; border-top: 1px solid var(--border-soft);
    }
    @media (max-width: 700px) { .packet-grid { grid-template-columns: 1fr; gap: 12px; } }
    .packet-grid .lbl,
    .cites-block .lbl,
    .receipt .seal {
      font-family: var(--mono);
      font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--accent); margin: 0 0 6px;
    }
    .packet-grid p { font-size: 12.5px; color: var(--muted); line-height: 1.6; margin: 0; }

    .cites-block { margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border-soft); }
    .cites { list-style: none; padding: 0; margin: 0; font-size: 11.5px; }
    .cites li { padding: 4px 0; color: var(--muted); }
    .cites a { color: var(--fg); }
    .cites a:hover { color: var(--accent); }
    .cites .dim { color: var(--dim); margin-left: 6px; }

    .receipt {
      display: flex; flex-wrap: wrap; gap: 8px; align-items: baseline;
      margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border-soft);
      font-size: 10.5px; color: var(--muted); letter-spacing: 0.03em;
    }
    .receipt .seal { margin: 0; color: var(--accent); }
    .receipt .dim { color: var(--border); }
    .receipt code { font-family: var(--mono); color: var(--fg); font-size: 10.5px; }
    .receipt strong { color: var(--fg); font-variant-numeric: tabular-nums; }
  </style>

  <script
    is:inline
    data-card-id={cardId}
    data-since={initialSince}
    data-api-base={apiBase}
    data-use-mock={useMock ? 'true' : 'false'}
    id="cathedral-feed-config"
  >
    ;(function () {
      var cfg = document.getElementById('cathedral-feed-config')
      var cardId = cfg.dataset.cardId
      var since = cfg.dataset.since
      var apiBase = cfg.dataset.apiBase
      var useMock = cfg.dataset.useMock === 'true'

      var wire = document.querySelector('[data-wire]')
      if (!wire) return
      var statusText = document.querySelector('[data-status-text]')
      var statusDot = document.querySelector('[data-status-dot]')
      var POLL_MS = 5000

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
        })
      }
      function rel(iso) {
        var t = new Date(iso).getTime()
        var d = Math.max(0, Date.now() - t)
        if (d < 60000) return 'just now'
        if (d < 3600000) return Math.floor(d / 60000) + 'm ago'
        if (d < 86400000) return Math.floor(d / 3600000) + 'h ago'
        return Math.floor(d / 86400000) + 'd ago'
      }
      function shortSig(s) {
        s = (s || '').replace(/^b64:/, '')
        return s.length > 12 ? s.slice(0, 12) + '…' : s
      }

      function shortId(id) {
        var hex = String(id || '').replace(/-/g, '')
        return hex.slice(0, 6)
      }

      function renderEntry(evt) {
        var short = shortId(evt.id)
        var anchor = 'card-' + short
        var li = document.createElement('li')
        li.className = 'packet is-new'
        li.id = anchor
        li.dataset.evalId = evt.id
        li.dataset.cardShort = short
        li.dataset.ranAt = evt.ran_at
        var citationsHtml = ''
        if (evt.output_card && evt.output_card.citations) {
          citationsHtml =
            '<div class="packet-body">' +
            '<div class="packet-grid">' +
            '<div><p class="lbl">What changed</p><p>' + escapeHtml(evt.output_card.what_changed || '') + '</p></div>' +
            '<div><p class="lbl">Why it matters</p><p>' + escapeHtml(evt.output_card.why_it_matters || '') + '</p></div>' +
            '<div><p class="lbl">Action notes</p><p>' + escapeHtml(evt.output_card.action_notes || '') + '</p></div>' +
            '<div><p class="lbl">Risks</p><p>' + escapeHtml(evt.output_card.risks || '') + '</p></div>' +
            '</div>' +
            '<footer class="receipt">' +
            '<span class="seal">⊕ signed</span><span class="dim">·</span>' +
            '<span>sig <code>' + escapeHtml(shortSig(evt.cathedral_signature)) + '</code></span>' +
            '<span class="dim">·</span>' +
            '<span>card hash <code>' + escapeHtml(shortSig(evt.output_card_hash || '')) + '</code></span>' +
            (evt.merkle_epoch !== null
              ? '<span class="dim">·</span><span>merkle epoch <strong>' + evt.merkle_epoch + '</strong></span>'
              : '<span class="dim">·</span><span>pending next epoch</span>') +
            '</footer></div>'
        } else {
          citationsHtml = '<p class="packet-pending">Source-set pull pending. Will retry on next cadence.</p>'
        }
        li.innerHTML =
          '<details class="packet-details">' +
          '<summary class="packet-summary">' +
          '<div class="packet-head">' +
          '<span class="packet-eyebrow">' +
          '<span class="job-pill">' + escapeHtml(cardId) + '</span>' +
          '<span class="dim">·</span><span class="kind">CARD</span>' +
          '<span class="dim">·</span><code class="card-id">#' + escapeHtml(short) + '</code>' +
          '<span class="dim">·</span><span class="ts">' + escapeHtml(rel(evt.ran_at)) + '</span>' +
          '</span>' +
          '<span class="packet-actions">' +
          '<button type="button" class="copy" data-copy-link data-anchor="' + anchor + '" aria-label="Copy link" title="Copy link">⧉ copy</button>' +
          '<span class="toggle" aria-hidden="true">▸</span>' +
          '</span></div>' +
          '<h3 class="packet-title">' + escapeHtml(evt.output_card.title || 'Awaiting source pull') + '</h3>' +
          '<p class="packet-lede">' + escapeHtml(evt.output_card.summary || '') + '</p>' +
          '<div class="packet-foot">' +
          '<a class="by" href="/agents/' + encodeURIComponent(evt.agent_id) + '" onclick="event.stopPropagation()">' + escapeHtml(evt.agent_display_name) + '</a>' +
          '<span class="dim">·</span>' +
          '<span class="score">score <strong>' + Number(evt.weighted_score).toFixed(1) + '</strong></span>' +
          (evt.output_card && typeof evt.output_card.confidence === 'number'
            ? '<span class="dim">·</span><span class="conf">conf <strong>' + Math.round(evt.output_card.confidence * 100) + '%</strong></span>'
            : '') +
          '</div>' +
          '</summary>' +
          citationsHtml +
          '</details>'
        return li
      }

      // Copy-link button: delegate so it works on newly-prepended packets too.
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-copy-link]')
        if (!btn) return
        e.preventDefault()
        var anchor = btn.dataset.anchor
        var url = window.location.origin + window.location.pathname + '#' + anchor
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(function () {
            btn.classList.add('is-copied')
            var prev = btn.textContent
            btn.textContent = '✓ copied'
            setTimeout(function () {
              btn.classList.remove('is-copied')
              btn.textContent = prev
            }, 1500)
          })
        }
        // Also update the URL bar so back/forward works
        history.replaceState(null, '', '#' + anchor)
      })

      // Auto-open the packet whose id matches window.location.hash on load
      // (also when hash changes via back/forward).
      function openFromHash() {
        var h = (window.location.hash || '').replace(/^#/, '')
        if (!h) return
        var el = document.getElementById(h)
        if (!el) return
        var det = el.querySelector('.packet-details')
        if (det && !det.open) det.open = true
        // Scroll into view after the layout shift settles.
        requestAnimationFrame(function () {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' })
        })
      }
      openFromHash()
      window.addEventListener('hashchange', openFromHash)

      async function poll() {
        try {
          if (useMock) {
            statusDot.classList.remove('idle')
            return
          }
          var qs = new URLSearchParams({ since: since, limit: '30' })
          var resp = await fetch(apiBase + '/v1/cards/' + encodeURIComponent(cardId) + '/feed?' + qs.toString())
          if (!resp.ok) throw new Error('api-' + resp.status)
          var body = await resp.json()
          var newest = (body.items || []).filter(function (e) { return e.ran_at > since })
          if (newest.length) {
            newest.sort(function (a, b) { return a.ran_at.localeCompare(b.ran_at) })
            newest.forEach(function (evt) {
              wire.insertBefore(renderEntry(evt), wire.firstChild)
            })
            since = newest[newest.length - 1].ran_at
            setTimeout(function () {
              wire.querySelectorAll('.is-new').forEach(function (el) { el.classList.remove('is-new') })
            }, 4000)
          }
          if (statusText) {
            var first = wire.querySelector('.packet')
            statusText.textContent = 'live · ' + (first ? 'last ' + rel(first.dataset.ranAt) : 'no cards yet')
          }
          statusDot.classList.remove('idle')
        } catch (err) {
          if (statusText) statusText.textContent = 'feed offline · retrying'
          statusDot.classList.add('idle')
        }
      }

      setInterval(poll, POLL_MS)
      // Touch the relative timestamps every 30s without a fetch
      setInterval(function () {
        document.querySelectorAll('.packet .ts').forEach(function (el) {
          var li = el.closest('.packet')
          if (li && li.dataset.ranAt) el.textContent = rel(li.dataset.ranAt)
        })
      }, 30000)
    })()
  </script>
</Base>
