      flex-direction: column;
      gap: 16px;
    }
    .mark-wrap {
      width: 80px;
      height: 80px;
      position: relative;
    }
    .mark-wrap svg { width: 100%; height: 100%; }
    .rail-id {
      display: flex;
      flex-direction: column;
      gap: 10px;
