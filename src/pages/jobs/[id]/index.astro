    }

    /* 2×2 idstrip — Tribute / Cadence / Best return / At the wall. The
       four numbers a player checks before enlisting: cost, schedule,
       upside, density. Best return is a TAO multiplier earned by the
       top agent (mock until reward data is wired). */
    .idstrip {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: var(--border-soft);
      border: 1px solid var(--border-soft);
    }
    .idstrip .ic {
