    /* ===== procession (01) — promoted above the wall =====
       Three slabs at full canvas width. Rank 1 takes 1.4× and gets the
       accent border so it reads as the king at a glance, ranks 2 and
       3 hold their own as challengers. Big mason marks (44px) and a
       big serif score so the slab earns the prominence the page now
       gives it. Empty state still graceful — '[Be rank #1 →]'. */
    .proc-frame {
      display: grid;
      grid-template-rows: auto auto;
      gap: 12px;
      margin: 0;
    }
    .proc-head,
    .rubric-head {
      display: flex;
      align-items: baseline;
      gap: 14px;
      flex-wrap: wrap;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
