    .proc-head .num,
    .rubric-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
    .proc-head h2,
    .rubric-head h2 {
      font-family: var(--serif);
      font-weight: 300;
      font-style: italic;
      font-size: 22px;
      letter-spacing: 0;
