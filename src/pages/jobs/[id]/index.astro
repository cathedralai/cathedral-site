      color: var(--dim);
    }
    .block-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
    .block-head h2 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 18px;
      letter-spacing: 0;
      text-transform: none;
