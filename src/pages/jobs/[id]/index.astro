    /* Bottom row — procession (left) + rubric (right). Lays them
       side by side below the wall so each gets its own column without
       competing with the wall for vertical attention. Stacks when the
       canvas is too narrow. */
    .canvas-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: start;
      margin-top: 28px;
    }
    @media (max-width: 880px) {
      .canvas-row { grid-template-columns: 1fr; gap: 24px; }
    }

    /* Compact procession — three vertical rows, mark + name + hk + score.
       The rank-1 row is faintly accented but no longer dominates the
       page; the wall above is the centerpiece. */
    .proc-list {
      list-style: none;
      padding: 0;
      margin: 12px 0 0;
      display: flex;
      flex-direction: column;
      gap: 1px;
      background: var(--border-soft);
      border: 1px solid var(--border-soft);
