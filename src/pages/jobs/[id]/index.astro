    .upload-fold p {
      margin: 8px 0 0;
      padding-left: 18px;
      color: var(--muted);
    }
    .upload-fold p code { color: var(--fg); font-family: inherit; }
    .upload-fold p a { color: var(--accent); }
    .upload-fold p a:hover { text-decoration: underline; text-underline-offset: 3px; }
  </style>
  )}
