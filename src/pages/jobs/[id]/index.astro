    }

    .rail .title {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(28px, 3.2vw, 36px);
      line-height: 1.04;
      letter-spacing: -0.02em;
      color: var(--fg);
      margin: 0;
      /* The mockup's title sets the second word in italic. We mark up
         the title generically (no per-job typography logic) but the
         italic + period treatment lands the same gravitas. */
      font-style: italic;
    }
    .rail .title::after {
      content: '.';
      font-style: italic;
      color: var(--accent);
    }
    .rail .lede {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 300;
      font-size: 14px;
      line-height: 1.55;
      color: var(--muted);
      margin: 0;
