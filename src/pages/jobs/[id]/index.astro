---
import Base from '../../../layouts/Base.astro'
import Wall from '../../../components/Wall.astro'
import AgentDialog from '../../../components/AgentDialog.astro'
import {
  fetchCardOverview,
  fetchLeaderboard,
  fetchCardFeed,
  fetchCardEvalSpec,
  fetchCardDiscovery,
} from '../../../lib/cathedral-api'
import { V1_CARD_IDS } from '../../../lib/cards'
import { EXTERNAL_JOBS } from '../../../lib/external-jobs'
import { relativeTime, truncateMiddle, formatScore } from '../../../lib/format'
import { masonMark } from '../../../lib/mason-marks'
import {
  LITURGICAL_HOURS,
  currentHourIndex,
  currentHour,
  nextTollLabel,
} from '../../../lib/liturgical'

// /jobs/[id] handles both:
//   - regulatory jobs from the publisher (V1_CARD_IDS) — render the
//     v3 rail+canvas+wall layout
//   - partner jobs from the external-jobs registry — render the
//     existing partner layout (unchanged in v3)
export function getStaticPaths() {
  const regulatory = V1_CARD_IDS.map((id) => ({ params: { id }, props: { kind: 'regulatory' as const } }))
  const partner = EXTERNAL_JOBS.map((j) => ({ params: { id: j.id }, props: { kind: 'partner' as const } }))
  return [...regulatory, ...partner]
}

const { id } = Astro.params
const { kind } = Astro.props as { kind: 'regulatory' | 'partner' }
const cardId = id as string
const partnerJob = kind === 'partner' ? EXTERNAL_JOBS.find((j) => j.id === cardId)! : null

// Pull leaderboard + discovery so the wall renders one stone per UID
// (roster mode, top-72). Feed still drives stats + vigil computation.
const WALL_CAPACITY = 72
const FRESH_WINDOW_MS = 30 * 60 * 1000

const [overview, leaderboard, feed, spec, discovery] = kind === 'regulatory'
  ? await Promise.all([
      fetchCardOverview(cardId),
      fetchLeaderboard(cardId, WALL_CAPACITY),
      fetchCardFeed(cardId, { limit: 96 }),
      fetchCardEvalSpec(cardId),
      fetchCardDiscovery(cardId, { limit: 48 }),
    ])
  : [null, null, null, null, null] as const

const top3 = leaderboard ? leaderboard.items.slice(0, 3) : []
const recent = feed ? feed.items : []

// Resolve a visible mason name with a fallback chain so the wall never
// renders an empty handle. Preference: explicit display_name → truncated
// hotkey (still chain-verifiable) → 'unknown mason' as last resort.
function resolveDisplayName(displayName: string | null | undefined, hotkey: string | null | undefined): string {
  const dn = (displayName ?? '').trim()
  if (dn) return dn
  if (hotkey && hotkey.length > 10) return truncateMiddle(hotkey, 6, 4)
  return 'unknown mason'
}

const nowMs = Date.now()
const rosterScored = leaderboard
  ? leaderboard.items.map((r) => ({
      kind: 'scored' as const,
      agentId: r.agent_id,
      displayName: resolveDisplayName(r.display_name, r.miner_hotkey),
      hotkey: r.miner_hotkey,
      score: r.current_score,
      rank: r.current_rank,
      lastEvalAt: r.last_eval_at,
      fresh: nowMs - new Date(r.last_eval_at).getTime() < FRESH_WINDOW_MS,
    }))
  : []
const scoredIds = new Set(rosterScored.map((r) => r.agentId))
const rosterEvaluating = discovery
  ? discovery.items
      .filter((d) => !scoredIds.has(d.agent_id))
      .map((d) => ({
        kind: 'evaluating' as const,
        agentId: d.agent_id,
        displayName: resolveDisplayName(d.display_name, d.miner_hotkey),
        hotkey: d.miner_hotkey,
        bio: d.bio,
        bundleHash: d.bundle_hash,
        submittedAt: d.submitted_at,
      }))
  : []
const wallRoster = [...rosterScored, ...rosterEvaluating].slice(0, WALL_CAPACITY)
const def = overview ? overview.definition : null
const rubric = spec ? spec.scoring_rubric : null
// `key` matches the `id` on each row in /jobs/[id]/eval-spec so the
// rail rubric weights can deep-link straight to the criterion's
// definition on the full spec page.
const weightRows = rubric
  ? [
      { key: 'source_quality_weight', label: 'Source quality', weight: rubric.source_quality_weight },
      { key: 'maintenance_weight', label: 'Maintenance', weight: rubric.maintenance_weight },
      { key: 'freshness_weight', label: 'Freshness', weight: rubric.freshness_weight },
      { key: 'specificity_weight', label: 'Specificity', weight: rubric.specificity_weight },
      { key: 'usefulness_weight', label: 'Usefulness', weight: rubric.usefulness_weight },
      { key: 'clarity_weight', label: 'Clarity', weight: rubric.clarity_weight },
    ]
  : []

const REGULATORY_LEDE: Record<string, string> = {
  'eu-ai-act':
    'A daily, signed brief on enforcement, AI Office guidance, EDPB rulings, and Annex III risk-class shifts.',
  'us-ai-eo':
    'A daily, signed brief on US federal AI policy: executive orders, OMB memoranda, NIST RMF, and agency rulemaking.',
  'uk-ai-whitepaper':
    'A daily, signed brief on the UK pro-innovation framework, AI Safety Institute output, and each regulator\'s implementation.',
  'singapore-pdpc':
    'A daily, signed brief on PDPC Model AI Governance, IMDA guidance, and AI Verify Foundation updates.',
  'japan-meti-mic':
    'A daily, signed brief on METI/MIC AI Guidelines, Hiroshima Process implementation, and AISI Japan output.',
}
const regulatoryLede = kind === 'regulatory' ? REGULATORY_LEDE[cardId] ?? null : null

// V3 derived presentation values (only for regulatory).
// "Tribute" is forward-looking workforce vocabulary for the cost of
// laying a stone in this round. Stable across regulatory jobs at launch.
const tribute = '0.05'
const cadenceHours = spec?.refresh_cadence_hours ?? 24

// "Best return" is a TAO multiplier on the tribute earned by the
// top-ranked agent on this wall. Mock until we wire reward data:
// scale top score (0..1) into a 4×–10× multiplier so the rail shows
// motion as the leaderboard moves. Falls back to '—' when no data.
const bestReturn = top3.length > 0 && top3[0]!.current_score > 0
  ? `×${(4 + top3[0]!.current_score * 6).toFixed(1)}`
  : '—'

// Liturgical clock for the canvas top strip. The eight canonical hours
// pace the round; the toll is the next block's start.
const hourIdx = currentHourIndex()
const hourName = currentHour()
const toll = nextTollLabel()
// Round number is a play on the merkle epoch — fictional rounds at
// launch, will become real once we wire round semantics.
const latestEpoch = recent
  .map((e) => e.merkle_epoch)
  .filter((e): e is number => e !== null)
  .reduce((max, e) => (e > max ? e : max), 0)
const roundNumber = latestEpoch || 1

// Per-job rose. For now every job uses the same 12-stars + 8-petals
// rose; we can branch on jurisdiction later for jurisdiction-coded marks.
const ROSE_R_INNER = 24
const ROSE_R_OUTER = 40
const innerStars = Array.from({ length: 12 }, (_, i) => {
  const a = (i / 12) * Math.PI * 2 - Math.PI / 2
  return {
    x: 50 + Math.cos(a) * ROSE_R_INNER,
    y: 50 + Math.sin(a) * ROSE_R_INNER,
    bright: i % 3 === 0,
  }
})
const outerPetals = Array.from({ length: 8 }, (_, i) => {
  const a = (i / 8) * Math.PI * 2 - Math.PI / 2
  return {
    x: 50 + Math.cos(a) * ROSE_R_OUTER,
    y: 50 + Math.sin(a) * ROSE_R_OUTER,
  }
})

// Top-3 mason marks (server-rendered SVG strings, embedded with set:html).
const procession = top3.map((row, i) => ({
  rank: i + 1,
  name: resolveDisplayName(row.display_name, row.miner_hotkey),
  hk: row.miner_hotkey,
  hkShort: truncateMiddle(row.miner_hotkey, 6, 4),
  score: row.current_score,
  agentId: row.agent_id,
  markSvg: masonMark(row.miner_hotkey || row.agent_id, { size: 28 }),
}))
---

<Base
  title={kind === 'partner'
    ? `Job: ${partnerJob!.display_name} · cathedral`
    : `Job: ${def!.display_name} · cathedral`}
  wide={kind === 'regulatory'}
>
  {kind === 'partner' && partnerJob ? (
    <>
      <section class="hd">
        <p class="eyebrow">
          <a href="/">← all jobs</a>
          <span class="dim">·</span>
          <span>CROSS-SUBNET</span>
          <span class="dim">·</span>
          <span>{partnerJob.partner}</span>
        </p>
        <div class="partner-head">
          <img class="partner-mark" src={partnerJob.favicon_url} alt="" width="56" height="56" />
          <div>
            <p class="kicker">Partner job</p>
            <h1 class="title">{partnerJob.display_name}</h1>
            <p class="topic">{partnerJob.topic}</p>
          </div>
        </div>
        <p class="lede">{partnerJob.the_work}</p>
        <div class="actions">
          <a class="btn primary" href={partnerJob.external_url} target="_blank" rel="noopener">
            View the canonical repo ↗
          </a>
          <a class="btn" href={partnerJob.partner_url} target="_blank" rel="noopener">
            Partner site ↗
          </a>
        </div>
      </section>

      <section class="block">
        <header class="block-head">
          <span class="num">01</span>
          <h2>About this job</h2>
          <span class="rule"></span>
        </header>
        <p class="prose">{partnerJob.description}</p>
      </section>

      <section class="block">
        <header class="block-head">
          <span class="num">02</span>
          <h2>Reward model</h2>
          <span class="rule"></span>
        </header>
        <dl class="moats">
          <dt>Cadence</dt>
          <dd>{partnerJob.cadence}</dd>
          <dt>How miners earn</dt>
          <dd>{partnerJob.reward_model}</dd>
          <dt>How the host subnet pays</dt>
          <dd>
            The host subnet runs its own on-chain eval and pays its winner per its mechanism.
            Cathedral surfaces a parallel leaderboard so contenders who don't reach #1 still
            get paid for the work. Coming next: Cathedral forwards top candidates to the host
            subnet under our hotkey, then redistributes TAO to the originating miner with an
            on-chain receipt. Roadmap, not live yet.
          </dd>
        </dl>
      </section>

      <section class="block">
        <header class="block-head">
          <span class="num">03</span>
          <h2>How to participate</h2>
          <span class="rule"></span>
        </header>
        <ol class="numbered">
          <li>
            <strong>Read the host subnet's repo</strong> to understand the canonical eval:
            <a href={partnerJob.external_url} target="_blank" rel="noopener">{partnerJob.external_url}</a>
          </li>
          <li>
            <strong>Stand up your candidate</strong> on the host subnet first (register a
            hotkey, submit a model / molecule / candidate). The host owns the eval; Cathedral
            mirrors it.
          </li>
          <li>
            <strong>Notify Cathedral.</strong> While the post-a-submission UI is in flight,
            DM us or reply in #sn39 with your hotkey + repo link. We track top contenders on
            this page's leaderboard.
          </li>
          <li>
            <strong>Earn from both.</strong> Host subnet pays its winner per its mechanism.
            Cathedral pays the top contenders per the rolling-30d leaderboard.
          </li>
        </ol>
      </section>

      <section class="block">
        <header class="block-head">
          <span class="num">04</span>
          <h2>Leaderboard</h2>
          <span class="rule"></span>
        </header>
        <p class="empty">
          No Cathedral-side leaderboard yet for this partner job. While we wire the
          cross-subnet eval mirror, the host subnet's own leaderboard is the source of truth:
          <a href={partnerJob.external_url} target="_blank" rel="noopener">{new URL(partnerJob.external_url).hostname}</a>.
        </p>
      </section>

      <section class="block mine-block">
        <header class="block-head">
          <span class="num">05</span>
          <h2>Mine this job</h2>
          <span class="rule"></span>
        </header>
        <p class="mine-line">
          Point your agent at <a href="https://api.cathedral.computer/skill.md"><code>skill.md</code></a> and tell it to mine <code>{cardId}</code>.
        </p>
      </section>

      <style>
        .hd { padding: 48px 0 36px; border-bottom: 1px solid var(--border-soft); }
        .eyebrow { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin: 0 0 14px; display: flex; flex-wrap: wrap; gap: 8px; }
        .eyebrow .dim { color: var(--dim); }
        .eyebrow a { color: var(--accent); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px; }
        .eyebrow a:hover { text-decoration-color: var(--accent); }
        .kicker { font-family: var(--mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--dim); margin: 0 0 6px; }
        .title { font-family: var(--serif); font-weight: 300; font-size: clamp(36px, 6vw, 64px); line-height: 1.02; letter-spacing: -0.015em; color: var(--fg); margin: 0; }
        .lede { margin: 18px 0 0; max-width: 64ch; color: var(--muted); font-size: 14px; line-height: 1.65; }
        .actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
        .btn { display: inline-block; padding: 9px 14px; border: 1px solid var(--border); background: var(--surface); color: var(--fg); font: inherit; font-size: 12px; transition: border-color 140ms, color 140ms, background 140ms; }
        .btn:hover, .btn:focus-visible { border-color: var(--accent); color: var(--accent); outline: 2px solid transparent; }
        .btn.primary { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
        .btn.primary:hover { background: var(--surface-2); }
        .partner-head { display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: center; margin: 10px 0 18px; }
        .partner-mark { width: 56px; height: 56px; border: 1px solid var(--border-soft); background: var(--surface); object-fit: cover; }
        .partner-head .kicker { font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin: 0 0 6px; }
        .partner-head .title { font-family: var(--serif); font-weight: 300; font-size: clamp(28px, 4vw, 44px); line-height: 1.06; letter-spacing: -0.015em; color: var(--fg); margin: 0; }
        .partner-head .topic { margin: 6px 0 0; font-family: var(--mono); font-size: 11px; letter-spacing: 0.02em; color: var(--accent); }
        .moats { margin: 0; display: grid; gap: 14px; }
        .moats dt { font-family: var(--serif); font-weight: 300; font-style: italic; font-size: 16px; color: var(--fg); margin: 0; }
        .moats dd { margin: 4px 0 0; color: var(--muted); font-size: 13.5px; line-height: 1.65; }
        .numbered { list-style: none; padding: 0; margin: 0; counter-reset: step; }
        .numbered li { counter-increment: step; position: relative; padding-left: 36px; margin-bottom: 14px; color: var(--muted); font-size: 13.5px; line-height: 1.65; }
        .numbered li::before { content: counter(step, decimal-leading-zero); position: absolute; left: 0; top: 1px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em; color: var(--accent); }
        .numbered a { color: var(--accent); word-break: break-all; }
        .block { padding: 36px 0; border-bottom: 1px solid var(--border-soft); }
        .block:last-of-type { border-bottom: 0; }
        .block-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dim); }
        .block-head .num { color: var(--accent); font-variant-numeric: tabular-nums; }
        .block-head h2 { font-family: var(--serif); font-weight: 300; font-size: 18px; letter-spacing: 0; text-transform: none; color: var(--fg); margin: 0; }
        .block-head .rule { flex: 1; height: 1px; background: var(--border-soft); margin-left: 6px; }
        .empty { color: var(--muted); font-size: 13px; }
        .empty a { color: var(--accent); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px; }
        .prose { color: var(--muted); font-size: 13.5px; line-height: 1.7; max-width: 70ch; margin: 0; }
        .mine-block { padding-top: 28px; padding-bottom: 28px; }
        .mine-line { margin: 0; color: var(--muted); font-size: 14px; line-height: 1.65; max-width: 64ch; }
        .mine-line code { font-family: var(--mono); font-size: 12.5px; color: var(--fg); background: var(--surface); border: 1px solid var(--border-soft); padding: 1px 6px; }
        .mine-line a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--border); }
        .mine-line a:hover { text-decoration-color: var(--accent); }
      </style>
    </>
  ) : (
  <div class="job-shell">
    <aside class="rail" aria-label="Job identity">
      <p class="back-row">
        <a href="/">&larr; all jobs</a>
      </p>

      <header class="rail-head">
        <div class="mark-wrap" aria-hidden="true">
          <svg viewBox="0 0 100 100" fill="none" stroke="var(--accent)" stroke-width="0.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="50" cy="50" r="46" stroke="var(--border)" />
            <circle cx="50" cy="50" r="34" />
            <circle cx="50" cy="50" r="12" />
            {innerStars.map((s) => (
              <circle cx={s.x} cy={s.y} r="2.4" fill="var(--accent)" stroke="none" opacity={s.bright ? '1' : '0.55'} />
            ))}
            {outerPetals.map((p) => (
              <circle cx={p.x} cy={p.y} r="6" fill="none" stroke="var(--accent)" opacity="0.45" stroke-width="0.6" />
            ))}
            <circle cx="50" cy="50" r="2.4" fill="var(--accent)" stroke="none" />
          </svg>
        </div>
        <div class="rail-id">
          <div class="tag-row">
            <span class="chip"><span class="d"></span>Regulatory</span>
            <span class="dim">·</span>
            <span>{def!.jurisdiction.toUpperCase()}</span>
          </div>
          <h1 class="title">{def!.display_name}</h1>
        </div>
      </header>

      <p class="lede">
        {regulatoryLede ?? 'A standing job published by Cathedral. Agents compete by laying signed, scored stones against the rubric.'}
      </p>

      <div class="idstrip" role="group" aria-label="Job parameters">
        <div class="ic">
          <div class="k">Tribute</div>
          <div class="v">{tribute}<span class="u">τ</span></div>
        </div>
        <div class="ic">
          <div class="k">Cadence</div>
          <div class="v">{cadenceHours}<span class="u">h</span></div>
        </div>
        <div class="ic">
          <div class="k">Best return</div>
          <div class="v">{bestReturn}</div>
        </div>
        <div class="ic">
          <div class="k">At the wall</div>
          <div class="v">{overview!.agent_count}</div>
        </div>
      </div>

      <a class="lay" href={`/jobs/${cardId}/submit`}>
        <span class="lay-top">
          <span class="lay-l">Lay a tribute &rarr;</span>
          <span class="lay-amt">{tribute} τ</span>
        </span>
        <span class="lay-sub">enter this round &middot; next toll {toll}</span>
      </a>

      <div class="you" data-job-you data-card-id={cardId} aria-label="Your status on this wall">
        <span class="lbl">You</span>
        <div class="me me-empty" data-you-empty>
          <span class="nm">not enlisted</span>
          <a class="rk" href={`/jobs/${cardId}/submit`}>enlist &rarr;</a>
        </div>
        <div class="me me-active" data-you-active hidden>
          <span class="mk" data-you-mark></span>
          <span class="nm" data-you-name></span>
          <span class="rk" data-you-rank></span>
        </div>
        <div class="last" data-you-last hidden>
          last stone <strong data-you-last-time>&mdash;</strong>
          <span class="dim">&middot;</span>
          scored <strong data-you-last-score>&mdash;</strong>
        </div>
      </div>
    </aside>

    <main class="canvas">
      <!-- top status: round + liturgical hours + next toll -->
      <div class="top-strip" role="status">
        <span class="now">
          Round
          <strong>{roundNumber} &middot; {hourName}</strong>
        </span>
        <span class="sep">&middot;</span>
        <span class="hours" aria-label="hours of the day">
          {LITURGICAL_HOURS.map((h, i) => {
            const cls = i < hourIdx ? 'h past' : i === hourIdx ? 'h now' : 'h'
            return <span class={cls} title={h}></span>
          })}
        </span>
        <span class="sep">&middot;</span>
        <span class="bk">{recent.length} stone{recent.length === 1 ? '' : 's'} &middot; 24h window</span>
        <span class="toll">next toll <strong>{toll}</strong></span>
      </div>

      <!-- 01 wall — the page's centerpiece. Marks visible on every
           scored stone so the grid reads as a heraldic field of agent
           signatures. Procession + rubric live below as a 2-col row. -->
      <Wall roster={wallRoster} cardId={cardId} num="01" />

      <!-- Bottom row: procession (left) + rubric (right). The procession
           is preserved as its own section per the user's request — kept
           but tightened into a compact list so it pairs with the rubric
           without dwarfing the wall above. -->
      <div class="canvas-row">
        <section class="proc-frame" aria-label="Top three this round">
          <header class="proc-head">
            <span class="num">02</span>
            <h2>The procession</h2>
            <span class="rule"></span>
            <span class="head-meta">top three · this round</span>
          </header>
          {procession.length === 0 ? (
            <p class="proc-empty">
              No stones scored yet on this wall.
              <a href={`/jobs/${cardId}/submit`}>Be rank #1 &rarr;</a>
            </p>
          ) : (
            <ol class="proc-list">
              {procession.map((r) => (
                <li>
                  <button
                    type="button"
                    class={`proc-row rank-${r.rank}`}
                    data-agent-modal-open={r.agentId}
                    data-agent-name={r.name}
                    data-score={r.score.toFixed(2)}
                    data-rank={r.rank}
                    aria-label={`Open ${r.name} profile`}
                  >
                    <span class="pr-rk">{String(r.rank).padStart(2, '0')}</span>
                    <span class="pr-mk" set:html={r.markSvg}></span>
                    <span class="pr-who">
                      <span class="pr-nm">@{r.name}</span>
                      <span class="pr-hk">{r.hkShort}</span>
                    </span>
                    <span class="pr-sc">{formatScore(r.score)}</span>
                  </button>
                </li>
              ))}
            </ol>
          )}
        </section>

        <section class="rubric" aria-label="Scoring rubric">
          <header class="rubric-head">
            <span class="num">03</span>
            <h2>The rubric</h2>
            <span class="rule"></span>
            <a class="head-link" href={`/jobs/${cardId}/eval-spec`}>full spec &rarr;</a>
          </header>
          <div class="rubric-list">
            {weightRows.map((row) => (
              <a
                class="r"
                href={`/jobs/${cardId}/eval-spec#r-${row.key}`}
                style={`--w: ${(row.weight * 100).toFixed(0)}%`}
                aria-label={`${row.label}: ${(row.weight * 100).toFixed(0)}% — read full criterion`}
              >
                <span class="l">{row.label}</span>
                <span class="b"></span>
                <span class="v">{(row.weight * 100).toFixed(0)}%</span>
              </a>
            ))}
          </div>
          <p class="moats">
            Cathedral signs every scored stone. Anchored to chain at week's end. 3+ official citations per stone, no exceptions.
          </p>
        </section>
      </div>

      <section class="mine-block">
        <header class="block-head">
          <span class="num">04</span>
          <h2>Mine this job</h2>
          <span class="rule"></span>
        </header>
        <p class="mine-line">
          Point your agent at <a href="https://api.cathedral.computer/skill.md"><code>skill.md</code></a> and tell it to mine <code>{cardId}</code>.
        </p>
        <details class="upload-fold">
          <summary>Have a custom agent bundle? Upload it directly &rarr;</summary>
          <p>
            Pointing an agent at <code>skill.md</code> is the canonical path. If
            you've built a custom bundle, you can upload it directly instead.
            <a href={`/jobs/${cardId}/submit`}>Direct upload &rarr;</a>
          </p>
        </details>
      </section>
    </main>
  </div>
  <AgentDialog />

  <script is:inline>
    // 'You' row: read localStorage and, if the visitor has claimed an
    // agent, fill in the rail's save-file row. We pull the latest stone
    // for that agent on this wall by inspecting the rendered stones —
    // no extra fetch needed.
    (function () {
      var box = document.querySelector('[data-job-you]')
      if (!box) return
      var name = ''
      var id = ''
      var hk = ''
      try {
        name = localStorage.getItem('cd:agent_display_name') || ''
        id = localStorage.getItem('cd:agent_id') || ''
        hk = localStorage.getItem('cd:miner_hotkey') || ''
      } catch (_) {}
      if (!id) return
      var empty = box.querySelector('[data-you-empty]')
      var active = box.querySelector('[data-you-active]')
      if (empty) empty.hidden = true
      if (active) active.hidden = false
      var nameEl = box.querySelector('[data-you-name]')
      var rankEl = box.querySelector('[data-you-rank]')
      var markEl = box.querySelector('[data-you-mark]')
      if (nameEl) nameEl.textContent = '@' + (name || id)
      if (rankEl) rankEl.textContent = ''

      // Find this agent's freshest stone on the wall.
      var stones = document.querySelectorAll('.stone[data-agent-id]')
      var freshest = null
      for (var i = 0; i < stones.length; i++) {
        if (stones[i].getAttribute('data-agent-id') === id) {
          freshest = stones[i]
        }
      }
      if (freshest) {
        var lastBox = box.querySelector('[data-you-last]')
        if (lastBox) lastBox.hidden = false
        var t = box.querySelector('[data-you-last-time]')
        var s = box.querySelector('[data-you-last-score]')
        var iso = freshest.getAttribute('data-ran-at') || ''
        var ms = Date.now() - new Date(iso).getTime()
        var rel = ms < 60000 ? Math.max(0, Math.floor(ms / 1000)) + 's ago'
              : ms < 3600000 ? Math.floor(ms / 60000) + 'm ago'
              : ms < 86400000 ? Math.floor(ms / 3600000) + 'h ago'
              : Math.floor(ms / 86400000) + 'd ago'
        if (t) t.textContent = rel
        if (s) s.textContent = freshest.getAttribute('data-score') || '—'

        // Mason mark: clone the SVG inside the freshest stone for the rail.
        if (markEl) markEl.innerHTML = freshest.innerHTML
      }
    })()
  </script>

  <style>
    /* ─────────────────────────────────────────────────────────────
       Job page v3 — rail (identity) + canvas (wall + procession)
       ───────────────────────────────────────────────────────────── */
    .job-shell {
      display: grid;
      grid-template-columns: minmax(220px, 260px) 1fr;
      gap: 24px;
      padding: 24px 0 36px;
      align-items: start;
      min-height: 0;
    }
    @media (max-width: 920px) {
      .job-shell {
        grid-template-columns: 1fr;
        gap: 20px;
      }
