    /* ===== rail =====
       Tighter than v3.0: smaller rose, the rose + tag + title share a
       row instead of stacking, lede gets its own breathing line, and
       the gap between sections is bumped to 22px so the four anchors
       (identity / params / CTA / you) read as distinct chapters. */
    .rail {
      padding: 0 24px 24px 0;
      border-right: 1px solid var(--border-soft);
      display: flex;
      flex-direction: column;
      gap: 22px;
      position: sticky;
      top: 24px;
