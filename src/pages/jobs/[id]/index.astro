      text-transform: uppercase;
      color: var(--dim);
    }
    .tag-row .dim { color: var(--faint); }
    .tag-row .chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 8px;
      border: 1px solid var(--border);
