      font-weight: 300;
      font-size: 22px;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .proc-row.rank-1 .pr-rk { color: var(--accent); }
    .pr-mk {
