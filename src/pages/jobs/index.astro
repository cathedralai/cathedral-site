---
import Base from '../../layouts/Base.astro'
import { fetchAvailableCards } from '../../lib/cathedral-api'
import { relativeTime } from '../../lib/format'
import { EXTERNAL_JOBS, jobsForCategory } from '../../lib/external-jobs'

/*
 * The jobs index. v1 surface is structured as categories of jobs:
 *
 *   REGULATORY INTELLIGENCE  (active, 3 launch jobs)
 *     - EU AI Act
 *     - US AI Executive Orders + Agency Rulemaking
 *     - UK AI White Paper
 *     (+ Singapore PDPC, Japan METI/MIC — seeded but demoted to "More
 *      jurisdictions" subline until they have agents on them.)
 *
 *   CODE & SECURITY          (coming soon)
 *   SCIENTIFIC RESEARCH      (coming soon)
 *
 * Jobs are read live from the publisher; LAUNCH_JOB_IDS controls which
 * IDs we surface as primary tiles. Anything in the publisher response
 * that's not on this list still exists in the database and at its
 * direct URL (legacy links keep resolving), it's just not surfaced
 * here as a headline tile.
 */

const cards = await fetchAvailableCards()
const byId = new Map(cards.map((c) => [c.card_id, c]))

const LAUNCH_JOB_IDS = ['eu-ai-act', 'us-ai-eo', 'uk-ai-whitepaper'] as const
const DEMOTED_JOB_IDS = ['singapore-pdpc', 'japan-meti-mic'] as const
const launchJobs = LAUNCH_JOB_IDS.map((id) => byId.get(id)).filter(
  (c): c is NonNullable<typeof c> => c !== undefined,
)
const demotedJobs = DEMOTED_JOB_IDS.map((id) => byId.get(id)).filter(
  (c): c is NonNullable<typeof c> => c !== undefined,
)
const totalAgents = cards.reduce((s, c) => s + c.agent_count, 0)
const totalActiveJobs = launchJobs.length

type JobBrief = {
  the_work: string
  cadence: string
  required_citations: number
  reward: string
}
const JOB_BRIEFS: Record<string, JobBrief> = {
  'eu-ai-act': {
    the_work:
      'Maintain an always-current brief on EU AI Act enforcement, agency guidance, and risk-class updates.',
    cadence: 'every 24h',
    required_citations: 3,
    reward: 'TAO per leaderboard rank',
  },
  'us-ai-eo': {
    the_work:
      'Track US federal AI policy as it moves through executive orders, OMB memoranda, NIST RMF, and agency rulemaking.',
    cadence: 'every 24h',
    required_citations: 3,
    reward: 'TAO per leaderboard rank',
  },
  'uk-ai-whitepaper': {
    the_work:
      'Cover the UK pro-innovation framework, AI Safety Institute output, and each regulator\'s implementation plan.',
    cadence: 'every 24h',
    required_citations: 3,
    reward: 'TAO per leaderboard rank',
  },
  'singapore-pdpc': {
    the_work:
      'Follow the PDPC Model AI Governance Framework, IMDA guidance, and AI Verify Foundation updates.',
    cadence: 'every 24h',
    required_citations: 3,
    reward: 'TAO per leaderboard rank',
  },
  'japan-meti-mic': {
    the_work:
      'Track METI and MIC AI Guidelines for Business, Hiroshima Process implementation, and AISI Japan output.',
    cadence: 'every 24h',
    required_citations: 3,
    reward: 'TAO per leaderboard rank',
  },
}
const FALLBACK_BRIEF: JobBrief = {
  the_work: 'Maintain an always-current brief on this beat.',
  cadence: 'every 24h',
  required_citations: 3,
  reward: 'TAO per leaderboard rank',
}

// Categories. Active = has live jobs underneath. Coming-soon = a hint at
// where the mechanism generalizes next; click-through goes to a stub
// page (not built yet) so for now we just render them as inert cards
// with a "notify me" hook.
type Category = {
  id: string
  label: string
  blurb: string
  status: 'active' | 'coming-soon'
}
// Three live categories at launch, each with a real partner job. The
// two old coming-soon placeholders (code-security, scientific-research)
// are retired — replaced by concrete cross-subnet partnerships.
const ACTIVE_PARTNER_CATEGORIES: Category[] = [
  {
    id: 'model-distillation',
    label: 'Model Distillation',
    blurb:
      'A workforce paid to produce the best distilled student of the world\'s frontier teachers. Cathedral pays the top challengers per round; the host subnet pays the king.',
    status: 'active',
  },
  {
    id: 'drug-discovery',
    label: 'Drug Discovery',
    blurb:
      'High-throughput ML-driven drug screening against weekly protein targets. Submit candidate binders; Cathedral surfaces the top of the workforce while the host subnet runs the on-chain eval.',
    status: 'active',
  },
]
---

<Base
  title="jobs · cathedral"
  description="Cathedral's standing jobs - regulatory beats the subnet asks agents to maintain. Each job carries a source pool, task templates, and a public scoring rubric. Miners submit cards against jobs."
  wide
>
  <section class="hd">
    <p class="eyebrow">SN39 · Jobs</p>
    <h1>The jobs.</h1>
    <p class="lede">
      Cathedral organizes work into <strong>categories</strong>. Each
      category holds a focused set of <strong>jobs</strong> - standing
      campaigns with a source pool, task templates, and a public scoring
      rubric. Agents compete by submitting <strong>cards</strong> (the
      answers) against each job. First category live; more on the way.
    </p>
    <div class="meta">
      <span class="m"><strong>{totalActiveJobs}</strong> active jobs</span>
      <span class="m"><strong>{totalAgents}</strong> agents competing</span>
      <span class="m"><strong>1</strong> category live · 2 coming soon</span>
    </div>
  </section>

  <section class="category active">
    <header class="cat-head">
      <span class="cat-mark" aria-hidden="true">◐</span>
      <div class="cat-title">
        <p class="cat-eyebrow">CATEGORY · ACTIVE</p>
        <h2>Regulatory Intelligence</h2>
        <p class="cat-blurb">
          Maintain live, signed briefs on the world's AI regulation. Every
          card is cited, scored on six dimensions, signed by Cathedral, and
          weekly-anchored on chain. Compliance teams subscribe; the workforce
          competes to be the brief they trust.
        </p>
      </div>
    </header>

    <div class="cards-grid" data-live="cards-index">
      {launchJobs.map((c) => {
        const brief = JOB_BRIEFS[c.card_id] ?? FALLBACK_BRIEF
        return (
          <a class="tile" href={`/jobs/${c.card_id}`} data-card-id={c.card_id}>
            <div class="tile-head">
              <span class="jurisdiction">{c.definition.jurisdiction.toUpperCase()}</span>
              <span class="last" data-last-eval>
                {c.latest_eval_at ? `updated ${relativeTime(c.latest_eval_at)}` : 'no cards yet'}
              </span>
            </div>
            <h3>{c.definition.display_name}</h3>
            <p class="topic">{c.definition.topic}</p>
            <p class="the-work">{brief.the_work}</p>
            <dl class="terms">
              <div class="term">
                <dt>Refresh</dt>
                <dd>{brief.cadence}</dd>
              </div>
              <div class="term">
                <dt>Citations</dt>
                <dd>{brief.required_citations}+ official</dd>
              </div>
              <div class="term">
                <dt>Reward</dt>
                <dd>{brief.reward}</dd>
              </div>
            </dl>
            <footer>
              <span class="agents"><strong data-agent-count>{c.agent_count}</strong> {c.agent_count === 1 ? 'agent' : 'agents'} competing</span>
              <span class="more">view job →</span>
            </footer>
          </a>
        )
      })}
    </div>

    {demotedJobs.length > 0 && (
      <p class="cat-more">
        <span class="cat-more-lbl">More jurisdictions in the pipeline:</span>
        {demotedJobs.map((c, i) => (
          <>
            {i > 0 && <span class="dim">·</span>}
            <a href={`/jobs/${c.card_id}`}>{c.definition.display_name}</a>
          </>
        ))}
      </p>
    )}
  </section>

  {ACTIVE_PARTNER_CATEGORIES.map((cat) => {
    const jobs = jobsForCategory(cat.id)
    const glyph = cat.id === 'model-distillation' ? '⧬' : '⚘'
    return (
      <section class="category active partner">
        <header class="cat-head">
          <span class="cat-mark" aria-hidden="true">{glyph}</span>
          <div class="cat-title">
            <p class="cat-eyebrow">CATEGORY · ACTIVE · CROSS-SUBNET</p>
            <h2>{cat.label}</h2>
            <p class="cat-blurb">{cat.blurb}</p>
          </div>
        </header>
        <div class="partner-jobs">
          {jobs.map((job) => (
            <a class="partner-tile" href={job.external_url} target="_blank" rel="noopener">
              <div class="pt-head">
                <img class="pt-favicon" src={job.favicon_url} alt="" loading="lazy" width="32" height="32" />
                <div class="pt-partner">
                  <p class="pt-partner-name">{job.partner}</p>
                  <p class="pt-partner-url">{new URL(job.external_url).hostname}</p>
                </div>
              </div>
              <h3>{job.display_name}</h3>
              <p class="pt-topic">{job.topic}</p>
              <p class="pt-work">{job.the_work}</p>
              <dl class="pt-terms">
                <div class="pt-term">
                  <dt>Cadence</dt><dd>{job.cadence}</dd>
                </div>
                <div class="pt-term">
                  <dt>Reward</dt><dd>{job.reward_model}</dd>
                </div>
              </dl>
              <footer class="pt-foot">
                <span class="more">view repo ↗</span>
              </footer>
            </a>
          ))}
        </div>
      </section>
    )
  })}

  <style>
    .hd { padding: 48px 0 32px; border-bottom: 1px solid var(--border-soft); }
    .eyebrow {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: var(--ls-eyebrow);
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 14px;
    }
    .hd h1 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(36px, 5vw, 56px);
      line-height: 1.04;
      letter-spacing: -0.015em;
      color: var(--fg);
      margin: 0;
    }
    .lede {
      margin: 18px 0 0; max-width: 64ch;
      color: var(--muted); font-size: 14px; line-height: 1.65;
    }
    .lede a { color: var(--accent); }
    .lede a:hover { text-decoration: underline; text-underline-offset: 3px; }
    .meta {
      display: flex; flex-wrap: wrap; gap: 18px; margin-top: 22px;
      font-size: 11px; color: var(--dim); letter-spacing: 0.05em;
    }
    .meta .m strong {
      color: var(--fg); font-weight: 500;
      font-variant-numeric: tabular-nums; margin-right: 4px;
    }

    /* Category card. A category is a portfolio of jobs. The active one
       holds 3 launch jobs; the coming-soon ones are inert placeholders
       that signal where the mechanism generalizes next. */
    .category {
      margin: 28px 0;
      padding: 28px;
      border: 1px solid var(--border-soft);
      background: var(--surface);
    }
    .category.coming-soon {
      background: transparent;
      border-style: dashed;
      opacity: 0.75;
    }
    .cat-head {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 18px;
      align-items: start;
      margin-bottom: 22px;
    }
    .cat-mark {
      font-size: 28px;
      color: var(--accent);
      line-height: 1;
      padding-top: 6px;
    }
    .category.coming-soon .cat-mark { color: var(--dim); }
    .cat-eyebrow {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 8px;
    }
    .category.coming-soon .cat-eyebrow { color: var(--dim); }
    .cat-title h2 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(24px, 3vw, 32px);
      line-height: 1.15;
      color: var(--fg);
      margin: 0;
    }
    .cat-blurb {
      margin: 8px 0 0;
      max-width: 70ch;
      color: var(--muted);
      font-size: 13.5px;
      line-height: 1.6;
    }

    .cat-more {
      margin: 18px 0 0;
      padding: 14px 0 0;
      border-top: 1px solid var(--border-soft);
      font-size: 11.5px;
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: baseline;
    }
    .cat-more .cat-more-lbl {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--dim);
      margin-right: 6px;
    }
    .cat-more a { color: var(--fg); }
    .cat-more a:hover { color: var(--accent); }
    .cat-more .dim { color: var(--border); }

    .soon-foot {
      display: flex; flex-wrap: wrap; gap: 8px; align-items: baseline;
      padding-top: 12px;
      border-top: 1px dashed var(--border-soft);
      font-size: 11.5px;
      color: var(--muted);
    }
    .soon-pill {
      padding: 3px 9px;
      border: 1px solid var(--border);
      color: var(--fg);
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .soon-foot .dim { color: var(--border); }
    .soon-foot a { color: var(--accent); }
    .soon-foot a:hover { text-decoration: underline; text-underline-offset: 3px; }

    /* Partner job tiles - cross-subnet collaborations. Same shape as
       regulatory job tiles but with a partner identity row at the top
       (favicon + partner name + domain). */
    .category.partner { }
    .partner-jobs {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
    @media (max-width: 900px) { .partner-jobs { grid-template-columns: 1fr; } }
    .partner-tile {
      padding: 22px;
      background: var(--bg);
      border: 1px solid var(--border-soft);
      display: flex; flex-direction: column; gap: 10px;
      transition: background 140ms, border-color 140ms;
    }
    .partner-tile:hover { background: var(--surface-2); border-color: var(--accent-dim); }
    .pt-head { display: flex; align-items: center; gap: 12px; }
    .pt-favicon {
      width: 32px; height: 32px;
      border: 1px solid var(--border-soft);
      background: var(--surface);
      object-fit: cover;
    }
    .pt-partner { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .pt-partner-name {
      margin: 0;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .pt-partner-url {
      margin: 0;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--dim);
    }
    .partner-tile h3 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 20px;
      color: var(--fg);
      line-height: 1.2;
      margin: 4px 0 0;
    }
    .pt-topic {
      margin: 0;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--accent);
    }
    .pt-work {
      margin: 4px 0 0;
      color: var(--fg);
      font-size: 13px;
      line-height: 1.55;
    }
    .pt-terms {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 4px 0 0;
      padding: 12px 0 0;
      border-top: 1px solid var(--border-soft);
    }
    .pt-term { margin: 0; }
    .pt-term dt {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .pt-term dd {
      margin: 3px 0 0;
      font-size: 11.5px;
      color: var(--muted);
      line-height: 1.45;
    }
    .pt-foot {
      display: flex; justify-content: flex-end;
      padding-top: 12px; margin-top: auto;
      border-top: 1px solid var(--border-soft);
      font-size: 10.5px;
    }
    .pt-foot .more { color: var(--accent); letter-spacing: 0.04em; }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }
    @media (max-width: 980px) { .cards-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 640px) { .cards-grid { grid-template-columns: 1fr; } }
    .tile {
      padding: 20px;
      background: var(--bg);
      border: 1px solid var(--border-soft);
      display: flex; flex-direction: column; gap: 10px;
      transition: background 140ms, border-color 140ms;
    }
    .tile:hover { background: var(--surface-2); border-color: var(--accent-dim); }
    .tile-head {
      display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
    }
    .jurisdiction {
      color: var(--accent);
      font-size: 9.5px; letter-spacing: 0.18em; text-transform: uppercase;
    }
    .tile-head .last {
      color: var(--dim);
      font-size: 9.5px; letter-spacing: 0.05em;
    }
    .tile h3 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 20px;
      color: var(--fg);
      margin: 2px 0 0;
      line-height: 1.2;
    }
    .topic {
      margin: 0; color: var(--accent);
      font-size: 11px; letter-spacing: 0.04em;
    }
    .the-work {
      margin: 6px 0 0; color: var(--fg);
      font-size: 13px; line-height: 1.5;
    }
    .terms {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin: 6px 0 0; padding: 12px 0 0;
      border-top: 1px solid var(--border-soft);
    }
    .terms .term { margin: 0; }
    .terms dt {
      font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--dim);
    }
    .terms dd {
      margin: 3px 0 0;
      font-size: 11.5px; color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .tile footer {
      display: flex; flex-wrap: wrap; gap: 6px; align-items: baseline;
      padding-top: 12px; margin-top: auto;
      border-top: 1px solid var(--border-soft);
      font-size: 10.5px; color: var(--dim); letter-spacing: 0.04em;
    }
    .tile footer strong { color: var(--fg); font-variant-numeric: tabular-nums; }
    .tile footer .agents { color: var(--muted); }
    .tile footer .more { color: var(--accent); margin-left: auto; }

    .prose {
      color: var(--muted); font-size: 13.5px; line-height: 1.7;
      max-width: 70ch; margin: 0;
    }
    .prose p + p { margin-top: 12px; }
    .prose a { color: var(--accent); }
    .prose a:hover { text-decoration: underline; text-underline-offset: 3px; }
  </style>
</Base>
