---
import Base from '../layouts/Base.astro'
---

<Base title="ledger · cathedral">
  <section class="sec">
    <div class="wrap">
      <div class="eyebrow"><span class="num">—</span><span>Ledger</span></div>
      <div>
        <p class="lede">This public ledger view is paused for now.</p>
        <p class="body">
          We are not shipping the live numbers here until the readout matches what we want you to trust.
          Use <a href="/mine">mine</a> for your own machine, or head <a href="/">home</a>.
        </p>
      </div>
    </div>
  </section>

  <style>
    .sec { padding: 56px 0; }
    .sec .wrap {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 48px;
      max-width: min(72ch, 100%);
    }
    @media (max-width: 900px) {
      .sec { padding: 44px 0; }
      .sec .wrap { grid-template-columns: 1fr; gap: 20px; }
    }
    .eyebrow {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--dim);
      display: flex;
      align-items: baseline;
      gap: 10px;
    }
    .eyebrow .num {
      font-variant-numeric: tabular-nums;
      color: var(--accent);
    }
    .lede {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 300;
      line-height: 1.45;
      color: var(--fg);
      max-width: 34ch;
      margin: 0 0 16px 0;
    }
    .body {
      font-size: 14px;
      line-height: 1.65;
      color: var(--muted);
      max-width: min(52ch, 100%);
      margin: 0;
    }
    .body a {
      color: var(--fg);
      text-decoration: underline;
      text-decoration-color: var(--dim);
      text-underline-offset: 2px;
    }
    .body a:hover {
      text-decoration-color: var(--accent);
    }
  </style>
</Base>
