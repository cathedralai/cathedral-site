---
// Per-mason detail — Digg grammar study.
// Label-on-border boxes, big serif name, AI-classification-style block,
// vibe/topics analog swapped for "evidence" donut charts.
import Base from '../layouts/Base.astro'
---

<Base title="mason · cathedral · v2">
  <style is:global>
    .v2-page {
      --v2-paper: var(--bg);
      --v2-ink: var(--fg);
      --v2-ink-soft: var(--muted);
      --v2-ink-dim: var(--dim);
      --v2-border: var(--border);
      --v2-border-soft: var(--border-soft);
      --v2-label: var(--accent);
      --v2-accent: var(--accent);
      --v2-accent-fg: var(--bg);
      --v2-tag-role-fg: var(--warn);
      --v2-tag-role-bg: var(--warn-dim);
      --v2-tag-rank-fg: var(--ok);
      --v2-tag-rank-bg: var(--ok-dim);
      /* donut segment palette — same across themes */
      --v2-chart-1: var(--accent);
      --v2-chart-2: var(--ok);
      --v2-chart-3: var(--warn);
      --v2-chart-4: var(--err);
      --v2-chart-5: var(--muted);
      --v2-chart-6: var(--dim);
      background: var(--v2-paper);
      color: var(--v2-ink);
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 14px;
      line-height: 1.6;
      padding: 40px 40px 80px;
      min-height: 100vh;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      width: 100vw;
    }

    .v2-h1 {
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-weight: 700;
      font-size: clamp(36px, 5vw, 64px);
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin: 0;
      color: var(--v2-ink);
    }
    .v2-handle {
      color: var(--v2-ink-soft);
      font-size: 15px;
      margin-top: 8px;
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .v2-handle a.v2-ext {
      color: var(--v2-ink-soft);
      border-bottom: 1px dotted var(--v2-ink-dim);
    }
    .v2-handle a.v2-ext:hover { color: var(--v2-accent); border-bottom-color: var(--v2-accent); }
    .v2-handle .v2-dot { color: var(--v2-ink-dim); padding: 0 4px; }
    .v2-handle .v2-num { font-weight: 700; color: var(--v2-ink); font-variant-numeric: tabular-nums; }
    .v2-handle .v2-unit {
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--v2-ink-soft);
      margin-left: 2px; margin-right: 6px;
    }

    .v2-section {
      position: relative;
      border: 1px solid var(--v2-border);
      border-radius: 12px;
      padding: 32px 28px 28px;
      margin: 22px 0;
      background: var(--v2-paper);
    }
    .v2-section .v2-label {
      position: absolute;
      top: -7px;
      left: 18px;
      padding: 0 10px;
      background: var(--v2-paper);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--v2-label);
      font-weight: 500;
    }

    /* Profile header — avatar tile + name + rank */
    .v2-profile {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 28px;
      align-items: flex-start;
      padding-top: 6px;
    }
    @media (max-width: 700px) { .v2-profile { grid-template-columns: 1fr; } }
    .v2-rank-tile {
      background: var(--v2-border-soft);
      border-radius: 12px;
      padding: 14px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .v2-rank-avatar {
      width: 108px; height: 108px;
      border-radius: 10px;
      background: var(--v2-paper);
      border: 1px solid var(--v2-border);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-weight: 700;
      font-size: 32px;
      color: var(--v2-ink-soft);
      font-variant-numeric: tabular-nums;
    }
    .v2-rank-seat {
      background: var(--v2-accent);
      color: var(--v2-accent-fg);
      padding: 6px 14px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 15px;
      font-variant-numeric: tabular-nums;
      text-align: center;
      min-width: 68px;
    }
    .v2-rank-caption {
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--v2-ink-dim);
      font-weight: 500;
    }

    .v2-profile-body .v2-tags {
      margin-top: 14px; display: flex; gap: 6px; flex-wrap: wrap;
    }
    .v2-tag {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 600;
    }
    .v2-tag-role { background: var(--v2-tag-role-bg); color: var(--v2-tag-role-fg); }
    .v2-tag-role .v2-tag-num {
      font-weight: 700; letter-spacing: 0;
      background: rgba(0,0,0,0.06); padding: 1px 5px; border-radius: 4px;
    }
    .v2-tag-sub { background: var(--v2-tag-rank-bg); color: var(--v2-tag-rank-fg); }
    .v2-profile-body .v2-quote {
      margin-top: 16px;
      color: var(--v2-ink-soft);
      font-size: 15px;
      line-height: 1.5;
      max-width: 60ch;
    }
    .v2-profile-body .v2-quote::before {
      content: "\201C";
      color: var(--v2-ink-dim);
      margin-right: 4px;
      font-size: 22px;
      font-family: 'Newsreader', ui-serif, Georgia, serif;
    }

    .v2-classification p {
      margin: 0;
      color: var(--v2-ink);
      font-size: 15px;
      line-height: 1.65;
      max-width: 72ch;
    }

    /* Evidence grid — donut + legend twin-panels, matching Digg's vibe/topics */
    .v2-evidence-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      padding-top: 8px;
    }
    @media (max-width: 700px) { .v2-evidence-grid { grid-template-columns: 1fr; } }
    .v2-pane .v2-pane-head {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--v2-label);
      font-weight: 500;
      margin-bottom: 16px;
    }
    .v2-donut-wrap { display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .v2-donut {
      width: 160px; height: 160px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--v2-ink);
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-weight: 700;
      font-size: 20px;
      letter-spacing: -0.01em;
      position: relative;
    }
    .v2-donut::after {
      content: '';
      position: absolute; inset: 28px;
      background: var(--v2-paper);
      border-radius: 50%;
    }
    .v2-donut .v2-donut-label {
      position: relative; z-index: 1; text-align: center; padding: 0 12px;
    }
    .v2-legend { font-size: 13px; margin-top: 6px; width: 100%; }
    .v2-legend-row {
      display: flex; align-items: center; gap: 10px;
      padding: 4px 0;
      color: var(--v2-ink-soft);
    }
    .v2-legend-dot {
      width: 10px; height: 10px; border-radius: 50%;
      flex-shrink: 0;
    }
    .v2-legend-label { flex: 1; color: var(--v2-ink); }
    .v2-legend-val { font-variant-numeric: tabular-nums; font-weight: 700; }

    /* Embed snippet */
    .v2-embed {
      background: var(--v2-border-soft);
      border-radius: 8px;
      padding: 14px 16px;
      font-size: 12px;
      color: var(--v2-ink);
      overflow-x: auto;
    }
    .v2-embed-note {
      margin-top: 8px;
      font-size: 11px;
      color: var(--v2-ink-dim);
    }

    /* Copy button */
    .v2-row-action {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--v2-ink-soft);
      border: 1px solid var(--v2-border);
      background: var(--v2-paper);
      border-radius: 6px;
      padding: 5px 10px;
      margin-left: 8px;
      cursor: pointer;
    }
    .v2-row-action:hover { color: var(--v2-accent); border-color: var(--v2-accent); }

    .v2-backlink {
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--v2-ink-dim);
      display: inline-block;
      margin-bottom: 24px;
    }
    .v2-backlink a {
      color: var(--v2-ink-soft);
      border-bottom: 1px dotted var(--v2-border);
    }
    .v2-backlink a:hover { color: var(--v2-accent); border-bottom-color: var(--v2-accent); }
  </style>

  <div class="v2-page">
    <div class="v2-inner" style="max-width: 1180px; margin: 0 auto;">
    <div class="v2-backlink">
      <a href="/masons-v2">‹ Back to register</a> · Prototype view — live is at <a href="/masons">/masons</a>.
    </div>

    <section class="v2-section">
      <span class="v2-label">Profile</span>
      <div class="v2-profile">
        <div class="v2-rank-tile">
          <div class="v2-rank-avatar" data-stat="uid">—</div>
          <div class="v2-rank-seat" data-stat="seat">#—</div>
          <div class="v2-rank-caption">Cathedral</div>
        </div>
        <div class="v2-profile-body">
          <h1 class="v2-h1" data-stat="display-name">Loading mason…</h1>
          <div class="v2-handle">
            <span data-stat="hk-abbrev">—</span>
            <button type="button" class="v2-row-action" data-copy="full-hotkey">Copy full</button>
            <span class="v2-dot">·</span>
            <span><span class="v2-num" data-stat="uid-inline">—</span><span class="v2-unit">UID</span></span>
            <span><span class="v2-num" data-stat="hw-gpu-count">—</span><span class="v2-unit">GPUs</span></span>
            <span><span class="v2-num" data-stat="hw-country">—</span><span class="v2-unit">Located</span></span>
          </div>
          <div class="v2-tags">
            <span class="v2-tag v2-tag-role" data-stat="primary-tag">Mason</span>
            <span class="v2-tag v2-tag-sub" data-stat="status-tag" style="display:none;">Apprentice</span>
          </div>
          <div class="v2-quote" data-stat="bio">A stone at the wall.</div>
        </div>
      </div>
    </section>

    <section class="v2-section">
      <span class="v2-label">Classification</span>
      <div class="v2-classification">
        <p data-stat="classification">This mason's participation is read from the on-chain metagraph and our validator registry. They appear here because our validator has confirmed their hardware or is in the process of doing so. What's on this page is evidence — nothing else.</p>
      </div>
    </section>

    <section class="v2-section">
      <span class="v2-label">Evidence &amp; activity</span>
      <div class="v2-evidence-grid">
        <div class="v2-pane">
          <div class="v2-pane-head">Verification funnel</div>
          <div class="v2-donut-wrap">
            <div class="v2-donut" style="background: conic-gradient(var(--v2-chart-1) 0 60%, var(--v2-chart-2) 60% 85%, var(--v2-chart-3) 85% 100%);">
              <div class="v2-donut-label">Verified</div>
            </div>
            <div class="v2-legend">
              <div class="v2-legend-row"><span class="v2-legend-dot" style="background: var(--v2-chart-1)"></span><span class="v2-legend-label">Verified time</span><span class="v2-legend-val">60%</span></div>
              <div class="v2-legend-row"><span class="v2-legend-dot" style="background: var(--v2-chart-2)"></span><span class="v2-legend-label">Registered</span><span class="v2-legend-val">25%</span></div>
              <div class="v2-legend-row"><span class="v2-legend-dot" style="background: var(--v2-chart-3)"></span><span class="v2-legend-label">Declared only</span><span class="v2-legend-val">15%</span></div>
            </div>
          </div>
        </div>
        <div class="v2-pane">
          <div class="v2-pane-head">Hardware composition</div>
          <div class="v2-donut-wrap">
            <div class="v2-donut" data-stat="hw-donut" style="background: conic-gradient(var(--v2-chart-4) 0 70%, var(--v2-chart-5) 70% 100%);">
              <div class="v2-donut-label" data-stat="hw-donut-center">—</div>
            </div>
            <div class="v2-legend" data-stat="hw-legend">
              <div class="v2-legend-row"><span class="v2-legend-dot" style="background: var(--v2-chart-4)"></span><span class="v2-legend-label" data-stat="hw-l1">—</span><span class="v2-legend-val" data-stat="hw-v1">—</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="v2-section">
      <span class="v2-label">Embed</span>
      <div class="v2-embed" data-stat="embed">![Verified mason · cathedral.computer](https://cathedral.computer/api/mason-badge?h=&lt;hotkey&gt;)</div>
      <div class="v2-embed-note">Paste into a Twitter bio, a GitHub README, a block of HTML. Links back to this page.</div>
    </section>
    </div>
  </div>

  <script is:inline>
    (function () {
      const API_BASE = 'https://api.polaris.computer'
      const params = new URLSearchParams(window.location.search)
      const hotkey = params.get('h') || ''

      function abbrev(s) {
        if (!s || s.length < 10) return s || '—'
        return s.slice(0, 6) + '…' + s.slice(-4)
      }
      function setText(sel, val) {
        const el = document.querySelector(sel)
        if (el) el.textContent = val
      }
      function countryFromLocation(loc) {
        if (!loc) return null
        const parts = loc.split('/').map((p) => p.trim()).filter(Boolean)
        return parts.length ? parts[parts.length - 1] : null
      }
      async function fetchJson(url) {
        const ctrl = new AbortController()
        const t = setTimeout(() => ctrl.abort(), 20000)
        try {
          const r = await fetch(url, { cache: 'no-store', signal: ctrl.signal })
          if (!r.ok) return null
          return await r.json()
        } catch (_) { return null } finally { clearTimeout(t) }
      }

      setText('[data-stat="hk-abbrev"]', abbrev(hotkey))
      const copyBtn = document.querySelector('[data-copy="full-hotkey"]')
      if (copyBtn) {
        copyBtn.addEventListener('click', () => {
          if (!hotkey) return
          navigator.clipboard && navigator.clipboard.writeText(hotkey)
          copyBtn.textContent = 'Copied'
          setTimeout(() => { copyBtn.textContent = 'Copy full' }, 1400)
        })
      }

      async function load() {
        const [stateData, registry, machines] = await Promise.all([
          fetchJson(API_BASE + '/api/substrate/state'),
          fetchJson(API_BASE + '/api/substrate/validator/registry'),
          fetchJson(API_BASE + '/api/v1/cathedral/machines'),
        ])
        const miners = (stateData && stateData.miners) || []
        const me = miners.find((m) => (m.hotkey || '') === hotkey) || miners[0] || {}
        const regData = registry && registry.data ? registry.data : {}
        const regMiners = Array.isArray(regData.miners) ? regData.miners : []
        const myReg = regMiners.find((r) => r.uid === me.uid) || {}
        const verified = regMiners.filter((r) => r.status === 'verified').sort((a, b) => a.uid - b.uid)
        const apprentices = regMiners.filter((r) => r.status !== 'verified').sort((a, b) => a.uid - b.uid)

        // seat number: verified first (lowest seats), apprentices after
        let seat = 0
        for (let i = 0; i < verified.length; i++) {
          if (verified[i].uid === me.uid) { seat = i + 1; break }
        }
        if (!seat) {
          for (let i = 0; i < apprentices.length; i++) {
            if (apprentices[i].uid === me.uid) { seat = verified.length + i + 1; break }
          }
        }

        setText('[data-stat="uid"]', me.uid != null ? String(me.uid) : '—')
        setText('[data-stat="uid-inline"]', me.uid != null ? String(me.uid) : '—')
        setText('[data-stat="seat"]', seat ? '#' + seat : '#—')
        setText('[data-stat="display-name"]', 'Mason ' + (me.uid != null ? me.uid : '—'))

        const founding = seat > 0 && seat <= 10 && myReg.status === 'verified'
        const primaryTag = document.querySelector('[data-stat="primary-tag"]')
        if (primaryTag) {
          if (founding) {
            primaryTag.innerHTML = 'Founding <span class="v2-tag-num">#' + seat + '</span>'
          } else if (myReg.status === 'verified') {
            primaryTag.textContent = 'Mason'
          } else {
            primaryTag.textContent = 'Apprentice'
          }
        }

        // Pair hardware best-effort by index (same pattern used elsewhere)
        const machList = (machines && machines.machines) || []
        const allOrdered = verified.concat(apprentices)
        const idx = allOrdered.findIndex((r) => r.uid === me.uid)
        const hw = machList[idx] || null
        if (hw) {
          const gpuCount = hw.is_cpu_only ? 0 : (hw.gpu_count || 0)
          setText('[data-stat="hw-gpu-count"]', hw.is_cpu_only ? '0' : String(gpuCount))
          setText('[data-stat="hw-country"]', countryFromLocation(hw.location) || '—')
          setText('[data-stat="hw-donut-center"]', hw.category || (hw.is_cpu_only ? 'CPU' : '—'))
          setText('[data-stat="hw-l1"]', hw.is_cpu_only
            ? (hw.cpu_cores || 0) + ' vCPU · ' + (hw.memory_gb || 0) + ' GB'
            : (hw.gpu_count || 0) + '× ' + (hw.category || 'GPU'))
          setText('[data-stat="hw-v1"]', hw.is_cpu_only ? 'CPU' : ((hw.gpu_count || 0) + ' units'))
        } else {
          setText('[data-stat="hw-gpu-count"]', '—')
          setText('[data-stat="hw-country"]', '—')
          setText('[data-stat="hw-donut-center"]', '—')
        }

        // Embed snippet
        const embedEl = document.querySelector('[data-stat="embed"]')
        if (embedEl && hotkey) {
          embedEl.textContent = '![Verified mason · cathedral.computer](https://cathedral.computer/api/mason-badge?h=' + hotkey + ')'
        }
      }

      load()
    })()
  </script>
</Base>
