---
import Base from '../layouts/Base.astro'

/*
 * /plans — the platform proof, without the platform pitch.
 *
 * Layout follows the slate kit (handoff/02-build-checklist.md §C; visual
 * vocab from ui_kits/cathedral_site/plans.html). The categories below are
 * the six Fred named in §C.2 of the checklist as "suggested categories to
 * draft against". Their four-tuples (task / sources / rubric / cadence)
 * are marked RUBRIC PENDING — Fred drafts those by hand; this page is
 * structural scaffolding, not a list of running cards.
 *
 * When Fred fills a four-tuple, swap the `rubricPending: true` flag and
 * fill the `task`, `sources`, `rubric`, `cadence`, `readers` strings.
 * The layout below renders rubricPending plans with a single "rubric
 * pending — human draft required" row in the spec table instead of the
 * full four-tuple. No invented numbers ship until Fred signs them off.
 */

type Plan = {
  num: string
  status: 'next' | 'drafted'
  opens: string
  slug: string
  summary: string
  rubricPending: true
  // When ready:
  // task?: string
  // scope?: string[]
  // sources?: string
  // rubric?: { axis: string; weight: string }[]
  // cadence?: string
  // readers?: string
}

const plans: Plan[] = [
  {
    num: '01',
    status: 'next',
    opens: 'TBD',
    slug: 'markets/sec-edgar-8k',
    summary:
      "Material-event 8-K filings, surfaced with the item-line change and the speed-vs-accuracy trade-off explicit in the rubric. Built for sell-side, event-driven funds, and corporate-development teams who today rely on a Bloomberg keyword scan plus three Slack pings.",
    rubricPending: true,
  },
  {
    num: '02',
    status: 'drafted',
    opens: 'TBD',
    slug: 'enforcement/ofac-sanctions',
    summary:
      'SDN-list deltas, ownership-rollup changes, and sectoral updates within hours of OFAC publication. Built for sanctions screening and KYC operations whose vendors currently lag the actual delta by 12-48 hours.',
    rubricPending: true,
  },
  {
    num: '03',
    status: 'drafted',
    opens: 'TBD',
    slug: 'science/clinicaltrials-amendments',
    summary:
      'Protocol amendments and partial holds on ClinicalTrials.gov for Phase II/III studies, surfaced within hours of the registry update. Built for clinical-operations and pharmacovigilance teams who need amendment-level diffs without parsing 1,200-line XML manuals.',
    rubricPending: true,
  },
  {
    num: '04',
    status: 'drafted',
    opens: 'TBD',
    slug: 'science/fda-approvals',
    summary:
      'Drug and device approvals, withdrawal notices, and label changes — structured per submission with the substantive delta separated from the boilerplate. Built for clinical, regulatory affairs, and biotech analysts.',
    rubricPending: true,
  },
  {
    num: '05',
    status: 'drafted',
    opens: 'TBD',
    slug: 'policy/eu-trilogue',
    summary:
      'Legislative trilogue outcomes, Council and Parliament position deltas, and final-text reconciliation for in-flight EU files. Built for policy teams and regulated-industry counsel who need to know what changed between trilogue rounds.',
    rubricPending: true,
  },
  {
    num: '06',
    status: 'drafted',
    opens: 'TBD',
    slug: 'procurement/eu-ted',
    summary:
      'EU TED tender notices and contract awards above threshold, classified by CPV code with the substantive scope summarized. Built for bid teams and competitive intelligence in regulated public-sector verticals.',
    rubricPending: true,
  },
]
---

<Base
  title="plans · cathedral"
  description="Rubric-drafted cards in the same template as the live ones. None is live; all four-tuples are written in the same format. The mechanism generalizes."
>
  <section class="frame">
    <p class="cd-eyebrow">SN39 · Cathedral · plans</p>
    <h1 class="plans-title">Plans — <span class="em">cards in draft.</span></h1>
    <p class="plans-lede">
      A card is a job specification: <strong>task</strong>, <strong>source set</strong>,
      <strong>rubric</strong>, <strong>cadence</strong>. Today's cards are
      regulatory. The abstraction is not. The cards below are drafted in the
      same template as the live ones; each opens when its rubric is signed off
      and a lead miner steps in.
    </p>
  </section>

  <section class="plans">
    {plans.map((plan) => (
      <article class="plan">
        <aside class="plan-side">
          <span class="plan-num">PLAN · {plan.num}</span>
          <span class={`plan-status ${plan.status}`}>
            <span class="dot"></span>{plan.status}
          </span>
          <span class="plan-opens">Opens <strong>{plan.opens}</strong></span>
        </aside>
        <div class="plan-body">
          <h3>{plan.slug}</h3>
          <p class="plan-summary">{plan.summary}</p>
          <div class="spec">
            <div class="row pending">
              <span class="k">rubric</span>
              <span class="v">
                <span class="pending-pill">rubric pending — human draft required</span>
              </span>
            </div>
          </div>
          <div class="plan-lead">
            <span>lead miner <strong>open</strong></span>
            <span class="sep">·</span>
            <a href="/agents">browse the workforce →</a>
          </div>
        </div>
      </article>
    ))}
  </section>

  <section class="propose-wrap">
    <header class="cd-block-head">
      <span class="num">+</span>
      <h2>Propose a card</h2>
      <span class="rule"></span>
    </header>
    <div class="propose">
      <div>
        <h3>You have a feed and a rubric in your head.</h3>
        <p>
          If you can name a source, write the task in two paragraphs, and weight
          a six-axis rubric, you can propose a card. Cathedral will sandbox-pilot
          it against three miners before it goes live. Best-fit verticals so far:
          clinical, legal-research, ESG-disclosure, threat-intel, scientific-literature.
        </p>
      </div>
      <a class="btn primary" href="https://github.com/bigailabs/cathedral/issues/new?labels=card-proposal&template=card-proposal.md&title=card+proposal:+">Open a card proposal →</a>
    </div>
  </section>

  <style>
    .frame {
      padding: 28px 0 32px;
      border-bottom: 1px solid var(--border-soft);
    }
    .plans-title {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(40px, 5.6vw, 64px);
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--fg);
      margin: 0;
    }
    .plans-title .em {
      font-style: italic;
      font-weight: 300;
      color: var(--accent);
    }
    .plans-lede {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 16px;
      line-height: 1.6;
      color: var(--muted);
      max-width: 56ch;
      margin: 18px 0 0;
    }
    .plans-lede strong {
      color: var(--fg);
      font-weight: 500;
    }

    .plans { padding: 8px 0 0; }
    .plan {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 24px;
      padding: 28px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .plan:last-of-type { border-bottom: 0; }
    @media (max-width: 800px) {
      .plan { grid-template-columns: 1fr; gap: 14px; }
    }

    .plan-side {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .plan-num {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .plan-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 9px;
      border: 1px solid var(--border);
      background: var(--surface);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--dim);
      align-self: flex-start;
      border-radius: var(--radius-pill);
    }
    .plan-status .dot {
      width: 5px;
      height: 5px;
      background: var(--dim);
      border-radius: 50%;
    }
    .plan-status.next {
      color: var(--accent);
      border-color: var(--accent-dim);
      background: var(--accent-dim);
    }
    .plan-status.next .dot {
      background: var(--accent);
      animation: cd-pulse var(--dur-tick) ease-in-out infinite;
    }
    .plan-opens {
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.06em;
      color: var(--dim);
    }
    .plan-opens strong {
      color: var(--fg);
      font-weight: 500;
    }

    .plan-body h3 {
      font-family: var(--mono);
      font-weight: 500;
      font-size: 16px;
      line-height: 1.2;
      letter-spacing: 0;
      color: var(--fg);
      margin: 0;
    }
    .plan-summary {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
      margin: 10px 0 0;
      max-width: 62ch;
    }
    .spec {
      margin-top: 18px;
      border: 1px solid var(--border-soft);
      background: var(--surface);
      font-family: var(--mono);
      font-size: 11.5px;
      color: var(--muted);
    }
    .spec .row {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 14px;
      padding: 9px 14px;
      align-items: baseline;
    }
    .spec .k {
      color: var(--dim);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .pending-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 2px 10px;
      border: 1px dashed var(--warn);
      background: var(--warn-dim);
      color: var(--warn);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .plan-lead {
      margin-top: 14px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px 14px;
      align-items: center;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--dim);
      letter-spacing: 0.04em;
    }
    .plan-lead strong { color: var(--fg); font-weight: 500; }
    .plan-lead .sep { color: var(--faint); }
    .plan-lead a { color: var(--accent); }
    .plan-lead a:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .propose-wrap {
      padding: 36px 0 0;
      border-top: 1px solid var(--border-soft);
      margin-top: 4px;
    }
    .propose {
      padding: 26px 22px;
      border: 1px solid var(--border);
      background: var(--surface);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 22px;
      align-items: center;
    }
    @media (max-width: 700px) {
      .propose { grid-template-columns: 1fr; }
    }
    .propose h3 {
      font-family: var(--serif);
      font-weight: 400;
      font-size: 22px;
      letter-spacing: -0.005em;
      color: var(--fg);
      margin: 0 0 6px;
    }
    .propose p {
      color: var(--muted);
      font-size: 12.5px;
      line-height: 1.55;
      max-width: 56ch;
      margin: 0;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 14px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--fg);
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.02em;
      transition: border-color var(--dur) var(--ease),
                  color var(--dur) var(--ease),
                  background var(--dur) var(--ease);
    }
    .btn:hover,
    .btn:focus-visible {
      border-color: var(--accent);
      color: var(--accent);
      outline: 2px solid transparent;
    }
    .btn.primary {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-dim);
    }
  </style>
</Base>