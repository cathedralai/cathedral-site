---
import Base from '../layouts/Base.astro'

type Issue = {
  number: number
  title: string
  state: 'open' | 'closed'
  html_url: string
  labels: { name: string }[]
  pull_request?: unknown
}

const ACTS = [
  { id: 'act-1', num: '01', title: 'Foundation', blurb: 'Lay the base course. Get the validator and the first masons\u2019 stones reliable, unlock weights with stake, harden the REST API. The foundation itself was poured by Basilica — see /origins. Nothing rises until this sets.' },
  { id: 'act-2', num: '02', title: 'The work',   blurb: 'Make laying stones on cathedral economically coherent. Generalize the image pipeline. The business model is being worked out in public — one stone at a time.' },
  { id: 'act-3', num: '03', title: 'The yard',   blurb: 'External masons join the courtyard. Masons at the wall, patrons in the chapel, clerks at the books. Subnet scouting. A treasury view that shows compute in, mining out — the ledger anyone can read.' },
] as const

async function fetchIssues(): Promise<{ issues: Issue[]; ok: boolean }> {
  try {
    const headers: Record<string, string> = { 'Accept': 'application/vnd.github+json', 'User-Agent': 'cathedral-site' }
    const token = import.meta.env.GITHUB_TOKEN || process.env.GITHUB_TOKEN
    if (token) headers.Authorization = `Bearer ${token}`
    const r = await fetch('https://api.github.com/repos/cathedralai/cathedral/issues?state=all&per_page=100', { headers })
    if (!r.ok) return { issues: [], ok: false }
    const data = (await r.json()) as Issue[]
    return { issues: data.filter((i) => !i.pull_request), ok: true }
  } catch { return { issues: [], ok: false } }
}

const { issues, ok: fetchOk } = await fetchIssues()

function forAct(actId: string): Issue[] {
  return issues
    .filter((i) => i.labels.some((l) => l.name === actId))
    .sort((a, b) => {
      const aEpic = a.labels.some((l) => l.name === 'epic') ? 0 : 1
      const bEpic = b.labels.some((l) => l.name === 'epic') ? 0 : 1
      if (aEpic !== bEpic) return aEpic - bEpic
      if (a.state !== b.state) return a.state === 'open' ? -1 : 1
      return a.number - b.number
    })
}

const unlabeled = issues.filter((i) => !i.labels.some((l) => /^act-[123]$/.test(l.name)))
const total = issues.length
const openCount = issues.filter((i) => i.state === 'open').length
---

<Base title="roadmap · cathedral">
  <style>
    .eyebrow {
      font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--dim); display: flex; align-items: baseline; gap: 10px;
    }
    .eyebrow .num { font-variant-numeric: tabular-nums; color: var(--accent); }
    .sec { padding: 56px 0; border-bottom: 1px solid var(--border-soft); }
    .sec:last-of-type { border-bottom: 0; }
    .sec .wrap { display: grid; grid-template-columns: 160px 1fr; gap: 48px; }
    @media (max-width: 900px) {
      .sec { padding: 44px 0; } .sec .wrap { grid-template-columns: 1fr; gap: 20px; }
    }
    .lede {
      font-family: var(--serif);
      font-size: 20px; font-weight: 300; line-height: 1.45; color: var(--fg);
      max-width: 34ch; margin: 0;
    }
    .lede em { font-style: italic; color: var(--muted); }
    .act-title {
      font-family: var(--serif);
      font-size: 22px; font-weight: 300; color: var(--fg); max-width: 36ch;
    }
    .act-title em { font-style: italic; color: var(--muted); }
    .issue-row {
      display: flex; align-items: baseline; gap: 12px;
      padding: 10px 0; border-bottom: 1px solid var(--border-soft);
      font-size: 12px;
    }
    .issue-row:last-child { border-bottom: 0; }
    .issue-row .num { font-variant-numeric: tabular-nums; width: 44px; flex-shrink: 0; }
    .issue-row .num.open { color: var(--accent); }
    .issue-row .num.closed { color: var(--dim); }
    .issue-row .t { flex: 1; min-width: 0; color: var(--fg); }
    .issue-row a:hover .t { color: var(--accent); }
    .issue-row .tags { display: inline-flex; gap: 8px; flex-shrink: 0; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; }
    .issue-row .tags .epic { color: var(--accent); }
    .issue-row .tags .security { color: var(--warn); }
    .issue-row .tags .state { color: var(--dim); }
    .issue-row .tags .state.open { color: var(--muted); }

    /* Thin banner — 19th-century stonework, desaturated, edges faded so
       it reads as a watermark under the page title, not a photograph. */
    .banner {
      width: 100%; height: 80px; margin-bottom: 24px;
      background-image: url('/images/stonework-nypl.jpg');
      background-size: cover; background-position: center 60%;
      filter: grayscale(1) contrast(0.95) brightness(0.95);
      opacity: 0.32;
      border-bottom: 1px solid var(--border-soft);
      mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
    }
    html[data-theme='light'] .banner { opacity: 0.24; filter: grayscale(1) contrast(0.9) brightness(1.04); }
  </style>

  <div class="banner" role="presentation" aria-hidden="true"></div>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">00</span><span>Roadmap</span></div></div>
      <div>
        <p class="lede">Three acts, in rough order.<br/><em>Foundation, then walls, then the yard.</em></p>
        <p class="text-[12px] text-muted leading-relaxed mt-4 max-w-[56ch]">
          The arc we think the work wants to take. Scope shifts as we learn. Live from
          <a href="https://github.com/cathedralai/cathedral/issues" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">GitHub issues</a>.
        </p>
        {total > 0 && (
          <p class="text-[11px] text-dim mt-3 tabular-nums">
            {openCount} open · {total - openCount} closed · {total} total
          </p>
        )}
      </div>
    </div>
  </section>

  {!fetchOk && (
    <section class="sec">
      <div class="wrap">
        <div></div>
        <div class="border border-border bg-surface px-4 py-3">
          <p class="text-[12px] text-muted leading-relaxed">
            GitHub's API rate-limited our build. Source of truth is
            <a href="https://github.com/cathedralai/cathedral/issues" class="text-fg hover:text-accent underline underline-offset-2 decoration-dim ml-1">the issue tracker</a>.
          </p>
        </div>
      </div>
    </section>
  )}

  {ACTS.map((act) => {
    const items = forAct(act.id)
    const open = items.filter((i) => i.state === 'open').length
    const parts = act.blurb.split('. ')
    const lede = parts[0] + (parts.length > 1 ? '.' : '')
    const rest = parts.slice(1).join('. ')
    return (
      <section class="sec">
        <div class="wrap">
          <div><div class="eyebrow"><span class="num">{act.num}</span><span>{act.title}</span></div></div>
          <div>
            <p class="act-title">{lede}</p>
            {rest && <p class="text-[12px] text-muted leading-relaxed mt-3 max-w-[64ch]">{rest}</p>}
            <div class="flex items-baseline justify-between gap-4 mt-6 mb-3">
              <h3 class="text-[10px] text-dim uppercase tracking-[0.2em]">In the issue tracker</h3>
              {items.length > 0 && (
                <span class="text-[11px] text-dim tabular-nums shrink-0">{open} open · {items.length} total</span>
              )}
            </div>
            {items.length === 0 ? (
              <p class="text-[11.5px] text-dim italic">{fetchOk ? 'nothing filed yet' : 'see github'}</p>
            ) : (
              <div style="border-top: 1px solid var(--border);">
                {items.map((i) => {
                  const isEpic = i.labels.some((l) => l.name === 'epic')
                  const isSec = i.labels.some((l) => l.name === 'security')
                  return (
                    <a href={i.html_url} class="issue-row">
                      <span class={`num ${i.state}`}>#{i.number}</span>
                      <span class="t">{i.title}</span>
                      <span class="tags">
                        {isEpic && <span class="epic">epic</span>}
                        {isSec && <span class="security">sec</span>}
                        <span class={`state ${i.state}`}>{i.state}</span>
                      </span>
                    </a>
                  )
                })}
              </div>
            )}
          </div>
        </div>
      </section>
    )
  })}

  {unlabeled.length > 0 && (
    <section class="sec">
      <div class="wrap">
        <div><div class="eyebrow"><span class="num">·</span><span>Unscoped</span></div></div>
        <div>
          <p class="text-[11.5px] text-muted leading-relaxed mb-4">Filed but not yet assigned to an act.</p>
          <div style="border-top: 1px solid var(--border);">
            {unlabeled.map((i) => (
              <a href={i.html_url} class="issue-row">
                <span class={`num ${i.state}`}>#{i.number}</span>
                <span class="t">{i.title}</span>
                <span class="tags"><span class={`state ${i.state}`}>{i.state}</span></span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="sec">
    <div class="wrap">
      <div></div>
      <p class="text-[11px] text-dim leading-relaxed">
        Something missing? <a href="https://github.com/cathedralai/cathedral/issues/new" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">File it</a>.
      </p>
    </div>
  </section>
</Base>
