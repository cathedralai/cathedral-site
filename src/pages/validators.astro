---
import Base from '../layouts/Base.astro'
import { metrics } from '../data/regulatoryIntelligence'
---

<Base title="validators · cathedral">
  <section class="hero">
    <p class="label">Validators</p>
    <h1>Score the evidence, not the story.</h1>
    <p>
      Cathedral validators check deployability, source quality, hidden review tasks, maintenance, and downstream Polaris usage before rewards matter.
    </p>
  </section>

  <section class="score-grid">
    <article>
      <span>30%</span>
      <h2>Source quality</h2>
      <p>Official laws, regulators, government guidance, and official policy pages score highest.</p>
    </article>
    <article>
      <span>20%</span>
      <h2>Freshness</h2>
      <p>Cards must show when sources were checked and whether anything changed.</p>
    </article>
    <article>
      <span>15%</span>
      <h2>Specificity</h2>
      <p>Good cards name the jurisdiction, topic, dates, obligations, and uncertainty.</p>
    </article>
    <article>
      <span>20%</span>
      <h2>Usefulness</h2>
      <p>Readers should know what changed, why it matters, and what to check next.</p>
    </article>
    <article>
      <span>15%</span>
      <h2>Clarity</h2>
      <p>Cards should be concise, readable, and clearly marked as regulatory intelligence.</p>
    </article>
  </section>

  <section class="section split">
    <div>
      <p class="label">Local verifier</p>
      <h2>Run the same basic checks</h2>
    </div>
    <div class="code">
      <pre>just regulatory-preflight
just regulatory-preflight-invalid
just regulatory-e2e</pre>
    </div>
  </section>

  <section class="section split">
    <div>
      <p class="label">Guardrails</p>
      <h2>What does not count</h2>
    </div>
    <ul>
      <li>Uncited claims.</li>
      <li>Legal advice phrased as instructions.</li>
      <li>Creator-owned or platform-owned usage.</li>
      <li>Refunded or abuse-flagged credit spend.</li>
      <li>Broken worker deploy links.</li>
      <li>Cards that stop being maintained.</li>
    </ul>
  </section>

  <section class="section facts">
    <div><span>Cards</span><strong>{metrics.cardsTotal}</strong></div>
    <div><span>Sources</span><strong>{metrics.sourceCount}</strong></div>
    <div><span>Sample live</span><strong>{metrics.cardsLive}</strong></div>
  </section>

  <style>
    .hero {
      padding: 54px 0 38px;
      border-bottom: 1px solid var(--border-soft);
    }
    .label {
      margin: 0 0 12px;
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    h1, h2 {
      margin: 0;
      color: var(--fg);
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-weight: 300;
      line-height: 1.08;
    }
    h1 {
      max-width: 820px;
      font-size: clamp(42px, 7vw, 82px);
    }
    h2 {
      font-size: 28px;
    }
    .hero p:not(.label),
    .score-grid p,
    .section li {
      color: var(--muted);
      font-size: 15px;
      line-height: 1.65;
    }
    .hero p:not(.label) {
      max-width: 760px;
      margin-top: 20px;
      font-size: 17px;
    }
    .score-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1px;
      margin: 30px 0;
      border: 1px solid var(--border-soft);
      background: var(--border-soft);
    }
    .score-grid article {
      min-height: 230px;
      padding: 18px;
      background: var(--surface);
    }
    .score-grid span {
      display: block;
      margin-bottom: 28px;
      color: var(--accent);
      font-size: 24px;
      font-variant-numeric: tabular-nums;
    }
    .section {
      padding: 42px 0;
      border-top: 1px solid var(--border-soft);
    }
    .split {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 32px;
    }
    .code {
      border: 1px solid var(--border);
      background: var(--surface);
      padding: 18px;
      overflow-x: auto;
    }
    pre {
      margin: 0;
      color: var(--fg);
      font-size: 12px;
      line-height: 1.7;
    }
    ul {
      margin: 0;
      padding: 0;
      list-style: none;
    }
    li {
      padding: 10px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .facts {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--border-soft);
      background: var(--border-soft);
    }
    .facts div {
      background: var(--surface);
      padding: 18px;
    }
    .facts span {
      display: block;
      color: var(--dim);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .facts strong {
      display: block;
      margin-top: 8px;
      color: var(--fg);
      font-size: 28px;
    }
    @media (max-width: 900px) {
      .score-grid,
      .split,
      .facts {
        grid-template-columns: 1fr;
      }
      .score-grid article {
        min-height: 0;
      }
    }
  </style>
</Base>
