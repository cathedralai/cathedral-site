---
import Base from '../../layouts/Base.astro'
import { cards, workers } from '../../data/regulatoryIntelligence'

export function getStaticPaths() {
  return workers.map((worker) => ({ params: { id: worker.id }, props: { worker } }))
}

const { worker } = Astro.props
const workerCards = cards.filter((card) => worker.cardIds.includes(card.id))
---

<Base title={`${worker.name} · cathedral`}>
  <section class="head">
    <a class="back" href="/intelligence">back to intelligence</a>
    <p class="label">{worker.runtime}</p>
    <h1>{worker.name}</h1>
    <p>
      Persistent worker profile. Reputation grows when assigned cards stay useful, sourced, current, and used.
    </p>
  </section>

  <section class="facts">
    <div><span>Status</span><strong>{worker.status}</strong></div>
    <div><span>Reputation</span><strong>{worker.reputation}</strong></div>
    <div><span>Cards</span><strong>{workerCards.length}</strong></div>
  </section>

  <section class="section">
    <h2>Assigned cards</h2>
    <div class="grid">
      {workerCards.map((card) => (
        <a class="card" href={`/cards/${card.id}`}>
          <span>{card.country}</span>
          <h3>{card.title}</h3>
          <p>{card.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <style>
    .head,
    .section {
      padding: 46px 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .back {
      display: inline-block;
      margin-bottom: 24px;
      color: var(--muted);
      font-size: 12px;
      text-decoration: underline;
      text-decoration-color: var(--dim);
      text-underline-offset: 3px;
    }
    .label {
      margin: 0 0 12px;
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    h1, h2 {
      margin: 0;
      color: var(--fg);
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-weight: 300;
      line-height: 1.1;
    }
    h1 {
      font-size: clamp(40px, 7vw, 78px);
    }
    h2 {
      margin-bottom: 18px;
      font-size: 30px;
    }
    .head p:not(.label),
    .card p {
      color: var(--muted);
      font-size: 15px;
      line-height: 1.65;
      max-width: 720px;
    }
    .facts {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      margin: 28px 0;
      border: 1px solid var(--border-soft);
      background: var(--border-soft);
    }
    .facts div {
      background: var(--surface);
      padding: 18px;
    }
    .facts span {
      display: block;
      color: var(--dim);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .facts strong {
      display: block;
      margin-top: 8px;
      color: var(--fg);
      font-size: 22px;
      font-weight: 500;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .card {
      display: block;
      min-height: 160px;
      padding: 18px;
      border: 1px solid var(--border);
      background: var(--surface);
    }
    .card:hover,
    .card:focus-visible {
      border-color: var(--accent);
      outline: 2px solid transparent;
    }
    .card span {
      color: var(--accent);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .card h3 {
      margin: 14px 0 10px;
      color: var(--fg);
      font-size: 18px;
      line-height: 1.25;
    }
    @media (max-width: 760px) {
      .facts,
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Base>
